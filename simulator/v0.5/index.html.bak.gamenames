// ============================================================================
// 5트랙 진척 시스템 (v1.0 — DEAD NEXUS 사이버펑크 정체성으로 리네이밍)
// ============================================================================
// 각 플레이어 5개 트랙 0~5 LV. 직접 투자(R&D 페이즈) 또는 카드 효과로 +1.
// 거리명성(Street Cred) = 5트랙 합. LV 임계 효과 (LV2 패시브 / LV4 강화 / LV5 once-ability).
// 내부 키는 호환성 유지 (combat/transport/mfg/party/security), 표시명만 사이버펑크화
const TRACK_KEYS = ['combat', 'transport', 'mfg', 'party', 'security'];
const TRACK_NAMES = {
  combat:    { name: '화력',     icon: '💥', desc: 'ATK·레이드 파워 — 솔로/킬러 라이프패스' },
  transport: { name: '그리드런', icon: '🌃', desc: '이동·도주 — 노매드 라이프패스' },
  mfg:       { name: '코드',     icon: '💾', desc: '부품·무기·해킹 — 넷러너/리거 라이프패스' },
  party:     { name: '인맥',     icon: '🤝', desc: '크레딧·영향력·접선 — 픽서 라이프패스' },
  security:  { name: '그림자',   icon: '🎭', desc: 'DEF·위장·은폐 — 첩보 라이프패스' },
};
// v1.0: 총합 지표명 (악명 → 거리명성 / Street Cred — Cyberpunk RPG 핵심 용어)
const STREETCRED_LABEL = '거리명성';
const TRACK_MAX = 5;

// 트랙별 투자 비용 (R&D 페이즈 직접 레벨업) — 트랙 성격에 맞는 자원
const TRACK_COST = {
  combat:    { weapons: 2 },  // 무력: 무기 2
  transport: { credit: 3 },   // 수송: ₵3
  mfg:       { parts: 2 },    // 제조: 부품 2
  party:     { credit: 3 },   // 파티: ₵3 (인맥 작업)
  security:  { data: 2 },     // 경호: 정보 2
};

// 클래스별 시작 트랙 (사이버펑크 라이프패스 풍)
const CLASS_STARTING_TRACKS = {
  // Ghost
  CIPHER:   { security: 1, mfg: 1, transport: 1 },     // v0.6.5a: transport 1 추가
  BLADE:    { combat: 2, security: 1, transport: 1 },  // v0.6.5a: transport 1 추가
  RIGGER:   { mfg: 2, transport: 1, combat: 1 },       // v0.6.5a: security→transport (드론 클래스라 이동도 필요)
  BROKER:   { party: 2, transport: 2, security: 1 },   // v0.6.5a: transport 강조 (협상가는 발이 빠름)
  DRIFTER:  { transport: 2, combat: 1, mfg: 1 },       // 균형 (변경 없음)
  MOLE:     { security: 2, transport: 2, party: 1 },   // v0.6.5a: transport 1→2 (잠입가는 발이 빨라야)
  // Bloc
  VANTA:    { party: 1, security: 2 },
  IRONWALL: { combat: 2, security: 1 },
  HELIX:    { mfg: 1, party: 1, security: 1 },
  AXIOM:    { mfg: 2, security: 1 },
  CARBON:   { mfg: 1, transport: 1, party: 1 },
};

const initTracks = (specific) => {
  const start = CLASS_STARTING_TRACKS[specific] || {};
  const tracks = {};
  TRACK_KEYS.forEach(k => { tracks[k] = start[k] || 0; });
  return { tracks };
};

// 거리명성(Street Cred) = 5트랙 합 — DEAD NEXUS Ashgrid 2091 핵심 지표
function getInfamy(player) {
  if (!player.tracks) return 0;
  return TRACK_KEYS.reduce((sum, k) => sum + (player.tracks[k] || 0), 0);
}

// 트랙 직접 레벨업 (자원 차감 + 레벨 +1) — 보통 R&D 페이즈에서 호출
// 반환: { ok: bool, state: newState, reason: string }
function levelUpTrack(state, playerIdx, key, opts = {}) {
  if (!TRACK_KEYS.includes(key)) return { ok: false, state, reason: '잘못된 트랙' };
  const p = state.players[playerIdx];
  const tracks = { ...(p.tracks || {}) };
  const curLv = tracks[key] || 0;
  if (curLv >= TRACK_MAX) return { ok: false, state, reason: 'LV5 도달' };
  // 비용 검증 (free 옵션이면 스킵)
  const cost = opts.free ? {} : (TRACK_COST[key] || {});
  for (const [resKey, amt] of Object.entries(cost)) {
    if ((p.resources[resKey] || 0) < amt) return { ok: false, state, reason: `${resKey} ${amt} 필요` };
  }
  // 자원 차감
  const ps = [...state.players];
  const newP = { ...p };
  newP.resources = { ...p.resources };
  for (const [resKey, amt] of Object.entries(cost)) {
    newP.resources[resKey] = (newP.resources[resKey] || 0) - amt;
  }
  tracks[key] = curLv + 1;
  newP.tracks = tracks;
  ps[playerIdx] = newP;
  let s = { ...state, players: ps };
  const tn = TRACK_NAMES[key];
  const marker = playerIdx === 0 ? '⭐ 당신 ' : '';
  const costStr = Object.entries(cost).map(([k, v]) => `-${v}${k.charAt(0).toUpperCase()}`).join(' ');
  s = logEntry(s, `${marker}${tn.icon} P${playerIdx} [${newP.specific}] · ${tn.name} 트랙 LV${curLv + 1} 투자 ${costStr ? `(${costStr})` : '(무료)'} · ${STREETCRED_LABEL} ${getInfamy(newP)}`);
  s = checkInfamyMilestones(s, playerIdx);
  return { ok: true, state: s, reason: '' };
}

// 트랙 자동 상승 — 카드 효과·액션 결과로 무료 +1 (보통 1칸)
// levelUpTrack과 달리 자원 비용 없음, 게임 중 누적 가능
function raiseTrack(state, playerIdx, key, n = 1, reason = '') {
  if (!TRACK_KEYS.includes(key)) return state;
  const p = state.players[playerIdx];
  if (!p || p.defeated) return state;
  const tracks = { ...(p.tracks || {}) };
  const curLv = tracks[key] || 0;
  if (curLv >= TRACK_MAX) return state;
  const newLv = Math.min(TRACK_MAX, curLv + n);
  if (newLv === curLv) return state;
  tracks[key] = newLv;
  const ps = [...state.players];
  ps[playerIdx] = { ...p, tracks };
  let s = { ...state, players: ps };
  const tn = TRACK_NAMES[key];
  const marker = playerIdx === 0 ? '⭐ 당신 ' : '';
  s = logEntry(s, `${marker}${tn.icon} P${playerIdx} [${p.specific}] · ${tn.name} LV${curLv}→${newLv} (${reason || '액션'}) · ${STREETCRED_LABEL} ${getInfamy(ps[playerIdx])}`);
  // v0.6.4: LV5 도달 시 once-ability 해금
  if (newLv === 5 && curLv < 5) {
    const onceMap = {
      combat: 'critFailImmunity',     // 무력 LV5: 크리티컬 실패 영구 면역
      transport: 'teleport',           // 수송 LV5: 1회 텔레포트
      mfg: 'droneFree',                // 제조 LV5: 1회 무료 드론
      party: 'reroll',                 // 파티 LV5: 1회 주사위 리롤
      security: 'deathSave',           // 경호 LV5: 1회 HP 0→1 부활
    };
    const ability = onceMap[key];
    if (ability) {
      const abilities = { ...(ps[playerIdx].onceAbilities || {}), [ability]: true };
      ps[playerIdx] = { ...ps[playerIdx], onceAbilities: abilities };
      s = { ...s, players: ps };
      s = logEntry(s, `🌟 P${playerIdx} [${p.specific}] · ${tn.name} LV5 궁극 해금 — ${ability}`);
    }
  }
  s = checkInfamyMilestones(s, playerIdx);
  return s;
}

// v0.6.3c: 트랙 LV별 패시브 보너스 (사이버펑크 라이프패스식)
// LV2: 기본 +1 / LV4: 추가 +2 (총 +3) / LV5: 추가 +1 (총 +4)
function trackBonus(p, kind) {
  if (!p?.tracks) return 0;
  const t = p.tracks;
  let b = 0;
  const map = { atk: 'combat', spd: 'transport', def: 'security', hack: 'mfg' };
  const trackKey = map[kind];
  if (!trackKey) return 0;
  const lv = t[trackKey] || 0;
  if (lv >= 2) b += 1;
  if (lv >= 4) b += 2;
  if (lv >= 5) b += 1;
  return b;
}

// v0.6.3e: Bloc 건물 건설 시스템 (Brass + Gallerist 영감)
// 자사 구역에 건물 1개 건설 → 영구 패시브. Ghost 레이드로 파괴 가능
const BUILDINGS = {
  factory:   { name: '공장',     icon: '🏭', tl: 1, cost: { credit: 4, parts: 2 }, desc: '매 라운드 부품 +2' },
  hq:        { name: '사옥',     icon: '🏢', tl: 2, cost: { credit: 6 },           desc: '자산 +5 영구, 매 라운드 인플루언스 +1' },
  security:  { name: '보안센터', icon: '🛡', tl: 1, cost: { credit: 3, parts: 1 }, desc: '구역 요새화 +2 영구 (레이드 방어)' },
  trading:   { name: '거래소',   icon: '📈', tl: 2, cost: { credit: 5 },           desc: '매 라운드 자사 주식 +1, 매 R&D 크레딧 +3' },
  media:     { name: '미디어허브', icon: '📡', tl: 3, cost: { credit: 5, parts: 2 }, desc: '뉴스 효과 -50% (받기), Ghost 수배 +1 (옆 도시)' },
};
function canBuildBuilding(state, playerIdx, key, coord) {
  const p = state.players[playerIdx];
  if (!p || p.role !== 'bloc' || p.defeated) return { ok: false, reason: 'Bloc 전용' };
  const cell = state.map[coord];
  if (!cell || cell.owner !== playerIdx) return { ok: false, reason: '자사 구역만' };
  if (cell.building) return { ok: false, reason: '이미 건물 존재' };
  const cfg = BUILDINGS[key];
  if (!cfg) return { ok: false, reason: '잘못된 건물' };
  if ((p.tl || 1) < cfg.tl) return { ok: false, reason: `TL${cfg.tl} 필요` };
  for (const [r, amt] of Object.entries(cfg.cost)) {
    if ((p.resources[r] || 0) < amt) return { ok: false, reason: `${r} ${amt} 필요` };
  }
  return { ok: true };
}

// v0.6.3d: SETI 시그널 — NPC 블록 정보 점진 공개
const SIGNAL_REVEAL_COST = { data: 3 };  // data 3 → +1 시그널
const SIGNAL_LEVEL_DESC = {
  0: '정체 미상 (???)',
  1: '정체 확인',
  2: '방어 특성 노출',
  3: '완전 노출 (레이드 시 보너스 약탈)',
};
function revealSignal(state, npcIdx, by = 0, n = 1) {
  const npc = state.players[npcIdx];
  if (!npc?.isNpc || !npc.signal) return state;
  const cur = npc.signal.revealed || 0;
  if (cur >= npc.signal.max) return state;
  const next = Math.min(npc.signal.max, cur + n);
  if (next === cur) return state;
  const ps = [...state.players];
  ps[npcIdx] = { ...npc, signal: { ...npc.signal, revealed: next } };
  let s = { ...state, players: ps };
  const marker = by === 0 ? '⭐ 당신 ' : '';
  s = logEntry(s, `${marker}📡 NPC P${npcIdx} 시그널 ${cur}→${next}: ${SIGNAL_LEVEL_DESC[next]}${next === 3 ? ' [' + npc.specific + ']' : ''}`);
  return s;
}

// 트랙 패시브 자원 보너스 (수익 페이즈에서 호출)
function trackIncomeBonus(p) {
  if (!p?.tracks) return { credit: 0, parts: 0 };
  const t = p.tracks;
  let credit = 0, parts = 0;
  const partyLv = t.party || 0;
  if (partyLv >= 2) credit += 1;
  if (partyLv >= 4) credit += 2;
  if (partyLv >= 5) credit += 1;
  const mfgLv = t.mfg || 0;
  if (mfgLv >= 2) parts += 1;
  if (mfgLv >= 4) parts += 2;
  if (mfgLv >= 5) parts += 1;
  return { credit, parts };
}

// 거리명성 마일스톤 (Street Cred 누적 보상)
// 6: 자원 보상 / 12: TL Progress +3 / 18: 승점 마일스톤
const INFAMY_MILESTONES = [6, 12, 18];
const MILESTONES_ENABLED = true;  // v0.6.3b 디버그용 토글

// v0.9.1: 하이라이트 모먼트 — 게임 중 기억할 만한 순간 (보드라이프 "기억남는 한 수" 디자인)
const HIGHLIGHT_DEFS = {
  // v0.9.3-fix: 평판 보상 일괄 -2 (5×5에서 Ghost 폭주 방지)
  first_nexus_visit:    { icon: '🌐', label: '첫 NEXUS 도달',          rep: 3,  desc: '도시의 신경망에 첫 접속' },
  first_nexus_claim:    { icon: '👑', label: '첫 NEXUS 점령',          rep: 5,  desc: 'Ashgrid 중앙을 장악' },
  first_raid_success:   { icon: '🗡',  label: '첫 레이드 성공',         rep: 2,  desc: '첫 Bloc 구역 중립화' },
  first_infiltrate:     { icon: '🕷',  label: '첫 잠입형 레이드',        rep: 2,  desc: '방어 우회 침투' },
  first_building_kill:  { icon: '🏚', label: '첫 건물 파괴',           rep: 3,  desc: 'Bloc 인프라 무력화' },
  first_mini_raid:      { icon: '⚡', label: '첫 mini-raid 발동',       rep: 2,  desc: '카드 효과로 자동 raid' },
  milestone_18:         { icon: '🏆', label: '거리명성 18 전설',         rep: 2,  desc: 'Ashgrid의 전설이 됨' },
  last_stand_activate:  { icon: '⚰️', label: '최후 저항 발동',          rep: 3,  desc: 'HP 1로 광폭화' },
  death_save:           { icon: '🛡', label: 'deathSave 부활',          rep: 2,  desc: '그림자 LV5 능력으로 부활' },
  defeat_revive:        { icon: '🧬', label: '동료 부활 (CLONE_DECOY)', rep: 2,  desc: 'HELIX 클론으로 사망 동료 복귀' },
  bounty_hit:           { icon: '🎯', label: '현상금/청부 명중',         rep: 1,  desc: 'Bloc의 능동 액션 성공' },
  ten_zone_hold:        { icon: '🏙', label: '10구역 동시 점유',         rep: 3,  desc: 'Bloc 영토 확장 정점' },
};

// v0.9.3: NEXUS 동적 컨트롤 — 누가 NEXUS 점유 중인지에 따라 글로벌 룰 변동
// NEXUS 좌표 (5×5: C3, 11×11: F6)
function getNexusCoord(state) {
  return state.meta.mapSize === '11x11' ? 'F6' : 'C3';
}
function getNexusController(state) {
  const coord = getNexusCoord(state);
  const cell = state.map[coord];
  if (!cell || cell.owner === null || cell.owner === undefined) return null;
  return state.players[cell.owner];
}
// Bloc별 NEXUS 컨트롤 글로벌 룰
const NEXUS_RULES = {
  VANTA:    { id: 'info_open',    label: '정보 공개', desc: '모든 NPC 시그널 +1, 정찰 효과 +1' },
  IRONWALL: { id: 'martial',      label: '계엄령',     desc: '모든 ATK +1 / Ghost 수배 +1/R' },
  HELIX:    { id: 'biocode',      label: '바이오 코드', desc: '모든 플레이어 매 R HP+1' },
  AXIOM:    { id: 'algo_market',  label: '알고리즘 시장', desc: '주식 변동 ×2, 모든 매 R 데이터+1' },
  CARBON:   { id: 'energy_grid',  label: '에너지 망',   desc: '모든 자사 구역 수입 +1 크레딧' },
};
// Ghost가 컨트롤 중일 때는 룰 무효화 (NEXUS는 Ghost가 점령해도 중립)
function getActiveNexusRule(state) {
  const ctrl = getNexusController(state);
  if (!ctrl || ctrl.role !== 'bloc') return null;
  return NEXUS_RULES[ctrl.specific];
}

// 하이라이트 기록 — 1회성 (이미 받았으면 재발동 X)
function recordHighlight(state, key, playerIdx) {
  const def = HIGHLIGHT_DEFS[key];
  if (!def) return state;
  const list = state.meta.highlights || [];
  const dupe = list.find(h => h.key === key && h.playerIdx === playerIdx);
  if (dupe) return state;  // 1회성
  const entry = { key, playerIdx, round: state.meta.round, label: def.label, icon: def.icon, rep: def.rep };
  let s = { ...state, meta: { ...state.meta, highlights: [...list, entry] } };
  // 평판 보상
  if (def.rep > 0) {
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + def.rep } };
    s = { ...s, players: ps };
  }
  const marker = playerIdx === 0 ? '⭐ 당신 ' : '';
  s = logEntry(s, `${marker}${def.icon} P${playerIdx} · 하이라이트 [${def.label}] · ${def.desc} · ★+${def.rep}`);
  return s;
}
function checkInfamyMilestones(state, playerIdx) {
  if (!MILESTONES_ENABLED) return state;
  const p = state.players[playerIdx];
  if (!p) return state;
  const infamy = getInfamy(p);
  const awarded = (state.meta.milestonesAwarded && state.meta.milestonesAwarded[playerIdx]) || [];
  let s = state;
  for (const ms of INFAMY_MILESTONES) {
    if (infamy >= ms && !awarded.includes(ms)) {
      s = applyInfamyMilestone(s, playerIdx, ms);
      const newAwarded = [...awarded, ms];
      const allAwarded = { ...(s.meta.milestonesAwarded || {}), [playerIdx]: newAwarded };
      s = { ...s, meta: { ...s.meta, milestonesAwarded: allAwarded } };
    }
  }
  return s;
}

function applyInfamyMilestone(state, playerIdx, ms) {
  const p = state.players[playerIdx];
  const ps = [...state.players];
  let s = state;
  const marker = playerIdx === 0 ? '⭐ 당신 ' : '';
  // v0.6.3b: 마일스톤은 "도장" 같은 작은 보너스로. 게임 종결을 직접 만들지 않음.
  if (ms === 6) {
    // 6: 자원 한 묶음 — Ghost ★+1 ₵+2, Bloc ₵+3 ⚙+1
    const gain = p.role === 'ghost' ? { rep: 1, credit: 2 } : { credit: 3, parts: 1 };
    ps[playerIdx] = { ...p, resources: { ...p.resources, rep: (p.resources.rep || 0) + (gain.rep || 0), credit: (p.resources.credit || 0) + (gain.credit || 0), parts: (p.resources.parts || 0) + (gain.parts || 0) } };
    s = { ...s, players: ps };
    s = logEntry(s, `${marker}☠ P${playerIdx} [${p.specific}] · ${STREETCRED_LABEL} 6 마일스톤 — ${p.role === 'ghost' ? '★+1 ₵+2' : '₵+3 ⚙+1'}`);
  } else if (ms === 12) {
    // 12: TL Progress +3 (자동 승급 X) + 자원 약간
    const newProg = (p.tlProgress || 0) + 3;
    ps[playerIdx] = { ...p, tlProgress: newProg, resources: { ...p.resources, rep: (p.resources.rep || 0) + 1, credit: (p.resources.credit || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `${marker}☠ P${playerIdx} [${p.specific}] · ${STREETCRED_LABEL} 12 마일스톤 — TL진척+3 ★+1 ₵+3`);
  } else if (ms === 18) {
    // 18: 전설 — Ghost는 ★+3, Bloc은 ₵+5 + 영구 영향력+1
    if (p.role === 'ghost') {
      ps[playerIdx] = { ...p, resources: { ...p.resources, rep: (p.resources.rep || 0) + 3 } };
    } else {
      ps[playerIdx] = { ...p, resources: { ...p.resources, credit: (p.resources.credit || 0) + 5, influence: (p.resources.influence || 0) + 1 } };
    }
    s = { ...s, players: ps };
    s = logEntry(s, `${marker}🏆 P${playerIdx} [${p.specific}] · ${STREETCRED_LABEL} 18 전설 마일스톤 — ${p.role === 'ghost' ? '★+3' : '₵+5 영향력+1'}`);
    s = recordHighlight(s, 'milestone_18', playerIdx);  // v0.9.1
  }
  return s;
}

// ============================================================================
// 맵 크기별 특수 규칙 (v0.5.13)
// ============================================================================
// 5×5 튜토리얼: 좁은 맵 → 이동 가치 상향 / DRIFTER HP·ATK 보정 (이미 적용)
// 11×11 표준: 이동 가치 정상 / DRIFTER 원래 스탯 복원 / 추가 공권력 감쇠
// 13×13 확장: 하이웨이 강화 / M&A 빈도 증가
const MAP_RULES = {
  '5x5': {
    roundLimit: 10,
    moveMultiplier: 1.0,      // 이동 카드 기본 효율
    driftAtkOverride: 2,       // DRIFTER atk (튜토리얼)
    driftHpOverride: 8,
    assetGoal: 50,
    repGoal: { battle: 14, repOnly: 20 },
    raidGoal: 2,
  },
  '11x11': {
    roundLimit: 12,
    moveMultiplier: 1.0,
    driftAtkOverride: 4,       // DRIFTER 원래 스탯 (넓은 맵에서 이동 가치 정상)
    driftHpOverride: 9,
    assetGoal: 60,
    repGoal: { battle: 30, repOnly: 40 },
    raidGoal: 2,
  },
};
const getMapRules = (mapSize) => MAP_RULES[mapSize] || MAP_RULES['5x5'];

// TL 승급 비용: v0.5.21 — 전 레벨 5pt 균일 (1칸=1pt 직관 보장)
const tlCostFor = (curTl) => {
  if (curTl >= 5) return 99;
  return 5;
};

// ============================================================================
// 게임 히스토리 (LocalStorage) — 브라우저 로컬에만 저장, 서버 전송 없음
// ============================================================================
const HISTORY_KEY = 'dn_sim_history_v053';
const loadHistory = () => {
  try {
    const raw = localStorage.getItem(HISTORY_KEY);
    return raw ? JSON.parse(raw) : [];
  } catch { return []; }
};
const saveGameRecord = (rec) => {
  try {
    const h = loadHistory();
    h.unshift(rec);
    localStorage.setItem(HISTORY_KEY, JSON.stringify(h.slice(0, 50)));  // 최근 50판만
  } catch (e) { console.warn('history save failed', e); }
};
const clearHistory = () => {
  try { localStorage.removeItem(HISTORY_KEY); } catch {}
};
const buildGameRecord = (state) => {
  const me = state.players[0];
  const iWon = state.meta.winner === 0;
  return {
    ts: Date.now(),
    round: state.meta.round,
    role: me.role,
    specific: me.specific,
    won: iWon,
    winner: state.meta.winner,
    winnerSpecific: state.meta.winner != null ? state.players[state.meta.winner]?.specific : null,
    reason: state.meta.winReason,
    hp: me.hp,
    rep: me.resources.rep,
    asset: assetValue(me, state.stocks, state),
    raids: state.meta.raidsThisGame?.[0] || 0,
    tl: me.tl,
    achievements: me.achievements.length,
    zones: Object.values(state.map).filter(c => c.owner === 0).length,
  };
};
const formatHistoryTime = (ts) => {
  const d = new Date(ts);
  const pad = n => String(n).padStart(2, '0');
  return `${d.getMonth()+1}/${d.getDate()} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
};

const coord = (col, row) => String.fromCharCode(65 + col) + (row + 1);
// v0.7.3: 두 번째 인자 maxIdx (0-based 최대 인덱스). 5×5는 4, 11×11은 10. 미지정 시 10 (큰 보드).
const coordsAdj = (c, maxIdx = 10) => {
  const col = c.charCodeAt(0) - 65;
  const row = parseInt(c.slice(1)) - 1;
  return [
    col > 0      ? coord(col - 1, row) : null,
    col < maxIdx ? coord(col + 1, row) : null,
    row > 0      ? coord(col, row - 1) : null,
    row < maxIdx ? coord(col, row + 1) : null,
  ].filter(Boolean);
};

// 자기 블록 주식: 통제권 표시, 자산 X
// 자산 = Σ(타 블록 주식 × 주가) + 구역 수 × 5
// 크레딧은 유동 자원이라 자본에 안 넣음 (자산 인플레 방지)
const assetValue = (p, stocks, state) => {
  // v0.5.16: Bloc 경제 개선
  // - 구역 가치 5 → 7 (구역 확장 가속)
  // - 크레딧 1/3 반영 (현금 보유도 자산의 일부, 단 유동성 할인)
  // - 무기/부품/데이터도 소액 자산화 (각 1pt)
  let total = 0;
  for (const [bl, qty] of Object.entries(p.stocks)) {
    const isOwn = p.role === 'bloc' && p.specific === bl;
    if (isOwn) continue;
    const price = stocks[bl] ?? 10;
    total += qty * price;
  }
  if (state?.map) {
    const zonesOwned = Object.values(state.map).filter(c => c.owner === p.id).length;
    total += zonesOwned * 5;
    // v0.6.3e: 건물 자산 보너스 — 사옥 +5, 거래소 +3, 공장/보안센터 +2, 미디어허브 +4
    const buildingValue = { hq: 5, trading: 3, factory: 2, security: 2, media: 4 };
    Object.values(state.map).forEach(cell => {
      if (cell.owner === p.id && cell.building) total += (buildingValue[cell.building] || 0);
    });
  }
  // v0.5.16 결론: 자산 구성은 순수하게 (타 블록 주식 + 구역)만 유지.
  // Bloc/Ghost P0 격차는 assetGoal 이 아닌 Ghost 승리 루트 수 문제.
  return Math.floor(total);
};

// Resource init
const initResources = (role) => role === 'bloc'
  ? { credit: 8, data: 2, influence: 3, weapons: 0, parts: 0, rep: 0 }
  : { credit: 5, data: 0, influence: 0, weapons: 0, parts: 0, rep: 5 };

// Initial stocks for bloc player
const initStocks = (role, specific) => {
  const base = { VANTA: 0, IRONWALL: 0, HELIX: 0, AXIOM: 0, CARBON: 0 };
  if (role === 'bloc') base[specific] = 10;
  return base;
};

// ============================================================================
// GAME STATE + REDUCER
// ============================================================================

function initGame(humanRole, humanSpecific, playerCount, mapSize, extraOpts) {
  // v0.7.3: 5x5 또는 11x11 맵 빌드 (mapSize 미지정 시 5x5)
  // v1.0: extraOpts = { mode, difficulty, humans } — 솔로/멀티 모드, 난이도, 추가 인간 정의
  const useSize = mapSize === '11x11' ? '11x11' : '5x5';
  const mapSrc = useSize === '11x11' ? MAP_11x11 : MAP_5x5;
  const blocSetupSrc = useSize === '11x11' ? BLOC_SETUP_11x11 : BLOC_SETUP;
  const mode = extraOpts?.mode || 'solo';
  const difficulty = extraOpts?.difficulty || 'normal';
  const humansList = extraOpts?.humans || null;
  const map = {};
  mapSrc.forEach(([c, z]) => {
    map[c] = { zone: z, owner: null, token: Math.random() < 0.6 ? 'quest' : (Math.random() < 0.5 ? 'instant' : 'discovery'), tokenRevealed: false };
  });

  // v1.0.2: 멀티 모드면 humansList 길이만큼 인간, 나머지는 봇으로
  // 솔로/봇만 모드: 1 human + (playerCount-1) bots
  const totalPlayers = Math.max(2, Math.min(5, playerCount || 4));
  const players = [];
  const allBlocs = ['VANTA', 'IRONWALL', 'HELIX', 'AXIOM', 'CARBON'];
  const allGhosts = ['CIPHER', 'BLADE', 'BROKER', 'RIGGER', 'DRIFTER', 'MOLE'];
  const usedBlocs = [];
  const usedGhosts = [];
  const pickBloc = () => { const avail = allBlocs.filter(b => !usedBlocs.includes(b)); const p = rand(avail); usedBlocs.push(p); return p; };
  const pickGhost = () => { const avail = allGhosts.filter(g => !usedGhosts.includes(g)); const p = rand(avail); usedGhosts.push(p); return p; };

  if (mode === 'multi' && humansList && humansList.length >= 2) {
    // 멀티 핫시트: humansList 그대로 인간 P0~P(N-1)
    humansList.forEach((h, i) => {
      players.push(buildPlayer(i, 'human', h.role, h.specific));
      if (h.role === 'bloc') usedBlocs.push(h.specific);
      else usedGhosts.push(h.specific);
    });
    // 빈 자리 봇 보충 (총 totalPlayers까지)
    const botCount = Math.max(0, totalPlayers - humansList.length);
    // 균형: 인간 Ghost 수 vs Bloc 수 차이를 봇이 보충
    const humanGhostN = humansList.filter(h => h.role === 'ghost').length;
    const humanBlocN  = humansList.filter(h => h.role === 'bloc').length;
    for (let i = 0; i < botCount; i++) {
      const needGhost = humanGhostN + (botCount > 0 ? Math.floor(i / 2) : 0) <= humanBlocN;
      const r = needGhost ? 'ghost' : 'bloc';
      const sp = r === 'bloc' ? pickBloc() : pickGhost();
      players.push(buildPlayer(humansList.length + i, 'bot', r, sp));
    }
  } else {
    // 솔로/단일 인간 모드
    if (humanRole === 'bloc') usedBlocs.push(humanSpecific);
    else usedGhosts.push(humanSpecific);
    players.push(buildPlayer(0, 'human', humanRole, humanSpecific));
    const botCount = totalPlayers - 1;
    const botSpecs = [];
    const oppositeRole = humanRole === 'bloc' ? 'ghost' : 'bloc';
    const botRoles = [];
    for (let i = 0; i < botCount; i++) {
      if (i === 0) botRoles.push(oppositeRole);
      else if (i === 1 && botCount >= 2) botRoles.push(oppositeRole);
      else botRoles.push(i % 2 === 0 ? oppositeRole : humanRole);
    }
    botRoles.forEach(r => botSpecs.push({ role: r, sp: r === 'bloc' ? pickBloc() : pickGhost() }));
    botSpecs.forEach((bs, i) => players.push(buildPlayer(i + 1, 'bot', bs.role, bs.sp)));
  }

  // v0.6.1: 2인 모드 NPC 중립 블록 2개 추가 (Bloc 편향 해소)
  // v0.6.3d: NPC는 SETI식 시그널(정보)을 점진 공개하는 표적 역할
  if (totalPlayers === 2) {
    const npc1 = pickBloc();
    const npc2 = pickBloc();
    const npcP1 = buildPlayer(players.length, 'npc', 'bloc', npc1);
    const npcP2 = buildPlayer(players.length + 1, 'npc', 'bloc', npc2);
    npcP1.isNpc = true;
    npcP2.isNpc = true;
    // v0.6.3d: 시그널 — 0=완전 미상, 1=정체, 2=특성, 3=완전 노출 (보너스 약탈)
    npcP1.signal = { revealed: 0, max: 3 };
    npcP2.signal = { revealed: 0, max: 3 };
    players.push(npcP1);
    players.push(npcP2);
  }

  // v1.0.1: 솔로 모드 난이도 보정 — easy: 인간 시작 자원 +5 / hard: 봇 시작 자원 +5
  if (mode === 'solo' && difficulty === 'easy') {
    const p0 = players[0];
    p0.resources = { ...p0.resources, credit: (p0.resources.credit || 0) + 5, weapons: (p0.resources.weapons || 0) + 1, parts: (p0.resources.parts || 0) + 1, data: (p0.resources.data || 0) + 1 };
  } else if (mode === 'solo' && difficulty === 'hard') {
    for (let i = 1; i < players.length; i++) {
      players[i].resources = { ...players[i].resources, credit: (players[i].resources.credit || 0) + 5, weapons: (players[i].resources.weapons || 0) + 1 };
    }
  }

  // Set bloc HQ zones as owned
  players.forEach(p => {
    if (p.role === 'bloc') {
      const setup = blocSetupSrc[p.specific];
      map[setup.hq].owner = p.id;
      setup.support.forEach(s => { map[s].owner = p.id; });
      p.position = setup.hq;
    } else {
      // v0.7.3: 11×11에서는 Ghost 시작 위치를 외곽으로 분산
      if (useSize === '11x11') {
        const ghostStarts11 = {
          CIPHER: 'A6', BLADE: 'F1', BROKER: 'K6', RIGGER: 'F11',
          DRIFTER: 'A1', MOLE: 'K11',
        };
        p.position = ghostStarts11[p.specific] || 'F6';
        // v0.8.4: 11×11 Ghost 시작 자원 보강 — 큰 보드 이동 비용 보전
        // 시작 ₵+5 / 무기+1 / 데이터+1 / 부품+1 + transport 트랙 +1
        p.resources = { ...p.resources, credit: (p.resources.credit || 0) + 5, weapons: (p.resources.weapons || 0) + 1, data: (p.resources.data || 0) + 1, parts: (p.resources.parts || 0) + 1 };
        if (p.tracks) p.tracks = { ...p.tracks, transport: (p.tracks.transport || 0) + 1 };
      } else {
        p.position = GHOST_STATS[p.specific].startZone;
      }
    }
  });

  // Deal objectives
  const objBloc = shuffle(OBJECTIVES.filter(o => o.role === 'bloc'));
  const objGhost = shuffle(OBJECTIVES.filter(o => o.role === 'ghost'));
  let bi = 0, gi = 0;
  players.forEach(p => {
    if (p.role === 'bloc') {
      p.objectives = [objBloc[bi++ % objBloc.length], objBloc[bi++ % objBloc.length]];
    } else {
      p.objectives = [objGhost[gi++ % objGhost.length], objGhost[gi++ % objGhost.length]];
    }
  });

  return {
    meta: {
      scenario: 'S01',
      mapSize: useSize,
      round: 1,
      phase: 0,
      currentPlayer: 0,
      humanPlayer: 0,
      turnInit: null,
      gameOver: false,
      winner: null,
      winReason: null,
      newsSinceStart: 0,
      raidsThisGame: Object.fromEntries([...Array(5).keys()].map(k => [k, 0])),
      zonesVisited: Object.fromEntries([...Array(5).keys()].map(k => [k, new Set()])),
      attacksUsed: Object.fromEntries([...Array(5).keys()].map(k => [k, 0])),
      lostCardsUsed: Object.fromEntries([...Array(5).keys()].map(k => [k, 0])),
      nexusHolder: null,
      nexusStreak: 0,
      claimedAchievements: {},  // id => playerIdx
      milestonesAwarded: Object.fromEntries([...Array(5).keys()].map(k => [k, []])),  // v0.6.3b: 거리명성 마일스톤 기록
      highlights: [],            // v0.9.1: 하이라이트 모먼트 기록 (게임 중 기억할 한 수)
      promises: [],              // v0.9.2: 협상 약속 트래킹
      mode,                      // v1.0.1: 'solo' | 'multi' (핫시트) | 'bots' (시뮬)
      difficulty,                // v1.0.1: easy / normal / hard (솔로 한정)
      activePlayer: 0,           // v1.0.2: 핫시트용 — 현재 차례 인간 인덱스
      pendingMoveTarget: null,   // 사용자가 지도에서 찍은 목표 좌표 (Ghost/Bloc 둘 다)
      awaitingMoveTarget: false, // true면 UI에서 목표 클릭 대기
      moveBudget: 0,             // 이번 턴 총 이동 칸 수 (BFS 반경)
      turnSnapshot: null,        // 턴 전 상태 스냅샷 (변화 요약용)
      turnDiff: null,            // 턴 후 계산된 변화 요약
      zoneBonusPending: null,    // { zone: 'home', coord: 'B3', options: [{...},{...},{...}] }
      visitedBonusZones: {},     // { playerIdx: { coord: true } } — 보너스를 이미 받은 구역
      pendingRaid: null,         // { coord, bloc, zoneNm, atk, threshold } — 사용자 레이드 결정 대기
      chosenTargets: [],         // [ { cardIdx, half, targetPlayerIdx } ] — 사용자가 지정한 공격 타겟들
      pendingTargetSelect: null, // { cardId, half, effectKey, candidates, cardIdx } — UI가 타겟 고를 수 있게
      pendingGhostDuel: null,    // { coord, atkGhostIdx, defGhostIdx } — Ghost PvP 결정 대기
      lastTargetedBy: null,      // { attacker, effectKey, detail } — 봇이 P0 타겟했을 때 표시
      attackBonusOnce: 0,        // 일회성 공격 판정 보너스
      peekNews: 0,               // 남은 peek 카운트 (cop/data 보너스)
      mapReveal: 0,              // 남은 전체 지도 노출 라운드
      moveBonusNext: 0,          // 다음 턴 이동 보너스 (port 보너스)
      atkBonusOnce: 0,           // 일회성 공격 판정 보너스 (arms 보너스)
    },
    players,
    map,
    pool: { M: 0, I: 0, V: 0, S: 0, B: 0, A: 0, GRID: 0 },
    stocks: { VANTA: 8, IRONWALL: 8, HELIX: 8, AXIOM: 8, CARBON: 8 },
    heat: 5,
    signalDie: rollSignalDie(),
    currentNews: null,
    log: [{ round: 0, phase: 0, message: '🎮 게임 시작. 튜토리얼 5×5 · 시나리오 S01' }],
  };
}

function buildPlayer(id, kind, role, specific) {
  const deck = role === 'bloc' ? BLOC_DECKS[specific] : GHOST_DECKS[specific];
  const stats = role === 'bloc' ? BLOC_STATS[specific] : GHOST_STATS[specific];
  const trackInit = initTracks(specific);
  return {
    id, kind, role, specific,
    hp: stats.hp,
    maxHp: stats.hp,
    stats,
    resources: initResources(role),
    stocks: initStocks(role, specific),
    deck: shuffle(deck),
    hand: [],
    discard: [],
    lost: [],
    contracts: [],
    wanted: 0,
    tl: 1,
    tlProgress: 0,
    position: null,
    zonesOwned: [],
    pool: { M: 0, I: 0, V: 0, S: 0, B: 0, A: 0, GRID: 0 },
    objectives: [],
    achievements: [],
    defeated: false,
    plannedCards: [],
    plannedHalves: [],
    // v0.6.3: 5트랙 시스템 (Speakeasy 악명식 — 직접 투자, 총악명=합)
    tracks: trackInit.tracks,
    onceAbilities: { critFailImmunity: false, droneFree: false, reroll: false, teleport: false, deathSave: false },
  };
}

// Reducer actions
function reducer(state, action) {
  switch (action.type) {
    case 'DRAW_INITIAL': {
      // Draw hand size depending on role
      const ps = state.players.map(p => {
        const handSize = 6;
        const newHand = p.deck.slice(0, handSize);
        const newDeck = p.deck.slice(handSize);
        return { ...p, hand: newHand, deck: newDeck };
      });
      return { ...state, players: ps };
    }

    case 'LOG':
      return { ...state, log: [...state.log, { round: state.meta.round, phase: state.meta.phase, message: action.msg }].slice(-150) };

    case 'SET_PHASE':
      return { ...state, meta: { ...state.meta, phase: action.phase } };

    case 'REQUEST_MOVE_TARGET':
      return { ...state, meta: { ...state.meta, awaitingMoveTarget: true, moveBudget: action.budget || 0, pendingMoveTarget: null } };

    case 'SET_MOVE_TARGET':
      return { ...state, meta: { ...state.meta, awaitingMoveTarget: false, pendingMoveTarget: action.coord } };

    case 'CLEAR_MOVE_TARGET':
      return { ...state, meta: { ...state.meta, awaitingMoveTarget: false, pendingMoveTarget: null, moveBudget: 0 } };

    case 'APPLY_ZONE_BONUS': {
      // action.opt: 선택된 옵션 객체 {k, v, label}
      const pending = state.meta.zoneBonusPending;
      if (!pending) return state;
      const opt = action.opt;
      let s = { ...state };
      const me = s.players[0];
      let res = { ...me.resources };
      let pool = { ...(me.pool || {}) };
      let hp = me.hp;
      let maxHp = me.maxHp;
      let wanted = me.wanted || 0;
      let heat = s.heat;
      let metaPatch = {};
      const logLines = [];
      switch (opt.k) {
        case 'credit': res.credit = (res.credit || 0) + opt.v; logLines.push(`₵ +${opt.v}`); break;
        case 'data': res.data = (res.data || 0) + opt.v; logLines.push(`📡 데이터 +${opt.v}`); break;
        case 'weapons': res.weapons = (res.weapons || 0) + opt.v; logLines.push(`🔩 무기 +${opt.v}`); break;
        case 'parts': res.parts = (res.parts || 0) + opt.v; logLines.push(`⚙️ 부품 +${opt.v}`); break;
        case 'influence': res.influence = (res.influence || 0) + opt.v; logLines.push(`🎙 인플루언스 +${opt.v}`); break;
        case 'rep': res.rep = (res.rep || 0) + opt.v; logLines.push(`★ 렙 +${opt.v}`); break;
        case 'heal': hp = Math.min(maxHp, hp + opt.v); logLines.push(`❤️ HP +${opt.v} (→${hp})`); break;
        case 'full_heal': hp = maxHp; logLines.push(`❤️❤️ HP 완전 회복 (→${hp})`); break;
        case 'wanted': wanted = Math.max(0, wanted + opt.v); logLines.push(`🚨 현상수배 ${opt.v > 0 ? '+' : ''}${opt.v} (→${wanted})`); break;
        case 'heat_down': heat = Math.max(0, heat - opt.v); logLines.push(`🔥 공권력 -${opt.v} (→${heat})`); break;
        case 'gen': pool[opt.v] = (pool[opt.v] || 0) + 1; logLines.push(`◈${opt.v} +1 (개인 풀)`); break;
        case 'all_attr':
          ['M','I','V','S','B','A'].forEach(a => { pool[a] = (pool[a] || 0) + opt.v; });
          logLines.push(`◈ 전속성 +${opt.v}`);
          break;
        case 'random_attr': {
          const pick = rand(['M','I','V','S','B','A']);
          pool[pick] = (pool[pick] || 0) + opt.v;
          logLines.push(`◈${pick} +${opt.v} (랜덤)`);
          break;
        }
        case 'draw': {
          const deck = [...(me.deck || [])];
          const handAdd = deck.splice(0, opt.v);
          const newHand = [...(me.hand || []), ...handAdd];
          // 플레이어에 반영 예약 (아래에서 한 번에 저장)
          metaPatch._drawNew = { deck, hand: newHand };
          logLines.push(`🂠 카드 ${handAdd.length}장 드로우`);
          break;
        }
        case 'stock_buy': {
          // 임의 선택 불가라 랜덤 블록 1주 할인 매수
          const blocs = Object.keys(s.stocks);
          const pick = rand(blocs);
          const cost = Math.max(1, s.stocks[pick] - opt.v);
          if (res.credit >= cost) {
            res.credit -= cost;
            const newStocks = { ...me.stocks, [pick]: (me.stocks[pick] || 0) + 1 };
            metaPatch._stocksNew = newStocks;
            logLines.push(`📈 ${pick} 주식 1주 매수 (₵${cost})`);
          } else {
            logLines.push(`📈 주식 할인 매수 — ₵부족 (필요 ${cost})`);
          }
          break;
        }
        case 'peek_news':
          metaPatch.peekNews = (s.meta.peekNews || 0) + opt.v;
          logLines.push(`👁 다음 뉴스 ${opt.v}장 미리보기 적립`);
          break;
        case 'info':
          metaPatch.mapReveal = (s.meta.mapReveal || 0) + 3;
          logLines.push(`👁 지도 3R 노출`);
          break;
        case 'move_bonus':
          metaPatch.moveBonusNext = (s.meta.moveBonusNext || 0) + opt.v;
          logLines.push(`🚶 다음 턴 이동 +${opt.v}`);
          break;
        case 'atk_boost':
          metaPatch.atkBonusOnce = (s.meta.atkBonusOnce || 0) + opt.v;
          logLines.push(`💥 다음 판정 +${opt.v} (일회성)`);
          break;
        default:
          logLines.push(`(${opt.k} 미구현)`);
      }
      // 플레이어 상태 병합
      let ps = [...s.players];
      const p0Next = {
        ...me,
        resources: res,
        pool,
        hp,
        wanted,
      };
      if (metaPatch._drawNew) {
        p0Next.deck = metaPatch._drawNew.deck;
        p0Next.hand = metaPatch._drawNew.hand;
        delete metaPatch._drawNew;
      }
      if (metaPatch._stocksNew) {
        p0Next.stocks = metaPatch._stocksNew;
        delete metaPatch._stocksNew;
      }
      ps[0] = p0Next;
      const meta2 = { ...s.meta, zoneBonusPending: null, ...metaPatch };
      s = { ...s, players: ps, heat, meta: meta2 };
      s = logEntry(s, `⭐ 당신 🌟 ${pending.coord} 보너스 획득 · ${opt.label}${logLines.length > 1 ? ` [${logLines.join(', ')}]` : ''}`);
      return s;
    }

    case 'SKIP_ZONE_BONUS':
      return { ...state, meta: { ...state.meta, zoneBonusPending: null } };

    case 'RAID_SELECT_TYPE': {
      const pr = state.meta.pendingRaid;
      if (!pr) return state;
      // v0.6.3c: 트랙 레벨 잠금 검증
      const cfg = RAID_TYPES[action.raidType];
      if (cfg?.requiresTrack) {
        const me = state.players[0];
        const lv = me?.tracks?.[cfg.requiresTrack.key] || 0;
        if (lv < cfg.requiresTrack.lv) {
          return { ...state, log: [...state.log, { round: state.meta.round, phase: state.meta.phase, message: `❌ ${cfg.name} 잠김 — ${TRACK_NAMES[cfg.requiresTrack.key].name} LV${cfg.requiresTrack.lv} 필요 (현재 LV${lv})` }].slice(-150) };
        }
      }
      return { ...state, meta: { ...state.meta, pendingRaid: { ...pr, selectedType: action.raidType, phase: 'invest' } } };
    }

    case 'RAID_INVEST': {
      // action.item: 'weapons' | 'data' | 'poolAttr' (with action.attr for pool)
      const pr = state.meta.pendingRaid;
      if (!pr) return state;
      const me = state.players[0];
      const inv = { ...pr.invested };
      if (action.item === 'weapons' && (me.resources.weapons || 0) > inv.weapons) {
        inv.weapons++;
      } else if (action.item === 'data' && (me.resources.data || 0) > inv.data) {
        inv.data++;
      } else if (action.item === 'poolAttr' && action.attr) {
        if ((me.pool?.[action.attr] || 0) > 0 && !inv.poolAttr) {
          inv.poolAttr = action.attr;
        }
      } else if (action.item === 'unset_pool') {
        inv.poolAttr = null;
      } else if (action.item === 'reset') {
        inv.weapons = 0; inv.data = 0; inv.poolAttr = null;
      }
      return { ...state, meta: { ...state.meta, pendingRaid: { ...pr, invested: inv } } };
    }

    case 'RAID_EXECUTE': {
      const pr = state.meta.pendingRaid;
      if (!pr || !pr.selectedType) return state;
      let s = { ...state };
      const me = s.players[0];
      const rtype = RAID_TYPES[pr.selectedType];
      const zoneLoot = ZONE_LOOT[pr.zoneType] || {};
      const bloc = pr.bloc;
      const counterBonus = countersBloc(me.specific, bloc) ? 1 : 0;

      // 투자 자원 소비
      const inv = pr.invested;
      const newRes = { ...me.resources };
      if (inv.weapons > 0) newRes.weapons = Math.max(0, (newRes.weapons || 0) - inv.weapons);
      if (inv.data > 0) newRes.data = Math.max(0, (newRes.data || 0) - inv.data);
      const newPool = { ...(me.pool || {}) };
      if (inv.poolAttr) newPool[inv.poolAttr] = Math.max(0, (newPool[inv.poolAttr] || 0) - 1);

      // 레이드 타입별 비용 선지불 (협상형·드론형 등)
      if (rtype.cost) {
        if (rtype.cost.credit) {
          if ((newRes.credit || 0) >= rtype.cost.credit) newRes.credit -= rtype.cost.credit;
          else {
            s = logEntry(s, `⭐ 당신 ${rtype.icon} ${rtype.name} 실패 (비용 ₵${rtype.cost.credit} 부족)`);
            return { ...s, meta: { ...s.meta, pendingRaid: null } };
          }
        }
        if (rtype.cost.parts) {
          if ((newRes.parts || 0) >= rtype.cost.parts) newRes.parts -= rtype.cost.parts;
          else {
            s = logEntry(s, `⭐ 당신 ${rtype.icon} ${rtype.name} 실패 (부품 ${rtype.cost.parts}개 부족)`);
            return { ...s, meta: { ...s.meta, pendingRaid: null } };
          }
        }
      }

      // Bloc 자동 반격 (잠입형은 bypass)
      const defense = rtype.bypass_defense ? {} : (BLOC_DEFENSE[bloc] || {});
      let thresholdMod = 0;
      let approachMod = 0;
      let executeMod = 0;
      let escapeMod = 0;
      const defenseLogs = [];
      if (rtype.bypass_defense) defenseLogs.push('🕷 방어 우회');
      if (defense.threshold_plus) { thresholdMod += defense.threshold_plus; defenseLogs.push(`${bloc} 방어 +${defense.threshold_plus} threshold`); }
      if (defense.detect) { approachMod -= 2; defenseLogs.push(`${bloc} 센서 감지 (접근 -2)`); }
      if (defense.all_plus) { approachMod += 0 - defense.all_plus; executeMod -= defense.all_plus; escapeMod -= defense.all_plus; defenseLogs.push(`${bloc} AI 보조 (전 판정 ${-defense.all_plus})`); }
      if (pr.fortified > 0 && !rtype.bypass_defense) { thresholdMod += pr.fortified; defenseLogs.push(`요새화 +${pr.fortified}`); }

      const finalThreshold = rtype.threshold + thresholdMod;

      // 투자 보너스
      const zoneAttr = ZONE_TYPES[pr.zoneType]?.attr;
      const poolBonus = inv.poolAttr === zoneAttr ? 2 : (inv.poolAttr ? 1 : 0);
      const execBonus = inv.weapons + counterBonus + executeMod;
      const approachBonus = inv.data + approachMod;
      const escapeBonus = escapeMod;

      // === 3단계 판정 ===
      // 1. Approach (접근) — d6 + SHADE 속성 투자 (data) vs 4
      const approachRoll = d6();
      const approachTotal = approachRoll + approachBonus + (inv.poolAttr === 'S' ? 2 : 0);
      const approachOK = approachTotal >= 4;

      // 2. Execute (실행) — d6 + 선택한 스탯 + 투자 + 상성 + 트랙 보너스 vs threshold
      // v0.5.25: 크리티컬 실패 — d6 = 1은 자동 실패 (스탯 무관)
      // v0.6.3c: 트랙 패시브 보너스 (combat/mfg/transport LV2~5)
      const execRoll = d6();
      const statVal = me.stats[rtype.useStat] || 0;
      const trackVal = trackBonus(me, rtype.useStat);
      const execTotal = execRoll + statVal + trackVal + execBonus + poolBonus + (approachOK ? 0 : -2);
      const critFail = execRoll === 1;
      // v0.6.3c: combat LV4+ 또는 onceAbilities.critFailImmunity → 크리티컬 실패 면역
      const critImmune = (me.tracks?.combat || 0) >= 4 || me.onceAbilities?.critFailImmunity;
      const execOK = (!critFail || critImmune) && execTotal >= finalThreshold;

      // 3. Escape (도주) — d6 + SPD + 수송 트랙 보너스 vs 3
      const escapeRoll = d6();
      const escapeTotal = escapeRoll + me.stats.spd + trackBonus(me, 'spd') + escapeBonus;
      const escapeOK = escapeTotal >= 3;

      // 결과 적용
      const cell = s.map[pr.coord];
      let rewards = rtype.success;
      let outcome = 'success';
      if (!execOK) {
        rewards = rtype.failure;
        outcome = 'failure';
      }

      const ps = [...s.players];
      let updatedP = { ...me, resources: newRes, pool: newPool };

      // 보상/페널티 적용
      if (outcome === 'success') {
        updatedP.resources.rep = (updatedP.resources.rep || 0) + (rewards.rep || 0);
        if (rewards.data) updatedP.resources.data = (updatedP.resources.data || 0) + rewards.data;
        if (rewards.parts) updatedP.resources.parts = Math.max(0, (updatedP.resources.parts || 0) + rewards.parts);
        if (rewards.influence) updatedP.resources.influence = (updatedP.resources.influence || 0) + rewards.influence;
        updatedP.wanted = (updatedP.wanted || 0) + (rewards.wanted || 0);
        // 구역 차등 전리품
        if (zoneLoot.credit) updatedP.resources.credit = (updatedP.resources.credit || 0) + zoneLoot.credit;
        if (zoneLoot.data) updatedP.resources.data = (updatedP.resources.data || 0) + zoneLoot.data;
        if (zoneLoot.weapons) updatedP.resources.weapons = (updatedP.resources.weapons || 0) + zoneLoot.weapons;
        if (zoneLoot.parts) updatedP.resources.parts = (updatedP.resources.parts || 0) + zoneLoot.parts;
        if (zoneLoot.influence) updatedP.resources.influence = (updatedP.resources.influence || 0) + zoneLoot.influence;
        if (zoneLoot.rep) updatedP.resources.rep += zoneLoot.rep;
        if (zoneLoot.wanted) updatedP.wanted = Math.max(0, (updatedP.wanted || 0) + zoneLoot.wanted);
        if (zoneLoot.full_heal) updatedP.hp = updatedP.maxHp;
        if (zoneLoot.all_attr) ['M','I','V','S','B','A'].forEach(a => { updatedP.pool[a] = (updatedP.pool[a] || 0) + 1; });
        if (zoneLoot.peek_news) s = { ...s, meta: { ...s.meta, peekNews: (s.meta.peekNews || 0) + 1 } };
      } else {
        updatedP.hp = Math.max(0, updatedP.hp - (rewards.hp || 0));
        updatedP.wanted = (updatedP.wanted || 0) + (rewards.wanted || 0);
        if (rewards.data) updatedP.resources.data = Math.max(0, (updatedP.resources.data || 0) + rewards.data);
        if (rewards.parts) updatedP.resources.parts = Math.max(0, (updatedP.resources.parts || 0) + rewards.parts);
      }

      // Escape 실패 추가 페널티
      if (!escapeOK && outcome === 'success') {
        updatedP.wanted = (updatedP.wanted || 0) + 1;
      }

      // 맵/주식 업데이트 (성공 시)
      let newMap = s.map;
      let newStocks = s.stocks;
      let destroyedBuilding = null;
      if (outcome === 'success') {
        if (cell.building) destroyedBuilding = cell.building;  // v0.6.3e: 건물 파괴 기록
        newMap = { ...s.map, [pr.coord]: { ...cell, owner: null, fortified: 0, building: null } };
        newStocks = { ...s.stocks, [bloc]: Math.max(1, s.stocks[bloc] - (rewards.stockHit || 0)) };
        // v0.6.3e: 건물 파괴 보너스 — Ghost는 추가 ★+2, ₵+3
        if (destroyedBuilding) {
          updatedP.resources.rep = (updatedP.resources.rep || 0) + 2;
          updatedP.resources.credit = (updatedP.resources.credit || 0) + 3;
        }
      }

      ps[0] = updatedP;
      const newHeat = Math.min(10, Math.max(0, s.heat + (rewards.heat || 0)));
      s = { ...s, players: ps, map: newMap, stocks: newStocks, heat: newHeat };

      // 레이드 카운트 증가 (성공만)
      if (outcome === 'success') {
        s.meta = { ...s.meta, raidsThisGame: { ...s.meta.raidsThisGame, 0: (s.meta.raidsThisGame[0] || 0) + 1 } };
        // v0.9.2: 약속 위반 체크 — Bloc 소유자가 truce 약속한 사이면 P0 ★-2, 피해자 ★+2
        const blocOwnerIdx = state.players.findIndex(pp => pp.specific === bloc && pp.role === 'bloc');
        const activePromises = (s.meta.promises || []).filter(pm => pm.status === 'active' && pm.expiresR >= s.meta.round && pm.type === 'truce' &&
          ((pm.from === 0 && pm.to === blocOwnerIdx) || (pm.from === blocOwnerIdx && pm.to === 0)));
        if (activePromises.length > 0) {
          const ps3 = [...s.players];
          ps3[0] = { ...ps3[0], resources: { ...ps3[0].resources, rep: Math.max(0, (ps3[0].resources.rep || 0) - 2) } };
          if (blocOwnerIdx >= 0) ps3[blocOwnerIdx] = { ...ps3[blocOwnerIdx], resources: { ...ps3[blocOwnerIdx].resources, rep: (ps3[blocOwnerIdx].resources.rep || 0) + 2 } };
          // 약속 status broken 처리
          const newPromises = (s.meta.promises || []).map(pm => activePromises.includes(pm) ? { ...pm, status: 'broken' } : pm);
          s = { ...s, players: ps3, meta: { ...s.meta, promises: newPromises } };
          s = logEntry(s, `⚠ 약속 위반! P0 → P${blocOwnerIdx} truce 무시 raid · P0 ★-2, P${blocOwnerIdx} ★+2`);
        }
        // v0.6.3b: 레이드 성공 시 사용한 스탯에 따라 트랙 +1
        const raidTrackMap = { atk: 'combat', spd: 'transport', hack: 'mfg' };
        const tk = raidTrackMap[rtype.useStat] || 'combat';
        s = raiseTrack(s, 0, tk, 1, '레이드 성공');
        // 잠입형/협상형 보너스: security/party
        if (rtype.useStat === 'inf' || rtype.id === 'infiltrate') s = raiseTrack(s, 0, 'security', 1, '잠입');
        if (rtype.id === 'negotiate') s = raiseTrack(s, 0, 'party', 1, '협상');
        // v0.9.1: 하이라이트 — 첫 raid 성공 / 첫 잠입형 / 첫 건물 파괴 / 첫 NEXUS 점령
        s = recordHighlight(s, 'first_raid_success', 0);
        if (pr.selectedType === 'infiltrate') s = recordHighlight(s, 'first_infiltrate', 0);
        if (destroyedBuilding) s = recordHighlight(s, 'first_building_kill', 0);
        if (s.map[pr.coord]?.zone === 'nex') s = recordHighlight(s, 'first_nexus_claim', 0);
        // v0.6.3d: NPC 블록 레이드 시 시그널 +1 (잠입형은 +2)
        const blocOwner = state.players.findIndex(pp => pp.specific === bloc && pp.role === 'bloc');
        const ownerP = state.players[blocOwner];
        if (ownerP?.isNpc) {
          const sigGain = (rtype.id === 'infiltrate' || rtype.bypass_defense) ? 2 : 1;
          s = revealSignal(s, blocOwner, 0, sigGain);
          // 시그널 LV3 보너스 약탈
          if (s.players[blocOwner].signal?.revealed >= 3) {
            const ps = [...s.players];
            ps[0] = { ...ps[0], resources: { ...ps[0].resources, credit: (ps[0].resources.credit || 0) + 5, data: (ps[0].resources.data || 0) + 2 } };
            s = { ...s, players: ps };
            s = logEntry(s, `🎁 시그널 LV3 보너스 약탈 — ₵+5 📡+2`);
          }
        }
      } else {
        // 실패 시 경호 트랙 +1 (방어 학습)
        s = raiseTrack(s, 0, 'security', 1, '레이드 실패');
      }

      // 결과 상세 로그
      const cbStr = counterBonus > 0 ? ` +상성${counterBonus}` : '';
      const invStr = [
        inv.weapons ? `🔩×${inv.weapons}` : null,
        inv.data ? `📡×${inv.data}` : null,
        inv.poolAttr ? `◈${inv.poolAttr}${poolBonus>1?'(매치+2)':'+1'}` : null,
      ].filter(Boolean).join(' ');
      const defStr = defenseLogs.length > 0 ? ` | 🛡 ${defenseLogs.join(', ')}` : '';
      const rtn = rtype.name;
      s = logEntry(s, `⭐ 당신 ${rtype.icon} ${rtn} 레이드 [${pr.coord} ${pr.zoneNm}] — ${pr.bloc}${defStr}`);
      if (invStr) s = logEntry(s, `  투자: ${invStr}`);
      s = logEntry(s, `  🎲 접근 ${approachRoll}+${approachBonus}=${approachTotal} ${approachOK ? '✓' : '✗(실행-2)'} · 실행 ${execRoll}+${statVal}${cbStr}+${execBonus+poolBonus}=${execTotal} vs ${finalThreshold} ${execOK ? '✓' : '✗'} · 도주 ${escapeRoll}+${me.stats.spd}=${escapeTotal} ${escapeOK ? '✓' : '✗(수배+1)'}`);
      if (outcome === 'success') {
        const lootStr = Object.values(zoneLoot).length > 0 ? ` + ${zoneLoot.label}` : '';
        const buildStr = destroyedBuilding ? ` · 🏚 ${BUILDINGS[destroyedBuilding].name} 파괴 (★+2 ₵+3)` : '';
        s = logEntry(s, `  ✅ 성공 · 렙+${rewards.rep} · ${bloc} 주가-${rewards.stockHit} · 중립화${lootStr}${buildStr}`);
      } else {
        s = logEntry(s, `  ❌ 실패 · HP-${rewards.hp || 0} · 수배+${rewards.wanted || 0}`);
      }

      s.meta = { ...s.meta, pendingRaid: null };
      return s;
    }

    case 'RESOLVE_RAID_YES': {
      // 레거시 호환 — 아직 호출되는 코드 있으면 즉시 새 EXECUTE로 위임
      const pr = state.meta.pendingRaid;
      if (!pr) return state;
      let s = { ...state };
      const raidRoll = d6();
      const me = s.players[0];
      // 상성 보너스: Ghost 클래스가 타겟 Bloc 카운터면 atk +1
      const counterBonus = countersBloc(me.specific, pr.bloc) ? 1 : 0;
      const raidTotal = raidRoll + pr.atk + counterBonus;
      const cell = s.map[pr.coord];
      if (raidTotal >= pr.threshold) {
        const newStocks = { ...s.stocks, [pr.bloc]: Math.max(1, s.stocks[pr.bloc] - 3) };
        const ps = [...s.players];
        ps[0] = {
          ...me,
          resources: { ...me.resources, rep: (me.resources.rep || 0) + 3 },
          wanted: (me.wanted || 0) + 1,
        };
        const newMap = { ...s.map, [pr.coord]: { ...cell, owner: null } };
        s = { ...s, players: ps, stocks: newStocks, map: newMap, heat: Math.min(10, s.heat + 1) };
        s.meta = { ...s.meta, pendingRaid: null, raidsThisGame: { ...s.meta.raidsThisGame, 0: (s.meta.raidsThisGame[0] || 0) + 1 } };
        const cbStr = counterBonus > 0 ? ` +상성${counterBonus}` : '';
        s = logEntry(s, `⭐ 당신 🗡️ 레이드 성공! [${pr.coord} ${pr.zoneNm}] 🎲${raidRoll}+${pr.atk}${cbStr}=${raidTotal} ≥ ${pr.threshold} — ${pr.bloc} 주가-3, 중립화, 렙+3 (누적 ${ps[0].resources.rep})`);
      } else {
        const ps = [...s.players];
        ps[0] = {
          ...me,
          hp: Math.max(0, me.hp - 3),
          wanted: (me.wanted || 0) + 1,
        };
        s = { ...s, players: ps, heat: Math.min(10, s.heat + 1), meta: { ...s.meta, pendingRaid: null } };
        s = logEntry(s, `⭐ 당신 ❌ 레이드 실패 [${pr.coord} ${pr.zoneNm}] 🎲${raidRoll}+${pr.atk}=${raidTotal} < ${pr.threshold} — HP-3, 수배+1`);
      }
      return s;
    }

    case 'RESOLVE_RAID_NO': {
      const pr = state.meta.pendingRaid;
      if (!pr) return state;
      let s = { ...state, meta: { ...state.meta, pendingRaid: null } };
      s = logEntry(s, `⭐ 당신 🕶 레이드 포기 [${pr.coord} ${pr.zoneNm}] — 정찰만 하고 물러남`);
      return s;
    }

    case 'RESOLVE_DUEL_YES': {
      const d = state.meta.pendingGhostDuel;
      if (!d) return state;
      let s = { ...state };
      const atkRoll = d6();
      const defRoll = d6();
      const ps = [...s.players];
      const atkP = ps[d.atkGhostIdx];
      const defP = ps[d.defGhostIdx];
      // 상성 보너스: 공격자 → 방어자 카운터 관계면 atk +2
      const counterBonus = countersGhost(atkP.specific, defP.specific) ? 2 : 0;
      const atkTotal = d.atkStat + atkRoll + counterBonus;
      const defTotal = d.defStat + defRoll;
      if (atkTotal >= defTotal + 2) {
        const loot = Math.min(3, defP.resources.credit || 0);
        ps[d.atkGhostIdx] = { ...atkP, resources: { ...atkP.resources, rep: (atkP.resources.rep || 0) + 2, credit: (atkP.resources.credit || 0) + loot } };
        ps[d.defGhostIdx] = { ...defP, resources: { ...defP.resources, credit: Math.max(0, (defP.resources.credit || 0) - loot) }, hp: Math.max(0, defP.hp - 2) };
        s = { ...s, players: ps, meta: { ...s.meta, pendingGhostDuel: null } };
        const cbStr = counterBonus > 0 ? ` +상성${counterBonus}` : '';
        s = logEntry(s, `⭐ 당신 ⚔️ Ghost 결투 승리! → P${d.defGhostIdx} ${defP.specific} | 🎲${atkRoll}+${d.atkStat}${cbStr}=${atkTotal} vs ${defTotal} | 렙+2, ₵+${loot} 탈취`);
      } else if (defTotal >= atkTotal + 2) {
        ps[d.atkGhostIdx] = { ...atkP, hp: Math.max(0, atkP.hp - 2) };
        s = { ...s, players: ps, meta: { ...s.meta, pendingGhostDuel: null } };
        s = logEntry(s, `⭐ 당신 ⚔️ Ghost 결투 반격당함! P${d.defGhostIdx} ${defP.specific} | 🎲${atkTotal} vs ${defTotal} | HP-2`);
      } else {
        s = { ...s, meta: { ...s.meta, pendingGhostDuel: null } };
        s = logEntry(s, `⭐ 당신 ⚔️ Ghost 결투 무승부 P${d.defGhostIdx} | 🎲${atkTotal} vs ${defTotal}`);
      }
      return s;
    }

    case 'RESOLVE_DUEL_NO': {
      const d = state.meta.pendingGhostDuel;
      if (!d) return state;
      let s = { ...state, meta: { ...state.meta, pendingGhostDuel: null } };
      const defP = s.players[d.defGhostIdx];
      s = logEntry(s, `⭐ 당신 🕶 결투 회피 — P${d.defGhostIdx} ${defP.specific}와 잠시 공존`);
      return s;
    }

    case 'DISMISS_TARGETED':
      return { ...state, meta: { ...state.meta, lastTargetedBy: null } };

    case 'BUY_STOCK': {
      // action.playerIdx, action.bloc, action.qty
      const price = state.stocks[action.bloc];
      if (!price) return state;
      const cost = price * action.qty;
      const ps = [...state.players];
      const p = ps[action.playerIdx];
      if ((p.resources.credit || 0) < cost) return state;
      ps[action.playerIdx] = {
        ...p,
        resources: { ...p.resources, credit: p.resources.credit - cost },
        stocks: { ...p.stocks, [action.bloc]: (p.stocks[action.bloc] || 0) + action.qty },
      };
      // Bloc 본인 매수 유동성 부여: 주가 +1 (매수세)
      const newStocks = { ...state.stocks, [action.bloc]: Math.min(20, price + (action.qty >= 3 ? 1 : 0)) };
      const marker = action.playerIdx === 0 ? '⭐ 당신 ' : '';
      return {
        ...state,
        players: ps,
        stocks: newStocks,
        log: [...state.log, { round: state.meta.round, phase: 1, message: `📈 ${marker}P${action.playerIdx} · ${action.bloc} ${action.qty}주 매수 (₵${cost}) — 주가 ${price}${newStocks[action.bloc] !== price ? `→${newStocks[action.bloc]}` : ''}` }].slice(-150),
      };
    }

    case 'SELL_STOCK': {
      const price = state.stocks[action.bloc];
      if (!price) return state;
      const ps = [...state.players];
      const p = ps[action.playerIdx];
      const have = p.stocks[action.bloc] || 0;
      const qty = Math.min(have, action.qty);
      if (qty === 0) return state;
      const earn = price * qty;
      ps[action.playerIdx] = {
        ...p,
        resources: { ...p.resources, credit: (p.resources.credit || 0) + earn },
        stocks: { ...p.stocks, [action.bloc]: have - qty },
      };
      const newStocks = { ...state.stocks, [action.bloc]: Math.max(1, price - (qty >= 3 ? 1 : 0)) };
      const marker = action.playerIdx === 0 ? '⭐ 당신 ' : '';
      return {
        ...state,
        players: ps,
        stocks: newStocks,
        log: [...state.log, { round: state.meta.round, phase: 1, message: `📉 ${marker}P${action.playerIdx} · ${action.bloc} ${qty}주 매도 (₵+${earn}) — 주가 ${price}${newStocks[action.bloc] !== price ? `→${newStocks[action.bloc]}` : ''}` }].slice(-150),
      };
    }

    case 'SHOP_BUY': {
      // 공용 상점 — 누구나 Phase 1에 구매 가능
      // action.playerIdx, action.item
      const items = {
        medical:   { cost: 5, name: '의료 치료',   apply: p => ({ ...p, hp: p.maxHp }) },
        arms:      { cost: 4, name: '무기상',      apply: p => ({ ...p, resources: { ...p.resources, weapons: (p.resources.weapons||0) + 2 } }) },
        info:      { cost: 3, name: '정보상',      apply: p => ({ ...p, resources: { ...p.resources, data: (p.resources.data||0) + 2, rep: (p.resources.rep||0) + 1 } }) },
        bribe:     { cost: 3, name: '뇌물',        apply: p => ({ ...p, wanted: Math.max(0, (p.wanted||0) - 2) }) },
        bounty:    { cost: 4, name: '현상금 청구', apply: p => ({ ...p, resources: { ...p.resources, rep: (p.resources.rep||0) + 2 } }) },
        recruit:   { cost: 6, name: '용병 영입',   apply: p => ({ ...p, resources: { ...p.resources, weapons: (p.resources.weapons||0) + 3, parts: (p.resources.parts||0) + 1 } }) },
      };
      const it = items[action.item];
      if (!it) return state;
      const p = state.players[action.playerIdx];
      if ((p.resources.credit||0) < it.cost) return state;
      const ps = [...state.players];
      let updated = { ...p, resources: { ...p.resources, credit: p.resources.credit - it.cost } };
      updated = it.apply(updated);
      ps[action.playerIdx] = updated;
      let s = { ...state, players: ps };
      if (action.item === 'bribe') s = { ...s, heat: Math.max(0, s.heat - 1) };
      const marker = action.playerIdx === 0 ? '⭐ 당신 ' : '';
      s = logEntry(s, `🏪 ${marker}P${action.playerIdx} · 상점: ${it.name} (₵-${it.cost})`);
      // v0.6.3b: 상점 구매 → 파티(인맥 거래) 트랙 +1, 무기/용병은 무력으로
      const tk = (action.item === 'arms' || action.item === 'recruit') ? 'combat' : 'party';
      s = raiseTrack(s, action.playerIdx, tk, 1, `상점:${it.name}`);
      return s;
    }

    case 'BOT_SHOP': {
      // 봇 상점 AI — 상황에 맞게 자동 구매
      let s = { ...state };
      const ps = [...state.players];
      state.players.forEach((p, pi) => {
        if (p.kind !== 'bot' || p.defeated) return;
        const credit = p.resources.credit || 0;
        // 우선순위: HP 낮으면 의료 > 수배 높으면 뇌물 > 무기 부족하면 무기상 > 렙 < 10이면 정보상/현상금
        const actions = [];
        if (p.hp < p.maxHp * 0.5 && credit >= 5) actions.push('medical');
        if ((p.wanted||0) >= 3 && credit >= 3) actions.push('bribe');
        if (p.role === 'ghost' && (p.resources.rep||0) < 12 && credit >= 4) actions.push('bounty');
        if ((p.resources.weapons||0) < 2 && credit >= 4) actions.push('arms');
        if (p.role === 'ghost' && (p.resources.data||0) < 2 && credit >= 3) actions.push('info');
        if (actions.length === 0) return;
        const item = actions[0];
        const items = {
          medical: { cost: 5, apply: pp => ({ ...pp, hp: pp.maxHp }) },
          arms:    { cost: 4, apply: pp => ({ ...pp, resources: { ...pp.resources, weapons: (pp.resources.weapons||0) + 2 } }) },
          info:    { cost: 3, apply: pp => ({ ...pp, resources: { ...pp.resources, data: (pp.resources.data||0) + 2, rep: (pp.resources.rep||0) + 1 } }) },
          bribe:   { cost: 3, apply: pp => ({ ...pp, wanted: Math.max(0, (pp.wanted||0) - 2) }) },
          bounty:  { cost: 4, apply: pp => ({ ...pp, resources: { ...pp.resources, rep: (pp.resources.rep||0) + 2 } }) },
        };
        const it = items[item];
        let upd = { ...p, resources: { ...p.resources, credit: p.resources.credit - it.cost } };
        upd = it.apply(upd);
        ps[pi] = upd;
        s = logEntry({ ...s, players: ps }, `🏪 P${pi} [${p.specific}] · 상점 구매 (${item}, ₵-${it.cost})`);
        if (item === 'bribe') s = { ...s, heat: Math.max(0, s.heat - 1) };
        // v0.6.3b: 봇 상점 구매 → 트랙 상승 (party/combat)
        const tk = (item === 'arms' || item === 'recruit') ? 'combat' : 'party';
        s = raiseTrack(s, pi, tk, 1, `상점:${item}`);
      });
      return s;
    }

    // v0.9.2: NEGOTIATE_PHASE — Phase 1.5 협상
    // 자원 거래 / 비공격 약속 / Bloc 동맹 — 봇 AI는 net-value로 자동 수락/거절
    case 'NEGOTIATE_PHASE': {
      let s = { ...state };
      const players = s.players;
      const proposals = [];
      // 각 플레이어가 1개 제안 시도 (수락 가능한 상대 1명 선정)
      for (let from = 0; from < players.length; from++) {
        const fromP = players[from];
        if (fromP.defeated || fromP.isNpc) continue;
        // 후보 상대: 인접하지 않아도 OK, defeated/NPC 제외
        const others = players.map((pp, i) => ({ pp, i })).filter(({ pp, i }) => i !== from && !pp.defeated && !pp.isNpc);
        if (others.length === 0) continue;
        // 거래 시나리오 후보 — 가장 실용적인 1개 선정
        const candidates = [];
        for (const { pp: toP, i: to } of others) {
          // (1) 자원 스왑: from이 부족한 자원 ↔ to가 부족한 자원
          // 단순 룰: from이 credit≥4 + to가 weapons≥2 → credit 4 / weapons 2 거래
          if ((fromP.resources.credit || 0) >= 4 && (toP.resources.weapons || 0) >= 2 && (fromP.resources.weapons || 0) < 2) {
            candidates.push({ from, to, type: 'swap', give: { credit: 4 }, get: { weapons: 2 }, value: 5 });
          }
          if ((fromP.resources.weapons || 0) >= 2 && (toP.resources.credit || 0) >= 4 && (fromP.resources.credit || 0) < 4) {
            candidates.push({ from, to, type: 'swap', give: { weapons: 2 }, get: { credit: 4 }, value: 5 });
          }
          if ((fromP.resources.data || 0) >= 2 && (toP.resources.parts || 0) >= 2 && (fromP.resources.parts || 0) < 2) {
            candidates.push({ from, to, type: 'swap', give: { data: 2 }, get: { parts: 2 }, value: 4 });
          }
          // (2) 비공격 약속: Ghost↔Bloc 또는 Ghost↔Ghost (서로 다음 R 안 친다)
          if (fromP.role !== toP.role) {
            // Ghost가 Bloc에게: "다음 R raid 안 함" 제안 (Bloc은 ★+1로 보상)
            candidates.push({ from, to, type: 'truce', give: {}, get: {}, expiresR: s.meta.round + 1, value: 3 });
          }
          // (3) BROKER 보너스 (v0.9.3) — 협상 시 +1 자원 (너프: rep 2→1, credit 2→1)
          if (fromP.specific === 'BROKER') {
            candidates.push({ from, to, type: 'broker_deal', give: {}, get: { rep: 1, credit: 1 }, value: 3 });
          }
        }
        if (candidates.length === 0) continue;
        // 가장 가치 높은 것 선택
        candidates.sort((a, b) => b.value - a.value);
        proposals.push(candidates[0]);
      }
      // 거래 처리
      for (const prop of proposals) {
        const fromP = s.players[prop.from];
        const toP = s.players[prop.to];
        if (fromP.defeated || toP.defeated) continue;
        // 봇 AI: to 측이 받을 가치 평가 (net positive면 수락)
        let acceptValue = 0;
        for (const [k, v] of Object.entries(prop.give || {})) acceptValue += v;
        for (const [k, v] of Object.entries(prop.get || {})) acceptValue -= v;
        if (prop.type === 'truce') acceptValue += 2;  // 비공격 약속 자체 가치
        if (prop.type === 'broker_deal') acceptValue = 1;  // BROKER 거래는 작은 비용으로 받아줌
        // 비용 충분한지
        let canAfford = true;
        if (prop.type === 'swap') {
          for (const [k, v] of Object.entries(prop.get)) {
            if ((toP.resources[k] || 0) < v) { canAfford = false; break; }
          }
        }
        if (!canAfford || acceptValue < -3) {
          s = logEntry(s, `🤝 협상 거절: P${prop.from} [${fromP.specific}] → P${prop.to} [${toP.specific}] (${prop.type})`);
          continue;
        }
        // 수락 — 자원 교환
        const ps = [...s.players];
        if (prop.type === 'swap') {
          const fr = { ...fromP.resources }, tr = { ...toP.resources };
          for (const [k, v] of Object.entries(prop.give)) { fr[k] = (fr[k] || 0) - v; tr[k] = (tr[k] || 0) + v; }
          for (const [k, v] of Object.entries(prop.get)) { tr[k] = (tr[k] || 0) - v; fr[k] = (fr[k] || 0) + v; }
          ps[prop.from] = { ...fromP, resources: fr };
          ps[prop.to] = { ...toP, resources: tr };
          s = { ...s, players: ps };
          const giveStr = Object.entries(prop.give).map(([k, v]) => `${v}${k.charAt(0).toUpperCase()}`).join(' ');
          const getStr = Object.entries(prop.get).map(([k, v]) => `${v}${k.charAt(0).toUpperCase()}`).join(' ');
          s = logEntry(s, `🤝 거래 성사: P${prop.from} [${fromP.specific}] (${giveStr}) ↔ P${prop.to} [${toP.specific}] (${getStr})`);
          s = raiseTrack(s, prop.from, 'party', 1, '거래');
        } else if (prop.type === 'truce') {
          // 약속 등록
          const newPromises = [...(s.meta.promises || []), { from: prop.from, to: prop.to, type: 'truce', expiresR: prop.expiresR, status: 'active' }];
          s = { ...s, meta: { ...s.meta, promises: newPromises } };
          s = logEntry(s, `🕊 비공격 약속: P${prop.from} ↔ P${prop.to} (R${prop.expiresR}까지)`);
        } else if (prop.type === 'broker_deal') {
          // BROKER가 평판 + 크레딧 받음 (v0.9.3 보너스, 너프됨)
          const fr = { ...fromP.resources, rep: (fromP.resources.rep || 0) + 1, credit: (fromP.resources.credit || 0) + 1 };
          ps[prop.from] = { ...fromP, resources: fr };
          s = { ...s, players: ps };
          s = logEntry(s, `🎙 BROKER 협상: P${prop.from} ★+1 ₵+1 (P${prop.to}와 중개 성사)`);
          s = raiseTrack(s, prop.from, 'party', 1, 'BROKER 협상');
        }
      }
      return s;
    }

    case 'BOT_MARKET': {
      // 봇들 자동 거래 (간단 AI)
      let s = { ...state };
      const ps = [...state.players];
      state.players.forEach((p, pi) => {
        if (p.kind !== 'bot' || p.defeated) return;
        const credit = p.resources.credit || 0;
        const blocs = Object.keys(s.stocks);
        // 주가 낮고 본인 자산에 들어갈 주식 매수 (Bloc은 자사 제외)
        blocs.forEach(bl => {
          if (p.role === 'bloc' && p.specific === bl) return;  // 자사 매수 X
          const price = s.stocks[bl];
          if (price <= 7 && credit >= price * 2 && Math.random() < 0.5) {
            const qty = 2;
            const cost = price * qty;
            ps[pi] = {
              ...ps[pi],
              resources: { ...ps[pi].resources, credit: ps[pi].resources.credit - cost },
              stocks: { ...ps[pi].stocks, [bl]: (ps[pi].stocks[bl] || 0) + qty },
            };
            s = { ...s, stocks: { ...s.stocks, [bl]: Math.min(20, s.stocks[bl] + 1) } };
            s = logEntry(s, `📈 P${pi} [${p.specific}] · ${bl} ${qty}주 매수 (₵${cost}) — 주가 ${price}→${s.stocks[bl]}`);
          }
        });
        // 주가 높은 보유 종목은 매도
        Object.entries(p.stocks).forEach(([bl, qty]) => {
          if (p.role === 'bloc' && p.specific === bl) return;
          const price = s.stocks[bl];
          if (price >= 15 && qty >= 2 && Math.random() < 0.6) {
            const sellQty = Math.min(qty, 2);
            const earn = price * sellQty;
            ps[pi] = {
              ...ps[pi],
              resources: { ...ps[pi].resources, credit: (ps[pi].resources.credit || 0) + earn },
              stocks: { ...ps[pi].stocks, [bl]: qty - sellQty },
            };
            s = { ...s, stocks: { ...s.stocks, [bl]: Math.max(1, s.stocks[bl] - 1) } };
            s = logEntry(s, `📉 P${pi} [${p.specific}] · ${bl} ${sellQty}주 매도 (₵+${earn}) — 주가 ${price}→${s.stocks[bl]}`);
          }
        });
      });
      s = { ...s, players: ps };
      return s;
    }

    case 'SNAPSHOT_TURN': {
      const snap = state.players.map(p => ({
        hp: p.hp,
        rep: p.resources.rep,
        credit: p.resources.credit,
        asset: assetValue(p, state.stocks, state),
        pool: { ...(p.pool || {}) },
        position: p.position,
        zones: Object.values(state.map).filter(c => c.owner === p.id).length,
        wanted: p.wanted || 0,
      }));
      return { ...state, meta: { ...state.meta, turnSnapshot: snap, turnDiff: null } };
    }

    case 'COMPUTE_TURN_DIFF': {
      const prev = state.meta.turnSnapshot;
      if (!prev) return state;
      const diff = state.players.map((p, i) => {
        const o = prev[i] || {};
        return {
          specific: p.specific,
          hp: p.hp - (o.hp ?? p.hp),
          rep: p.resources.rep - (o.rep ?? 0),
          credit: p.resources.credit - (o.credit ?? 0),
          asset: assetValue(p, state.stocks, state) - (o.asset ?? 0),
          zones: Object.values(state.map).filter(c => c.owner === i).length - (o.zones ?? 0),
          wanted: (p.wanted||0) - (o.wanted ?? 0),
          moved: p.position !== o.position ? `${o.position}→${p.position}` : null,
          poolDelta: ['M','I','V','S','B','A','GRID'].map(k => {
            const d = (p.pool?.[k] || 0) - (o.pool?.[k] || 0);
            return d !== 0 ? `${k}${d>0?'+':''}${d}` : null;
          }).filter(Boolean).join(' '),
        };
      });
      return { ...state, meta: { ...state.meta, turnDiff: diff } };
    }

    case 'NEXT_PHASE': {
      const cur = state.meta.phase;
      if (cur < 6) return { ...state, meta: { ...state.meta, phase: cur + 1 } };
      // End of round
      return state;  // handled elsewhere
    }

    case 'NEXT_ROUND': {
      const newRound = state.meta.round + 1;
      // v0.8.3: 맵별 maxRounds — 5×5: 8, 11×11: 12
      const maxR = state.meta.mapSize === '11x11' ? 12 : 8;
      if (newRound > maxR) {
        return checkVictoryByPoints(state);
      }
      // v0.9.3: NEXUS 글로벌 룰 적용 (라운드 시작 시)
      const nexRule = getActiveNexusRule(state);
      if (nexRule) {
        const ps0 = [...state.players];
        const ctrlIdx = state.players.indexOf(getNexusController(state));
        if (nexRule.id === 'info_open') {
          // 모든 NPC 시그널 +1
          for (let i = 0; i < ps0.length; i++) {
            if (ps0[i].isNpc && ps0[i].signal && ps0[i].signal.revealed < ps0[i].signal.max) {
              ps0[i] = { ...ps0[i], signal: { ...ps0[i].signal, revealed: ps0[i].signal.revealed + 1 } };
            }
          }
        } else if (nexRule.id === 'martial') {
          // Ghost 전원 수배 +1
          for (let i = 0; i < ps0.length; i++) if (ps0[i].role === 'ghost' && !ps0[i].defeated) ps0[i] = { ...ps0[i], wanted: (ps0[i].wanted || 0) + 1 };
        } else if (nexRule.id === 'biocode') {
          // 모든 플레이어 HP+1
          for (let i = 0; i < ps0.length; i++) if (!ps0[i].defeated) ps0[i] = { ...ps0[i], hp: Math.min(ps0[i].maxHp, ps0[i].hp + 1) };
        } else if (nexRule.id === 'algo_market') {
          // 모든 플레이어 데이터+1
          for (let i = 0; i < ps0.length; i++) if (!ps0[i].defeated) ps0[i] = { ...ps0[i], resources: { ...ps0[i].resources, data: (ps0[i].resources.data || 0) + 1 } };
        }
        // CARBON energy_grid는 COLLECT_INCOME에서 처리
        state = { ...state, players: ps0,
          log: [...state.log, { round: newRound, phase: 0, message: `🌐 NEXUS 룰 [${nexRule.label}] 활성 (P${ctrlIdx} ${getNexusController(state).specific} 점유)` }].slice(-150)
        };
      }

      // v0.9.2: 만료된 truce 약속 — 지킴(active)이면 양측 ★+1
      const promisesNow = state.meta.promises || [];
      const expired = promisesNow.filter(pm => pm.expiresR < newRound);
      if (expired.length > 0) {
        const ps0 = [...state.players];
        for (const pm of expired) {
          if (pm.status === 'active') {
            const a = ps0[pm.from], b = ps0[pm.to];
            if (a && !a.defeated) ps0[pm.from] = { ...a, resources: { ...a.resources, rep: (a.resources.rep || 0) + 1 } };
            if (b && !b.defeated) ps0[pm.to] = { ...b, resources: { ...b.resources, rep: (b.resources.rep || 0) + 1 } };
          }
        }
        state = { ...state, players: ps0, log: [...state.log,
          ...expired.filter(pm => pm.status === 'active').map(pm => ({ round: state.meta.round, phase: state.meta.phase, message: `🤝 약속 지킴: P${pm.from} ↔ P${pm.to} 양측 ★+1` }))
        ].slice(-150) };
      }
      const nd = rollSignalDie();
      // v0.8.5: extraDrawNext (stat_boost / temp_tl 효과) 적용 후 리셋
      const extraDraw = state.meta.extraDrawNext || 0;
      // === 손패 리필 + 개인 풀 감쇠 ===
      const refilledPlayers = state.players.map(p => {
        if (p.defeated) return p;
        const handMax = 6 + (p.id === 0 ? extraDraw : 0);  // P0만 보너스 적용
        const needed = Math.max(0, handMax - p.hand.length);
        let newDeck = [...p.deck];
        let newDiscard = [...p.discard];
        let newHand = [...p.hand];
        for (let i = 0; i < needed; i++) {
          if (newDeck.length === 0) {
            if (newDiscard.length === 0) break;
            newDeck = shuffle(newDiscard);
            newDiscard = [];
          }
          newHand.push(newDeck.shift());
        }
        // 개인 풀 감쇠 (ceil로 시드 보존)
        const decayedPool = {};
        for (const [k, v] of Object.entries(p.pool || {})) decayedPool[k] = Math.ceil(v / 2);
        return { ...p, hand: newHand, deck: newDeck, discard: newDiscard, pool: decayedPool };
      });
      // === 이전 라운드 요약 ===
      const summaryLines = [];
      summaryLines.push({ round: state.meta.round, phase: 6, message: `━━━━━━━━━━━ R${state.meta.round} 요약 ━━━━━━━━━━━` });
      state.players.forEach((p, i) => {
        if (p.defeated) { summaryLines.push({ round: state.meta.round, phase: 6, message: `  P${i} [${p.specific}] · 💀 쓰러짐` }); return; }
        const marker = i === 0 ? '⭐ 당신 ' : '   ';
        if (p.role === 'ghost') {
          const raidsTotal = state.meta.raidsThisGame[i] || 0;
          summaryLines.push({ round: state.meta.round, phase: 6, message: `  ${marker}P${i} [${p.specific}] 👻 · HP ${p.hp}/${p.maxHp} · 렙 ${p.resources.rep} · 누적 레이드 ${raidsTotal}회 · ${p.position || '?'} 위치` });
        } else {
          const av = assetValue(p, state.stocks, state);
          const ownZones = Object.values(state.map).filter(c => c.owner === i).length;
          summaryLines.push({ round: state.meta.round, phase: 6, message: `  ${marker}P${i} [${p.specific}] 🏢 · 자산 ${av}/55 · 구역 ${ownZones}곳 · ₵${p.resources.credit}` });
        }
      });
      // 개인 풀 요약
      state.players.forEach((p, i) => {
        if (p.defeated) return;
        const poolStr = Object.entries(p.pool || {}).filter(([,v]) => v>0).map(([k,v])=>`${k}${v}`).join(' ') || '(비어있음)';
        const marker = i === 0 ? '⭐ ' : '   ';
        summaryLines.push({ round: state.meta.round, phase: 6, message: `  ${marker}P${i} 풀: ${poolStr}` });
      });
      summaryLines.push({ round: state.meta.round, phase: 6, message: `  공권력 ${state.heat}/10` });

      const finalLog = [
        ...state.log,
        ...summaryLines,
        { round: newRound, phase: 0, message: `🔄 R${newRound} 시작 · 시그널 ${nd} · 손패 리필 · 개인 풀 절반 감쇠` }
      ].slice(-150);

      return {
        ...state,
        meta: { ...state.meta, round: newRound, phase: 0, extraDrawNext: 0,
          // v0.9.2: 만료된 truce 약속 정리 (지킴 → 양측 ★+1, broken은 그대로 두고 만료)
          promises: (state.meta.promises || []).filter(pm => pm.expiresR >= newRound),
        },
        signalDie: nd,
        currentNews: null,
        players: refilledPlayers,
        log: finalLog,
      };
    }

    case 'DRAW_NEWS': {
      const news = rand(NEWS);
      const eff = news.effect;
      let newStocks = { ...state.stocks };
      let newHeat = state.heat;
      let newSignal = state.signalDie;
      let ps = [...state.players];
      const logMsgs = [];

      // Heat
      if (eff.heat) { newHeat += eff.heat; logMsgs.push(`🔥공권력${eff.heat > 0 ? '+' : ''}${eff.heat}`); }
      // Stock: all
      if (eff.all_stock) {
        Object.keys(newStocks).forEach(k => newStocks[k] = Math.max(1, Math.min(20, newStocks[k] + eff.all_stock)));
        logMsgs.push(`📊전체주가${eff.all_stock > 0 ? '+' : ''}${eff.all_stock}`);
      }
      // Stock: target
      if (eff.target_stock) {
        const { bloc, delta } = eff.target_stock;
        if (newStocks[bloc] != null) {
          newStocks[bloc] = Math.max(1, Math.min(20, newStocks[bloc] + delta));
          logMsgs.push(`📊${bloc}${delta > 0 ? '+' : ''}${delta}`);
        }
      }
      if (eff.target_stock2) {
        const { bloc, delta } = eff.target_stock2;
        if (newStocks[bloc] != null) {
          newStocks[bloc] = Math.max(1, Math.min(20, newStocks[bloc] + delta));
          logMsgs.push(`📊${bloc}${delta > 0 ? '+' : ''}${delta}`);
        }
      }
      // Random crash
      if (eff.random_crash) {
        const blocs = Object.keys(newStocks);
        const pick = blocs[Math.floor(Math.random() * blocs.length)];
        newStocks[pick] = Math.max(1, newStocks[pick] - eff.random_crash);
        logMsgs.push(`📉${pick}-${eff.random_crash}`);
      }
      // Signal lock
      if (eff.signal_lock) { newSignal = eff.signal_lock; logMsgs.push(`📡고정${eff.signal_lock}`); }
      // Credit: all
      if (eff.all_credit) {
        ps = ps.map(p => ({ ...p, resources: { ...p.resources, credit: Math.max(0, (p.resources.credit || 0) + eff.all_credit) } }));
        logMsgs.push(`₵전체${eff.all_credit > 0 ? '+' : ''}${eff.all_credit}`);
      }
      // Credit: targeted by role
      if (eff.target_credit) {
        const { role, delta } = eff.target_credit;
        ps = ps.map(p => p.role === role ? { ...p, resources: { ...p.resources, credit: Math.max(0, (p.resources.credit || 0) + delta) } } : p);
        logMsgs.push(`₵${role}${delta > 0 ? '+' : ''}${delta}`);
      }
      // All rep (Ghost only)
      if (eff.all_rep) {
        ps = ps.map(p => p.role === 'ghost' ? { ...p, resources: { ...p.resources, rep: Math.max(0, (p.resources.rep || 0) + eff.all_rep) } } : p);
        logMsgs.push(`★Ghost렙${eff.all_rep > 0 ? '+' : ''}${eff.all_rep}`);
      }
      // All weapons/parts/data
      if (eff.all_weapons) { ps = ps.map(p => ({ ...p, resources: { ...p.resources, weapons: Math.max(0, (p.resources.weapons || 0) + eff.all_weapons) } })); logMsgs.push(`🔩전체${eff.all_weapons > 0 ? '+' : ''}${eff.all_weapons}`); }
      if (eff.all_parts)   { ps = ps.map(p => ({ ...p, resources: { ...p.resources, parts:   Math.max(0, (p.resources.parts   || 0) + eff.all_parts)   } })); logMsgs.push(`⚙️전체${eff.all_parts > 0 ? '+' : ''}${eff.all_parts}`); }
      if (eff.all_data)    { ps = ps.map(p => ({ ...p, resources: { ...p.resources, data:    Math.max(0, (p.resources.data    || 0) + eff.all_data)    } })); logMsgs.push(`📡전체${eff.all_data > 0 ? '+' : ''}${eff.all_data}`); }
      // Wanted all (ghost)
      if (eff.wanted_all) {
        ps = ps.map(p => p.role === 'ghost' ? { ...p, wanted: Math.max(0, (p.wanted || 0) + eff.wanted_all) } : p);
        logMsgs.push(`🚨Ghost수배${eff.wanted_all > 0 ? '+' : ''}${eff.wanted_all}`);
      }
      // HP all ghost
      if (eff.hp_all) {
        ps = ps.map(p => p.role === 'ghost' ? { ...p, hp: Math.max(0, Math.min(p.maxHp, p.hp + eff.hp_all)) } : p);
        logMsgs.push(`❤️Ghost HP${eff.hp_all > 0 ? '+' : ''}${eff.hp_all}`);
      }
      // Random zone flip
      if (eff.random_zone_flip) {
        const newMap = { ...state.map };
        const owned = Object.entries(newMap).filter(([c, cell]) => cell.owner !== null && cell.owner !== undefined);
        for (let i = 0; i < eff.random_zone_flip && owned.length > 0; i++) {
          const idx = Math.floor(Math.random() * owned.length);
          const [coord] = owned.splice(idx, 1)[0];
          newMap[coord] = { ...newMap[coord], owner: null };
          logMsgs.push(`🗺️${coord}중립화`);
        }
        return {
          ...state, players: ps, stocks: newStocks, map: newMap, signalDie: newSignal,
          heat: Math.max(0, Math.min(10, newHeat)),
          currentNews: news,
          log: [...state.log, { round: state.meta.round, phase: 1, message: `📰 ${news.title} — ${logMsgs.join(' · ')}` }].slice(-150),
        };
      }
      // Map reveal
      let mapReveal = state.meta.mapReveal || 0;
      if (eff.map_reveal) { mapReveal += eff.map_reveal; logMsgs.push(`👁지도${eff.map_reveal}R노출`); }
      // Ghost move boost
      let moveBonusNext = state.meta.moveBonusNext || 0;
      if (eff.ghost_move) { moveBonusNext += eff.ghost_move; logMsgs.push(`🚶이동${eff.ghost_move > 0 ? '+' : ''}${eff.ghost_move}`); }

      return {
        ...state,
        currentNews: news,
        stocks: newStocks,
        signalDie: newSignal,
        heat: Math.max(0, Math.min(10, newHeat)),
        players: ps,
        meta: { ...state.meta, mapReveal, moveBonusNext },
        log: [...state.log, { round: state.meta.round, phase: 1, message: `📰 ${news.title} — ${logMsgs.join(' · ') || '효과 없음'}` }].slice(-150),
      };
    }

    // v1.0.2: 핫시트 다음 인간으로 차례 전환
    case 'NEXT_HUMAN': {
      const humansIdx = state.players.map((p, i) => p.kind === 'human' && !p.defeated ? i : -1).filter(x => x >= 0);
      const cur = state.meta.activePlayer ?? 0;
      const curPos = humansIdx.indexOf(cur);
      const nextIdx = humansIdx[(curPos + 1) % humansIdx.length];
      // 마지막 인간 차례 끝 → activePlayer를 0으로 리셋, plan 끝
      const allDone = state.players.filter(p => p.kind === 'human' && !p.defeated).every(p => p.plannedCards && p.plannedCards.length > 0);
      if (allDone || curPos === humansIdx.length - 1) {
        return { ...state, meta: { ...state.meta, activePlayer: 0 } };
      }
      return { ...state, meta: { ...state.meta, activePlayer: nextIdx },
        log: [...state.log, { round: state.meta.round, phase: state.meta.phase, message: `🔄 차례 전환 → P${nextIdx} ${state.players[nextIdx].specific}` }].slice(-150) };
    }

    case 'PLAN_CARDS': {
      // action.playerIdx, action.cards, action.halves (optional)
      const ps = state.players.map((p, i) => {
        if (i === action.playerIdx) {
          return { ...p, plannedCards: action.cards, plannedHalves: action.halves || [] };
        }
        return p;
      });
      return { ...state, players: ps };
    }

    case 'EXECUTE_TURN': {
      // Order players by initiative
      const pOrder = state.players
        .map((p, i) => ({ p, i, init: getInitiative(p) }))
        .filter(x => !x.p.defeated && x.p.plannedCards.length > 0)
        .sort((a, b) => a.init - b.init);

      let s = state;
      for (const { p, i } of pOrder) {
        s = executeCards(s, i);
      }
      // Clear planned
      s.players = s.players.map(p => ({ ...p, plannedCards: [] }));
      return s;
    }

    case 'COLLECT_INCOME': {
      let s = { ...state };
      const newLog = [...s.log];

      const newPlayers = state.players.map((p, pi) => {
        if (p.defeated) return p;
        const res = { ...p.resources };
        const pool = { ...(p.pool || { M:0,I:0,V:0,S:0,B:0,A:0,GRID:0 }) };
        const ownedCoords = Object.entries(state.map).filter(([c, cell]) => cell.owner === pi).map(([c]) => c);

        ownedCoords.forEach(c => {
          const cell = state.map[c];
          const z = ZONE_TYPES[cell.zone];
          if (!z) return;
          for (const [k, v] of Object.entries(z.income)) {
            if (k === 'all_attr') {
              ['M','I','V','S','B','A'].forEach(a => { pool[a] = (pool[a] || 0) + v; });
            } else if (k === 'random_attr') {
              const rnd = rand(['M','I','V','S','B','A']);
              pool[rnd] = (pool[rnd] || 0) + v;
            } else if (k === 'operative') {
              res.credit = (res.credit || 0) + v;
            } else {
              res[k] = (res[k] || 0) + v;
            }
          }
          // 구역 생산 속성 — 개인 풀에 적립
          if (z.attr && z.attr !== 'all' && z.attr !== null) {
            pool[z.attr] = (pool[z.attr] || 0) + 1;
          }
        });

        for (const [bl, qty] of Object.entries(p.stocks)) {
          if (qty >= 2) {
            const divPerShare = state.stocks[bl] >= 15 ? 1 : 0.5;
            const div = Math.floor(qty * divPerShare);
            if (div > 0) res.credit = (res.credit || 0) + div;
          }
        }

        // v0.6.3c: 트랙 패시브 수익 보너스 (party LV2+ → 크레딧 / mfg LV2+ → 부품)
        const incBonus = trackIncomeBonus(p);
        if (incBonus.credit > 0) res.credit = (res.credit || 0) + incBonus.credit;
        if (incBonus.parts > 0) res.parts = (res.parts || 0) + incBonus.parts;
        // v0.9.3: NEXUS CARBON energy_grid — 모든 자사 구역 수입 +1 크레딧
        const nexRule3 = getActiveNexusRule(state);
        if (nexRule3?.id === 'energy_grid') {
          res.credit = (res.credit || 0) + ownedCoords.length;
        }

        // v0.6.3e: 건물 라운드 수익
        ownedCoords.forEach(c => {
          const cell = state.map[c];
          if (!cell.building) return;
          const b = cell.building;
          if (b === 'factory') res.parts = (res.parts || 0) + 2;
          else if (b === 'hq') res.influence = (res.influence || 0) + 1;
          else if (b === 'trading') res.credit = (res.credit || 0) + 2;  // 거래소 라운드 +2
        });

        if (ownedCoords.length > 0 || incBonus.credit > 0 || incBonus.parts > 0) {
          const incBonusStr = (incBonus.credit > 0 || incBonus.parts > 0) ? ` (트랙: ${incBonus.credit ? '₵+' + incBonus.credit : ''}${incBonus.credit && incBonus.parts ? ' ' : ''}${incBonus.parts ? '⚙+' + incBonus.parts : ''})` : '';
          const summary = `💰 P${pi} [${p.specific}] · ${ownedCoords.length}구역 수입 ₵+${res.credit - (p.resources.credit || 0)}${incBonusStr}`;
          newLog.push({ round: s.meta.round, phase: s.meta.phase, message: summary });
        }

        return { ...p, resources: res, pool };
      });

      s = { ...s, players: newPlayers, log: newLog.slice(-150) };

      // v0.6.3b: 큰 수입 라운드 → 트랙 상승 (구역 ≥3 → 파티 +1, 구역 ≥5 → 제조 +1 추가)
      for (let pi = 0; pi < s.players.length; pi++) {
        const p = s.players[pi];
        if (p.defeated) continue;
        const ownedCnt = Object.values(s.map).filter(c => c.owner === pi).length;
        if (ownedCnt >= 3) s = raiseTrack(s, pi, 'party', 1, '대규모 수입');
        if (ownedCnt >= 5) s = raiseTrack(s, pi, 'mfg', 1, '산업 가동');
      }

      // v0.6.3e: Bloc 봇 자동 건설 (자사 구역 중 건물 없는 곳에 가능한 건물 1개)
      for (let pi = 0; pi < s.players.length; pi++) {
        const p = s.players[pi];
        if (p.role !== 'bloc' || p.defeated || p.isNpc || pi === 0) continue;
        const emptyCoord = Object.entries(s.map).find(([c, cell]) => cell.owner === pi && !cell.building);
        if (!emptyCoord) continue;
        // 우선순위: tl 가능 + 자원 충분한 것 중 가장 비싼 것
        const buildOrder = ['hq', 'media', 'trading', 'factory', 'security'];
        for (const k of buildOrder) {
          const check = canBuildBuilding(s, pi, k, emptyCoord[0]);
          if (check.ok) {
            s = reducer(s, { type: 'BUILD_BUILDING', playerIdx: pi, key: k, coord: emptyCoord[0] });
            break;
          }
        }
      }

      // === v0.7.4: Bloc 방어 비용 (Speakeasy식, 완화 버전) ===
      // 4구역까지 무료, 5구역째부터 추가 1구역당 무기 OR 크레딧 1 소모
      // 부족 시 가장 약한 구역(요새화 0, 건물 없음, HQ 외) 잃음
      for (let pi = 0; pi < s.players.length; pi++) {
        const p = s.players[pi];
        if (p.role !== 'bloc' || p.defeated || p.isNpc) continue;
        const ownedCoords = Object.entries(s.map).filter(([c, cell]) => cell.owner === pi).map(([c]) => c);
        if (ownedCoords.length <= 4) continue;  // 4구역 이하는 무료
        const cost = ownedCoords.length - 4;
        const haveW = p.resources.weapons || 0;
        const haveC = p.resources.credit || 0;
        // 무기 우선, 부족 시 크레딧으로 (1 무기 = 1 크레딧)
        const have = haveW + haveC;
        const ps2 = [...s.players];
        if (have >= cost) {
          // 무기 우선 차감, 모자라면 크레딧
          let payW = Math.min(haveW, cost);
          let payC = cost - payW;
          ps2[pi] = { ...p, resources: { ...p.resources, weapons: haveW - payW, credit: haveC - payC } };
          s = { ...s, players: ps2 };
          s = logEntry(s, `🔩 P${pi} [${p.specific}] · 방어비용 (${ownedCoords.length}구역) -${payW}🔩${payC > 0 ? ` -${payC}₵` : ''}`);
        } else {
          // 부족 → 다 쓰고 (cost - have) 만큼 약한 구역 손실
          const deficit = cost - have;
          ps2[pi] = { ...p, resources: { ...p.resources, weapons: 0, credit: 0 } };
          // 약한 구역 정렬: 요새화 0, 건물 없음, support 아닌 것 우선
          const setup = (s.meta.mapSize === '11x11' ? BLOC_SETUP_11x11 : BLOC_SETUP)[p.specific] || {};
          const hqCoord = setup.hq;
          const sortedByWeak = ownedCoords
            .filter(c => c !== hqCoord)  // HQ는 잃지 않음
            .sort((a, b) => {
              const ca = s.map[a], cb = s.map[b];
              const aScore = (ca.fortified || 0) * 10 + (ca.building ? 5 : 0);
              const bScore = (cb.fortified || 0) * 10 + (cb.building ? 5 : 0);
              return aScore - bScore;
            });
          const newMap = { ...s.map };
          let lost = 0;
          for (const coord of sortedByWeak) {
            if (lost >= deficit) break;
            newMap[coord] = { ...newMap[coord], owner: null, fortified: 0, building: null };
            lost++;
          }
          s = { ...s, players: ps2, map: newMap };
          s = logEntry(s, `⚠ P${pi} [${p.specific}] · 자원 부족 (${have}/${cost}) → ${lost}구역 손실 (방어 실패)`);
        }
      }

      // === Bloc 패시브 확장 ===
      // v0.8.4: 11×11 50% 확률. v1.0.1: 난이도 보정 — easy 50% / normal 75% / hard 100%
      const expandedMap = { ...s.map };
      const expandLog = [];
      const isLargeMap = s.meta.mapSize === '11x11';
      const expandRate = (() => {
        if (s.meta.difficulty === 'easy') return 0.5;
        if (s.meta.difficulty === 'hard') return 1.0;
        return isLargeMap ? 0.75 : 1.0;  // normal 기본
      })();
      for (let pi = 0; pi < s.players.length; pi++) {
        const p = s.players[pi];
        if (p.role !== 'bloc' || p.defeated || p.isNpc) continue;
        if (Math.random() > expandRate) continue;  // v1.0.1: 난이도 기반 확률
        const myZones = Object.entries(expandedMap).filter(([c, cell]) => cell.owner === pi).map(([c]) => c);
        const candidates = new Set();
        myZones.forEach(c => {
          coordsAdj(c).forEach(adj => {
            const cell = expandedMap[adj];
            if (cell && cell.owner === null && ZONE_TYPES[cell.zone]?.buildable) candidates.add(adj);
          });
        });
        if (candidates.size > 0) {
          const picks = [...candidates];
          const target = picks[Math.floor(Math.random() * picks.length)];
          expandedMap[target] = { ...expandedMap[target], owner: pi };
          const zName = ZONE_TYPES[expandedMap[target].zone]?.name || target;
          expandLog.push({ round: s.meta.round, phase: s.meta.phase, message: `📈 P${pi} [${p.specific}] 영향권 확장 → ${target} (${zName}) · 자산 +5` });
        }
      }
      if (expandLog.length > 0) {
        s = { ...s, map: expandedMap, log: [...s.log, ...expandLog].slice(-150) };
      }
      return s;
    }

    case 'RESEARCH_PHASE': {
      // R&D: 각 플레이어가 tlProgress 축적 + 승급 판정
      // Bloc 공식: 구역수 + ⌊풀/2⌋  (구역 확장으로 자연 축적)
      // Ghost 공식: ⌊렙/3⌋ + 레이드×2 + ⌊풀/2⌋  (렙·레이드로 축적 — Bloc 대비 비대칭)
      let s = { ...state };
      const newLog = [...s.log];
      const newPlayers = state.players.map((p, pi) => {
        if (p.defeated) return p;
        const poolSum = ['M','I','V','S','B','A'].reduce((a,k) => a + (p.pool?.[k] || 0), 0);
        const poolHalf = Math.floor(poolSum / 2);
        const raids = state.meta.raidsThisGame?.[pi] || 0;
        const ownCount = Object.values(state.map).filter(c => c.owner === pi).length;
        let gain = 0;
        let breakdown = '';
        // v0.5.21: 5pt 균일 비용에 맞춰 공식 축소 (속도 조정)
        if (p.role === 'ghost') {
          const repPart = Math.floor((p.resources.rep || 0) / 5);  // ⅓ → ⅕
          const raidPart = raids;                                  // ×2 → ×1
          const poolPart = Math.floor(poolSum / 3);                // ½ → ⅓
          gain = repPart + raidPart + poolPart;
          breakdown = `렙⅕${repPart} +레이드${raidPart} +풀⅓${poolPart}`;
        } else {
          const zonePart = Math.floor(ownCount / 2);               // 구역 → ½
          const poolPart = Math.floor(poolSum / 3);                // ½ → ⅓
          gain = zonePart + poolPart;
          breakdown = `구역½${zonePart} +풀⅓${poolPart}`;
        }
        let tl = p.tl || 1;
        let tlProgress = (p.tlProgress || 0) + gain;
        const events = [];
        while (tl < 5 && tlProgress >= tlCostFor(tl)) {
          tlProgress -= tlCostFor(tl);
          tl += 1;
          events.push(tl);
        }
        if (gain > 0 || events.length > 0) {
          const marker = pi === 0 ? '⭐ 당신 ' : '';
          const upMsg = events.length > 0 ? ` · ⚡TL UP → TL ${tl}` : '';
          newLog.push({ round: s.meta.round, phase: 5, message: `🧪 ${marker}P${pi} [${p.specific}] R&D +${gain}pt (${breakdown}) → ${tlProgress}/${tlCostFor(tl)}${upMsg}` });
        }
        return { ...p, tl, tlProgress };
      });
      s = { ...s, players: newPlayers, log: newLog.slice(-150) };

      // v0.6.3b: R&D 페이즈 — 봇은 자동으로 트랙 1개 무료 레벨업 (가장 약한 지표 또는 클래스 시그니처)
      // P0는 모달로 따로 받음 (PROMPT_TRACK_INVEST 액션이 트리거)
      for (let pi = 0; pi < s.players.length; pi++) {
        const p = s.players[pi];
        if (p.defeated || pi === 0) continue;
        // v0.6.5b: 봇 트랙 선택 — 5트랙 모두 포함, 클래스 시그니처 우선
        const prefByClass = {
          BLADE:    ['combat', 'security', 'transport', 'mfg', 'party'],
          CIPHER:   ['mfg', 'security', 'party', 'transport', 'combat'],
          RIGGER:   ['mfg', 'combat', 'transport', 'security', 'party'],
          BROKER:   ['party', 'security', 'transport', 'mfg', 'combat'],
          DRIFTER:  ['transport', 'combat', 'mfg', 'security', 'party'],
          MOLE:     ['security', 'party', 'transport', 'mfg', 'combat'],
          VANTA:    ['party', 'security', 'mfg', 'combat', 'transport'],
          IRONWALL: ['combat', 'security', 'mfg', 'party', 'transport'],
          HELIX:    ['mfg', 'party', 'security', 'combat', 'transport'],
          AXIOM:    ['mfg', 'security', 'combat', 'party', 'transport'],
          CARBON:   ['mfg', 'transport', 'party', 'security', 'combat'],
        };
        const pref = prefByClass[p.specific] || TRACK_KEYS;
        // 매 라운드 한 트랙씩 회전: round % length 만큼 시작점 이동
        const rotated = pref.slice(s.meta.round % pref.length).concat(pref.slice(0, s.meta.round % pref.length));
        for (const k of rotated) {
          if ((p.tracks?.[k] || 0) < TRACK_MAX) {
            const r = levelUpTrack(s, pi, k, { free: true });
            if (r.ok) { s = r.state; break; }
          }
        }
      }
      // P0가 살아있고 미착수면 모달 — 모달은 GameApp 측에서 phase 5 진입 시 별도 트리거
      if (!s.players[0].defeated) {
        s = { ...s, meta: { ...s.meta, pendingTrackInvest: true } };
      }
      return s;
    }

    case 'TRACK_INVEST': {
      // action.playerIdx, action.key, action.free (boolean — R&D 무료 레벨업)
      const r = levelUpTrack(state, action.playerIdx, action.key, { free: !!action.free });
      if (!r.ok) {
        return { ...state, log: [...state.log, { round: state.meta.round, phase: state.meta.phase, message: `❌ P${action.playerIdx} 트랙 투자 실패 — ${r.reason}` }].slice(-150) };
      }
      let s2 = r.state;
      if (action.free && action.playerIdx === 0) {
        s2 = { ...s2, meta: { ...s2.meta, pendingTrackInvest: false } };
      }
      return s2;
    }

    case 'SKIP_TRACK_INVEST': {
      return { ...state, meta: { ...state.meta, pendingTrackInvest: false } };
    }

    case 'BUILD_BUILDING': {
      // v0.6.3e: action.playerIdx, action.key, action.coord
      const check = canBuildBuilding(state, action.playerIdx, action.key, action.coord);
      if (!check.ok) {
        return { ...state, log: [...state.log, { round: state.meta.round, phase: state.meta.phase, message: `❌ P${action.playerIdx} 건설 실패 — ${check.reason}` }].slice(-150) };
      }
      const cfg = BUILDINGS[action.key];
      const p = state.players[action.playerIdx];
      const ps = [...state.players];
      const newRes = { ...p.resources };
      for (const [r, amt] of Object.entries(cfg.cost)) {
        newRes[r] = (newRes[r] || 0) - amt;
      }
      ps[action.playerIdx] = { ...p, resources: newRes };
      const cell = state.map[action.coord];
      const newMap = { ...state.map, [action.coord]: { ...cell, building: action.key, fortified: (cell.fortified || 0) + (action.key === 'security' ? 2 : 0) } };
      let s = { ...state, players: ps, map: newMap };
      const marker = action.playerIdx === 0 ? '⭐ 당신 ' : '';
      s = logEntry(s, `${marker}${cfg.icon} P${action.playerIdx} [${p.specific}] · ${cfg.name} 건설 @ ${action.coord} (${cfg.desc})`);
      // 건설은 약간의 mfg/party 트랙 보상
      s = raiseTrack(s, action.playerIdx, action.key === 'factory' || action.key === 'security' ? 'mfg' : 'party', 1, '건설');
      return s;
    }

    case 'SIGNAL_INVEST': {
      // v0.6.3d: data 3 → NPC 블록 시그널 +1
      const { playerIdx, npcIdx } = action;
      const p = state.players[playerIdx];
      const npc = state.players[npcIdx];
      if (!p || !npc?.isNpc || !npc.signal) return state;
      if ((p.resources.data || 0) < SIGNAL_REVEAL_COST.data) {
        return { ...state, log: [...state.log, { round: state.meta.round, phase: state.meta.phase, message: `❌ P${playerIdx} 시그널 투자 실패 — data ${SIGNAL_REVEAL_COST.data} 필요` }].slice(-150) };
      }
      const ps = [...state.players];
      ps[playerIdx] = { ...p, resources: { ...p.resources, data: p.resources.data - SIGNAL_REVEAL_COST.data } };
      let s = { ...state, players: ps };
      s = revealSignal(s, npcIdx, playerIdx, 1);
      return s;
    }

    case 'CLAIM_ACHIEVEMENT': {
      // action.playerIdx, action.achievementId
      if (state.meta.claimedAchievements[action.achievementId] !== undefined) return state;
      const achv = ACHIEVEMENTS_IN.find(a => a.id === action.achievementId);
      if (!achv) return state;
      const ps = state.players.map((p, i) => {
        if (i !== action.playerIdx) return p;
        const res = { ...p.resources };
        if (achv.reward.res) res.credit += achv.reward.res;
        if (achv.reward.rep) res.rep += achv.reward.rep;
        if (achv.reward.parts) res.parts += achv.reward.parts;
        if (achv.reward.data) res.data += achv.reward.data;
        if (achv.reward.contact) res.influence += achv.reward.contact;
        return { ...p, resources: res, achievements: [...p.achievements, action.achievementId] };
      });
      return {
        ...state,
        players: ps,
        meta: { ...state.meta, claimedAchievements: { ...state.meta.claimedAchievements, [action.achievementId]: action.playerIdx } },
        log: [...state.log, { round: state.meta.round, phase: state.meta.phase, message: `🏆 P${action.playerIdx} 업적 달성: ${achv.name}` }].slice(-150),
      };
    }

    case 'MOVE_PLAYER': {
      // action.playerIdx, action.to
      const ps = state.players.map((p, i) => {
        if (i !== action.playerIdx) return p;
        return { ...p, position: action.to };
      });
      return {
        ...state,
        players: ps,
        log: [...state.log, { round: state.meta.round, phase: state.meta.phase, message: `P${action.playerIdx} 이동 → ${action.to}` }].slice(-150),
      };
    }

    case 'VICTORY':
      return { ...state, meta: { ...state.meta, gameOver: true, winner: action.winner, winReason: action.reason } };

    case 'RESET':
      // v1.0: opts 객체로 통합. 호환: humanRole/humanSpecific/mapSize 직접 전달도 지원
      if (action.opts) return initGame(action.opts.role, action.opts.specific, undefined, action.opts.mapSize, action.opts);
      return initGame(action.humanRole, action.humanSpecific, undefined, action.mapSize);

    default:
      return state;
  }
}

function getInitiative(p) {
  if (p.role === 'ghost' && p.plannedCards[0]) {
    const c = getCard(p.plannedCards[0]);
    return c?.init ?? 50;
  }
  if (p.role === 'bloc' && p.plannedCards[0]) {
    return (p.tl || 1) * 10;
  }
  return 50;
}

function executeCards(state, playerIdx) {
  let s = { ...state };
  const p = s.players[playerIdx];
  if (!p.plannedCards || p.plannedCards.length === 0) return s;

  if (p.role === 'ghost') {
    // plannedHalves[i] = 'top' | 'bot' — 각 카드에서 어느 반쪽을 쓸지
    // 기본: 1번 카드=top, 2번 카드=bot. 사용자가 선택 가능
    const halves = p.plannedHalves && p.plannedHalves.length === p.plannedCards.length
      ? p.plannedHalves
      : p.plannedCards.map((_, i) => i === 0 ? 'top' : 'bot');
    // 실행: 선택 순서대로 (top 먼저 → bot 나중, 하지만 둘 다 top이면 0번→1번 순)
    const order = [...p.plannedCards.keys()].sort((a, b) => {
      const ha = halves[a], hb = halves[b];
      if (ha === hb) return a - b;
      return ha === 'top' ? -1 : 1;  // top 먼저
    });
    for (const idx of order) {
      const c = getCard(p.plannedCards[idx]);
      const half = halves[idx];
      if (c && c[half]) s = applyEffect(s, playerIdx, c[half], half, c);
    }
    const newHand = p.hand.filter(h => !p.plannedCards.includes(h));
    const newDiscard = [...p.discard];
    const newLost = [...p.lost];
    p.plannedCards.forEach((cid) => {
      const c = getCard(cid);
      if (c?.loss) newLost.push(cid);
      else newDiscard.push(cid);
    });
    s.players = s.players.map((pp, j) => j === playerIdx ? { ...pp, hand: newHand, discard: newDiscard, lost: newLost, plannedHalves: [] } : pp);
  } else {
    // Bloc: Ghost와 동일하게 2장 × main/side 조합
    const halves = p.plannedHalves && p.plannedHalves.length === p.plannedCards.length
      ? p.plannedHalves
      : p.plannedCards.map((_, i) => i === 0 ? 'main' : 'side');
    const order = [...p.plannedCards.keys()].sort((a, b) => {
      const ha = halves[a], hb = halves[b];
      if (ha === hb) return a - b;
      return ha === 'main' ? -1 : 1;
    });
    for (const idx of order) {
      const c = getCard(p.plannedCards[idx]);
      const half = halves[idx];
      if (c && c[half]) s = applyEffect(s, playerIdx, c[half], half, c);
    }
    const newHand = p.hand.filter(h => !p.plannedCards.includes(h));
    const newDiscard = [...p.discard, ...p.plannedCards];
    s.players = s.players.map((pp, j) => j === playerIdx ? { ...pp, hand: newHand, discard: newDiscard, plannedHalves: [] } : pp);
  }
  return s;
}

// ============================================================================
// 경로 탐색: 가장 가까운 Bloc 소유 구역 찾기 (BFS, Chebyshev 4-방향)
// ============================================================================
function bfsDistance(state, from, to) {
  if (from === to) return 0;
  const visited = new Set([from]);
  let frontier = [from];
  let dist = 0;
  while (frontier.length > 0) {
    dist++;
    const next = [];
    for (const c of frontier) {
      for (const a of coordsAdj(c)) {
        if (!state.map[a] || visited.has(a)) continue;
        if (a === to) return dist;
        visited.add(a);
        next.push(a);
      }
    }
    frontier = next;
  }
  return Infinity;
}

function findNearestBlocZone(state, fromCoord, excludeOwnBloc = null) {
  const visited = new Set([fromCoord]);
  let frontier = [fromCoord];
  while (frontier.length > 0) {
    const next = [];
    for (const c of frontier) {
      const cell = state.map[c];
      if (!cell) continue;
      if (cell.owner !== null && cell.owner !== undefined) {
        const owner = state.players[cell.owner];
        if (owner?.role === 'bloc' && owner.specific !== excludeOwnBloc) {
          return c; // Found bloc zone
        }
      }
      for (const adj of coordsAdj(c)) {
        if (!visited.has(adj)) { visited.add(adj); next.push(adj); }
      }
    }
    frontier = next;
  }
  return null;
}

// 현재 위치에서 목표 방향으로 한 칸 이동 (BFS 기반)
function stepToward(state, fromCoord, toCoord) {
  if (fromCoord === toCoord) return fromCoord;
  // BFS로 경로 찾기
  const parent = { [fromCoord]: null };
  const queue = [fromCoord];
  while (queue.length > 0) {
    const c = queue.shift();
    if (c === toCoord) {
      // Backtrack to find first step
      let step = c;
      while (parent[step] !== fromCoord && parent[step] !== null) step = parent[step];
      return step === toCoord ? toCoord : step;
    }
    for (const adj of coordsAdj(c)) {
      if (!(adj in parent)) { parent[adj] = c; queue.push(adj); }
    }
  }
  return fromCoord;
}

function applyEffect(state, playerIdx, effect, kind, card) {
  let s = state;
  const p = s.players[playerIdx];

  // 속성 생성 (개인 풀)
  if (effect.gen) {
    const curPool = { ...(s.players[playerIdx].pool || {}) };
    const keys = effect.gen.split(':');
    keys.forEach(k => { curPool[k] = (curPool[k] || 0) + 1; });
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], pool: curPool };
    s = { ...s, players: ps };
    const meTag = playerIdx === 0 ? '⭐ 당신 ' : '';
    s = logEntry(s, `${meTag}P${playerIdx} [${p.specific}] · 속성 ${keys.join('+')} +1 (개인 풀)`);
  }

  // 비용 지불 (개인 풀에서)
  if (effect.cost) {
    const curPool = { ...(s.players[playerIdx].pool || {}) };
    for (const a of effect.cost) {
      if (curPool[a] > 0) curPool[a]--;
      else if (curPool.GRID > 0) curPool.GRID--;
      else {
        const meTag = playerIdx === 0 ? '⭐ 당신 ' : '';
        s = logEntry(s, `${meTag}P${playerIdx} · ${a} 부족 — 효과 불발 (${cardDisplayName(card) || card?.name})`);
        return s;
      }
    }
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], pool: curPool };
    s = { ...s, players: ps };
  }

  // === 이동 (스마트 라우팅, effect.move 스텝만큼 반복) ===
  if (effect.move) {
    const meTag = playerIdx === 0 ? '⭐ 당신 ' : '';
    const startPos = s.players[playerIdx].position;
    let current = startPos;
    const path = [startPos];
    // 사람(P0)이 지도에서 직접 목표를 찍었으면 그 좌표를 우선 사용
    const userGoal = (playerIdx === 0 && s.meta.pendingMoveTarget) ? s.meta.pendingMoveTarget : null;
    for (let step = 0; step < effect.move; step++) {
      let nextStep = null;
      const pNow = s.players[playerIdx];
      if (userGoal) {
        if (current === userGoal) break;
        nextStep = stepToward(s, current, userGoal);
      } else if (pNow.role === 'ghost') {
        const goal = findNearestBlocZone(s, current);
        if (goal && goal !== current) {
          nextStep = stepToward(s, current, goal);
        } else if (goal === current) {
          break; // 이미 목표 도착, 남은 이동은 보존
        } else {
          const adj = coordsAdj(current);
          if (adj.length) nextStep = rand(adj);
        }
      } else {
        // Bloc: 빈 buildable 구역 선호
        const adj = coordsAdj(current);
        const empty = adj.filter(c => s.map[c] && s.map[c].owner === null && ZONE_TYPES[s.map[c].zone]?.buildable);
        if (empty.length > 0) nextStep = rand(empty);
        else if (adj.length > 0) nextStep = rand(adj);
      }
      if (!nextStep || nextStep === current) break;
      current = nextStep;
      path.push(current);
      // 각 스텝마다 s.players 업데이트
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], position: current };
      const v = new Set(s.meta.zonesVisited[playerIdx] || []);
      v.add(current);
      s = { ...s, players: ps, meta: { ...s.meta, zonesVisited: { ...s.meta.zonesVisited, [playerIdx]: v } } };
    }
    if (path.length > 1) {
      const finalPos = current;
      const zName = ZONE_TYPES[s.map[finalPos]?.zone]?.name || finalPos;
      const pathStr = path.join(' → ');
      s = logEntry(s, `${meTag}🚶 P${playerIdx} [${p.specific}] · ${pathStr} (${zName}, ${path.length - 1}칸 이동)`);
      // v0.6.3b: 3칸 이상 이동 시 수송 트랙 +1 (Speakeasy식 단발 보상)
      if (path.length - 1 >= 3) s = raiseTrack(s, playerIdx, 'transport', 1, '장거리 이동');
      // v0.9.1: NEXUS 첫 도달 하이라이트
      if (s.map[finalPos]?.zone === 'nex') s = recordHighlight(s, 'first_nexus_visit', playerIdx);

      // === Ghost가 다른 Ghost와 같은 구역에 있음 → PvP 옵션 ===
      const pAfterMove = s.players[playerIdx];
      if (pAfterMove.role === 'ghost') {
        const rivalGhosts = s.players.filter((pp, i) => i !== playerIdx && !pp.defeated && pp.role === 'ghost' && pp.position === pAfterMove.position);
        if (rivalGhosts.length > 0) {
          const rival = rivalGhosts[0];
          const rivalIdx = s.players.indexOf(rival);
          if (playerIdx === 0) {
            // 사용자에게 결투 선택 모달
            s = {
              ...s,
              meta: {
                ...s.meta,
                pendingGhostDuel: {
                  coord: pAfterMove.position,
                  atkGhostIdx: 0,
                  defGhostIdx: rivalIdx,
                  atkStat: pAfterMove.stats.atk,
                  defStat: rival.stats.def,
                  zoneNm: ZONE_TYPES[s.map[pAfterMove.position]?.zone]?.name || '',
                },
              },
            };
            s.meta._didAutoRaid = true;
          } else {
            // 봇이 P0를 공격하는 경우: 자동 결투 (상성 적용)
            const atkRoll = d6();
            const defRoll = d6();
            const counterBonus = countersGhost(pAfterMove.specific, rival.specific) ? 2 : 0;
            const atkTotal = pAfterMove.stats.atk + trackBonus(pAfterMove, 'atk') + atkRoll + counterBonus;
            const defTotal = rival.stats.def + trackBonus(rival, 'def') + defRoll;
            const ps = [...s.players];
            if (atkTotal >= defTotal + 2) {
              // 공격자 승리: 렙+2, 방어자 자원 일부 탈취
              const loot = Math.min(3, rival.resources.credit || 0);
              ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 2, credit: (ps[playerIdx].resources.credit || 0) + loot } };
              ps[rivalIdx] = { ...ps[rivalIdx], resources: { ...ps[rivalIdx].resources, credit: Math.max(0, (ps[rivalIdx].resources.credit || 0) - loot) }, hp: Math.max(0, ps[rivalIdx].hp - 2) };
              s = { ...s, players: ps };
              s = logEntry(s, `⚔️ Ghost 결투: P${playerIdx} → P${rivalIdx} · ${atkTotal} vs ${defTotal} · 승리 · 렙+2, ₵+${loot}, 상대 HP-2`);
              if (rivalIdx === 0) s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'ghost_pvp', detail: `HP-2, ₵-${loot}` } };
            } else if (defTotal >= atkTotal + 2) {
              // 방어자 반격
              ps[playerIdx] = { ...ps[playerIdx], hp: Math.max(0, ps[playerIdx].hp - 2) };
              s = { ...s, players: ps };
              s = logEntry(s, `⚔️ Ghost 결투: P${playerIdx} → P${rivalIdx} · ${atkTotal} vs ${defTotal} · 반격당함 · HP-2`);
            } else {
              s = logEntry(s, `⚔️ Ghost 결투: P${playerIdx} → P${rivalIdx} · ${atkTotal} vs ${defTotal} · 무승부 (양측 무사)`);
            }
            s.meta._didAutoRaid = true;
          }
        }
      }

      // === Ghost가 Bloc 소유 구역에 도착 → 레이드 시도 ===
      // v0.6.0: RIGGER는 도착 + 인접 Bloc 구역도 드론 레이드 후보. 가까운 Bloc 찾음.
      if (pAfterMove.role === 'ghost' && !s.meta._didAutoRaid) {
        let cellThere = s.map[pAfterMove.position];
        let effectiveCoord = pAfterMove.position;
        // RIGGER 원격: 현위치에 Bloc 없으면 인접 Bloc 검색
        if (pAfterMove.specific === 'RIGGER' && (!cellThere || cellThere.owner === null || cellThere.owner === undefined || s.players[cellThere.owner]?.role !== 'bloc')) {
          const adj = coordsAdj(pAfterMove.position);
          const adjBloc = adj.find(c => {
            const cell = s.map[c];
            return cell?.owner !== null && cell?.owner !== undefined && s.players[cell.owner]?.role === 'bloc';
          });
          if (adjBloc) { cellThere = s.map[adjBloc]; effectiveCoord = adjBloc; }
        }
        if (cellThere?.owner !== null && cellThere?.owner !== undefined && s.players[cellThere.owner]?.role === 'bloc') {
          const blocIdx = cellThere.owner;
          const bloc = s.players[blocIdx].specific;
          const zoneNm = ZONE_TYPES[cellThere.zone]?.name || '';
          const threshold = 5;
          if (playerIdx === 0) {
            // v0.5.22: 확장된 레이드 상태 — 타입 선택 + 자원 투자 + 3단계 판정
            const zoneType = cellThere.zone;
            s = {
              ...s,
              meta: {
                ...s.meta,
                pendingRaid: {
                  coord: effectiveCoord,
                  bloc,
                  zoneNm,
                  zoneType,
                  blocIdx,
                  stats: { atk: pAfterMove.stats.atk, spd: pAfterMove.stats.spd, hack: pAfterMove.stats.hack },
                  fortified: cellThere.fortified || 0,
                  // 사용자가 단계적으로 채움
                  selectedType: null,
                  invested: { weapons: 0, data: 0, poolAttr: null },
                  executed: false,
                  phase: 'type',  // 'type' | 'invest' | 'done'
                },
              },
            };
            s.meta._didAutoRaid = true;
          } else {
            // 봇: 기존 자동 로직 + 상성 보너스 + 트랙 보너스(v0.6.3c)
            const raidRoll = d6();
            const counterBonus = countersBloc(pAfterMove.specific, bloc) ? 1 : 0;
            const tBonus = trackBonus(pAfterMove, 'atk');
            const raidTotal = raidRoll + pAfterMove.stats.atk + counterBonus + tBonus;
            if (raidTotal >= threshold) {
              const newStocks = { ...s.stocks, [bloc]: Math.max(1, s.stocks[bloc] - 3) };
              const ps = [...s.players];
              ps[playerIdx] = {
                ...ps[playerIdx],
                resources: { ...ps[playerIdx].resources, rep: ps[playerIdx].resources.rep + 3 },
                wanted: ps[playerIdx].wanted + 1,
              };
              const newMap = { ...s.map, [effectiveCoord]: { ...cellThere, owner: null } };
              s = { ...s, players: ps, stocks: newStocks, map: newMap, heat: Math.min(10, s.heat + 1) };
              s.meta.raidsThisGame[playerIdx] = (s.meta.raidsThisGame[playerIdx] || 0) + 1;
              s = logEntry(s, `🗡️ 레이드 성공! P${playerIdx} → [${effectiveCoord} ${zoneNm}] 🎲${raidRoll}+${pAfterMove.stats.atk}=${raidTotal} ≥ ${threshold} — ${bloc} 주가-3, 구역 중립화, 렙+3`);
              s = raiseTrack(s, playerIdx, 'combat', 1, '봇 레이드 성공');  // v0.6.3b
              s.meta._didAutoRaid = true;
              if (blocIdx === 0 && playerIdx !== 0) {
                s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'raid', detail: `${effectiveCoord} 잃음, ${bloc} 주가-3` } };
              }
            } else {
              const ps = [...s.players];
              ps[playerIdx] = {
                ...ps[playerIdx],
                hp: Math.max(0, ps[playerIdx].hp - 3),
                wanted: ps[playerIdx].wanted + 1,
              };
              s = { ...s, players: ps, heat: Math.min(10, s.heat + 1) };
              s = logEntry(s, `❌ 레이드 실패 P${playerIdx} [${effectiveCoord} ${zoneNm}] 🎲${raidRoll}+${pAfterMove.stats.atk}=${raidTotal} < ${threshold} — HP-3, 수배+1`);
              s.meta._didAutoRaid = true;
            }
          }
        }
      }
    }
    // 사용자 지정 목표를 사용했으면 소비 (1회 사용)
    if (playerIdx === 0 && s.meta.pendingMoveTarget) {
      s = { ...s, meta: { ...s.meta, pendingMoveTarget: null, moveBudget: 0 } };
    }

    // === 구역 첫 방문 보너스 (P0 전용, 실제로 이동한 경우만, 자동 레이드 발생 시 스킵) ===
    if (playerIdx === 0 && !s.meta._didAutoRaid && path.length > 1) {
      const pNow = s.players[0];
      const cellThere = s.map[pNow.position];
      const visitedMap = s.meta.visitedBonusZones || {};
      const visitedByMe = visitedMap[0] || {};
      if (cellThere && !visitedByMe[pNow.position]) {
        const zoneKind = cellThere.zone;
        const pool = ZONE_BONUS_POOL[zoneKind];
        if (pool && pool.length > 0) {
          const shuffled = [...pool].sort(() => Math.random() - 0.5);
          const options = shuffled.slice(0, Math.min(3, pool.length));
          const newVisited = { ...visitedByMe, [pNow.position]: true };
          s = {
            ...s,
            meta: {
              ...s.meta,
              zoneBonusPending: { zone: zoneKind, coord: pNow.position, options },
              visitedBonusZones: { ...visitedMap, 0: newVisited },
            },
          };
          const zName = ZONE_TYPES[zoneKind]?.name || zoneKind;
          s = logEntry(s, `⭐ 당신 🌟 ${pNow.position} (${zName}) 첫 방문 — 보너스 3중 1 선택`);
        }
      }
    }
    // 다음 턴 쓸 수 있게 플래그 초기화
    s = { ...s, meta: { ...s.meta, _didAutoRaid: false } };
  }

  // === OPERATIVE 배치 (Bloc 구역 확장) ===
  // v0.6.6b: 점령 시 ₵+3 + party 트랙 보너스 (Bloc 강화)
  if (effect.deploy_op && p.role === 'bloc') {
    const curPos = s.players[playerIdx].position;
    const adj = coordsAdj(curPos);
    const empty = adj.filter(c => s.map[c] && s.map[c].owner === null && ZONE_TYPES[s.map[c].zone]?.buildable);
    const count = Math.min(effect.deploy_op, empty.length);
    if (count > 0) {
      const newMap = { ...s.map };
      const captured = [];
      for (let i = 0; i < count; i++) {
        const target = empty[i];
        newMap[target] = { ...newMap[target], owner: playerIdx };
        captured.push(target);
      }
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + count * 3 } };
      s = { ...s, map: newMap, players: ps };
      const names = captured.map(c => `${c}(${ZONE_TYPES[s.map[c].zone]?.name || ''})`).join(', ');
      s = logEntry(s, `🏢 P${playerIdx} [${p.specific}] · 구역 점령: ${names} — 자산 +${count * 5} ₵+${count * 3}`);
      s = raiseTrack(s, playerIdx, 'party', 1, '구역 점령');
    } else {
      // v0.6.6b: 빈 구역 없어도 보상 (점령 못 해도 의미 있게) — ₵+2
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 2 } };
      s = { ...s, players: ps };
      s = logEntry(s, `🏢 P${playerIdx} [${p.specific}] · 점령 불발 (₵+2 위로금)`);
    }
  }

  // === 공격 (같은 구역 적) ===
  if (effect.atk || effect.atk_x2 || effect.atk_x3_retort) {
    const curP = s.players[playerIdx];
    const atkVal = effect.atk || (effect.atk_x2 ? curP.stats.atk : 0) || 0;
    const enemies = s.players.filter((pp, i) => i !== playerIdx && !pp.defeated && pp.position === curP.position);
    if (enemies.length > 0) {
      const target = enemies[0];
      const tIdx = s.players.indexOf(target);
      const atkRoll = d6();
      const defRoll = d6();
      const atkTotal = curP.stats.atk + trackBonus(curP, 'atk') + atkVal + atkRoll;
      const defTotal = target.stats.def + trackBonus(target, 'def') + defRoll;
      const dmg = Math.max(0, atkTotal - defTotal);
      s = logEntry(s, `💥 P${playerIdx} → P${tIdx} (${target.specific}) · 공격 ${curP.stats.atk}+${atkVal}+🎲${atkRoll}=${atkTotal} vs 방어 ${target.stats.def}+🎲${defRoll}=${defTotal} → 피해 ${dmg}`);
      const ps = [...s.players];
      ps[tIdx] = { ...ps[tIdx], hp: Math.max(0, ps[tIdx].hp - dmg) };
      let psMut = ps;  // v0.9.3-fix: const → let (deathSave 후 재할당 위해)
      if (psMut[tIdx].hp === 0) {
        // v0.6.4: 경호 LV5 deathSave — HP 0→1 복구하고 능력 소진
        if (psMut[tIdx].onceAbilities?.deathSave) {
          psMut[tIdx] = { ...psMut[tIdx], hp: 1, onceAbilities: { ...psMut[tIdx].onceAbilities, deathSave: false } };
          s = logEntry(s, `🛡 P${tIdx} (${target.specific}) · 경호 LV5 deathSave 발동! HP 0→1`);
          s = { ...s, players: psMut };
          s = recordHighlight(s, 'death_save', tIdx);  // v0.9.1
          psMut = [...s.players];
        } else {
          psMut[tIdx] = { ...psMut[tIdx], defeated: true };
          s = logEntry(s, `⚰️ P${tIdx} (${target.specific}) 쓰러짐`);
        }
      }
      s = { ...s, players: psMut };
      s.meta.attacksUsed[playerIdx] = (s.meta.attacksUsed[playerIdx] || 0) + 1;
    }
  }

  // === 레이드 (Ghost + Bloc 구역에서 공격 카드 사용 시) ===
  // ⚠ 중요: p는 시작 시점 기준이라 이동 후 무효. 현재 위치 재읽기 필수
  const curP2 = s.players[playerIdx];
  const atCell = s.map[curP2.position];
  const isBlocOwnedZone = atCell?.owner !== null && atCell?.owner !== undefined && s.players[atCell.owner]?.role === 'bloc';
  if (curP2.role === 'ghost' && effect.atk && isBlocOwnedZone) {
    const blocIdx = atCell.owner;
    const bloc = s.players[blocIdx].specific;
    const zName = ZONE_TYPES[atCell.zone]?.name || '';
    const raidRoll = d6();
    const raidTotal = raidRoll + curP2.stats.atk + trackBonus(curP2, 'atk');  // v0.6.3c
    const threshold = 5;
    if (raidTotal >= threshold) {
      // 성공 — 주가 -3, 렙 +3, 구역 점령 여부 선택
      const newStocks = { ...s.stocks, [bloc]: Math.max(1, s.stocks[bloc] - 3) };
      s = { ...s, stocks: newStocks };
      const ps = [...s.players];
      ps[playerIdx] = {
        ...ps[playerIdx],
        resources: { ...ps[playerIdx].resources, rep: ps[playerIdx].resources.rep + 3 },
        wanted: ps[playerIdx].wanted + 1,
      };
      const newMap = { ...s.map, [curP2.position]: { ...atCell, owner: null } };
      s = { ...s, players: ps, map: newMap, heat: Math.min(10, s.heat + 1) };
      s.meta.raidsThisGame[playerIdx] = (s.meta.raidsThisGame[playerIdx] || 0) + 1;
      const meTag = playerIdx === 0 ? '⭐ 당신 ' : '';
      s = logEntry(s, `${meTag}🗡️ 레이드 성공! [${curP2.position} ${zName}] 🎲${raidRoll}+${curP2.stats.atk}=${raidTotal} — ${bloc} 주가-3, 구역 중립화, P${playerIdx} 렙+3 (누적 ${ps[playerIdx].resources.rep}), 현상수배+1`);
      s = raiseTrack(s, playerIdx, 'combat', 1, '레이드 성공');  // v0.6.3b
    } else {
      const ps = [...s.players];
      ps[playerIdx] = {
        ...ps[playerIdx],
        hp: Math.max(0, ps[playerIdx].hp - 3),
        wanted: ps[playerIdx].wanted + 1,
      };
      s = { ...s, players: ps, heat: Math.min(10, s.heat + 1) };
      const meTag = playerIdx === 0 ? '⭐ 당신 ' : '';
      s = logEntry(s, `${meTag}❌ 레이드 실패 [${curP2.position} ${zName}] 🎲${raidRoll}+${curP2.stats.atk}=${raidTotal} < ${threshold} — P${playerIdx} HP-3, 현상수배+1`);
    }
  }

  // === 회복 (아군 Ghost 50%) ===
  if (effect.heal_all) {
    const ps = s.players.map(pp => pp.role === 'bloc' ? pp : { ...pp, hp: Math.min(pp.maxHp, pp.hp + Math.floor(pp.maxHp * 0.5)) });
    s = { ...s, players: ps };
    s = logEntry(s, `💚 P${playerIdx} [${p.specific}] · 아군 Ghost 전원 HP 50% 회복`);
  }

  if (card?.loss) {
    s.meta.lostCardsUsed[playerIdx] = (s.meta.lostCardsUsed[playerIdx] || 0) + 1;
  }

  // === 주가 조작 ===
  if (effect.crash_stock || effect.crash_target) {
    // v0.6.6c: CIPHER 주가 조작 강화 — Ghost인 경우 추가 ★+amt + mfg 트랙
    const candidates = Object.keys(s.stocks).filter(b => !(p.role === 'bloc' && p.specific === b));
    const target = rand(candidates);
    const amt = effect.crash_stock || effect.crash_target || 3;
    const newStocks = { ...s.stocks, [target]: Math.max(1, s.stocks[target] - amt) };
    s = { ...s, stocks: newStocks };
    if (p.role === 'ghost') {
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + amt, data: (ps[playerIdx].resources.data || 0) + 1 } };
      s = { ...s, players: ps };
    }
    s = logEntry(s, `📉 P${playerIdx} [${p.specific}] · ${target} 주가 -${amt}${p.role === 'ghost' ? ` (Ghost ★+${amt} 📡+1)` : ''}`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '주가 조작');
  }

  // === 무기·자원 지급 ===
  if (effect.weapons) {
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, weapons: (ps[playerIdx].resources.weapons || 0) + effect.weapons } };
    s = { ...s, players: ps };
    s = logEntry(s, `🔩 P${playerIdx} · 무기 +${effect.weapons}`);
  }
  if (effect.credit) {
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + effect.credit } };
    s = { ...s, players: ps };
    s = logEntry(s, `₵ P${playerIdx} · 크레딧 +${effect.credit}`);
  }
  if (effect.parts) {
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, parts: (ps[playerIdx].resources.parts || 0) + effect.parts } };
    s = { ...s, players: ps };
    s = logEntry(s, `⚙️ P${playerIdx} · 부품 +${effect.parts}`);
  }

  // === 공권력 변동 ===
  if (effect.heat) {
    const newHeat = Math.max(0, Math.min(10, s.heat + effect.heat));
    s = { ...s, heat: newHeat };
    s = logEntry(s, `🚨 공권력 ${effect.heat > 0 ? '+' : ''}${effect.heat} → ${newHeat}`);
  }

  // === v0.5.10: 미구현 효과 키 폴백 보상 (BROKER·CIPHER·MOLE 언더파워 해소) ===
  // 원래 카드 텍스트에 있던 효과가 구현 안 됐으면 최소 자원/렙 보상 부여해 Ghost 비대칭 전략 루트 강화
  if (effect.contact) {
    // v0.6.5d: 접선 강화 — 영향력+contact, ₵+contact*2, ★+contact (BROKER 평판 루트)
    const ps = [...s.players];
    const add = effect.contact * 2;
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, influence: (ps[playerIdx].resources.influence || 0) + effect.contact, credit: (ps[playerIdx].resources.credit || 0) + add, rep: (ps[playerIdx].resources.rep || 0) + effect.contact } };
    s = { ...s, players: ps };
    s = logEntry(s, `🎙️ P${playerIdx} · 접선 +${effect.contact} · ₵+${add} ★+${effect.contact}`);
    s = raiseTrack(s, playerIdx, 'party', 1, '접선');
  }
  if (effect.blackmarket) {
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, weapons: (ps[playerIdx].resources.weapons || 0) + effect.blackmarket, credit: (ps[playerIdx].resources.credit || 0) + effect.blackmarket * 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🕶 P${playerIdx} · 블랙마켓 구매 (무기+${effect.blackmarket}, ₵+${effect.blackmarket * 2})`);
  }
  if (effect.extort) {
    // v0.6.5d: 협박 강화 — 렙 ratio 1.5→2배 + party 트랙 +1
    const repGain = effect.extort * 2;
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + repGain, credit: (ps[playerIdx].resources.credit || 0) + effect.extort } };
    s = { ...s, players: ps };
    s = logEntry(s, `💼 P${playerIdx} · 협박 · ★+${repGain}, ₵+${effect.extort}`);
    s = raiseTrack(s, playerIdx, 'party', 1, '협박');
  }
  if (effect.peek_objective || effect.sell_info || effect.peek_hand || effect.peek_full || effect.peek_news) {
    // v0.5.18: 정보 수집/판매 → rep + data + 크레딧 (Bloc의 경우 자산 직결)
    const amount = effect.sell_info ? 3 : 2;
    const isBloc = p.role === 'bloc';
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + amount, data: (ps[playerIdx].resources.data || 0) + amount, credit: (ps[playerIdx].resources.credit || 0) + (isBloc ? amount * 2 : 0) } };
    s = { ...s, players: ps };
    s = logEntry(s, `👁 P${playerIdx} · 정보 행동 · ★+${amount}, 📡+${amount}${isBloc ? `, ₵+${amount*2}` : ''}`);
  }
  if (effect.scout || effect.scout_all || effect.drone_scan) {
    // v0.5.17: 정찰 → data + 렙 (RIGGER 구제)
    const amount = effect.scout_all ? 2 : 1;
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, data: (ps[playerIdx].resources.data || 0) + amount, rep: (ps[playerIdx].resources.rep || 0) + amount } };
    s = { ...s, players: ps };
    s = logEntry(s, `🛰 P${playerIdx} · 정찰 · 📡+${amount}, ★+${amount}`);
    s = raiseTrack(s, playerIdx, 'security', 1, '정찰');  // v0.6.3b
    // v0.6.3d: 정찰은 가장 시그널 낮은 NPC 시그널 +1
    const npcIdx = s.players.findIndex(pp => pp.isNpc && pp.signal && pp.signal.revealed < pp.signal.max);
    if (npcIdx >= 0) s = revealSignal(s, npcIdx, playerIdx, 1);
  }
  if (effect.broker_fee) {
    // v0.6.5d: 중개 수수료 강화 — ★+broker_fee/3
    const repGain = Math.max(1, Math.floor(effect.broker_fee / 3));
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + effect.broker_fee, rep: (ps[playerIdx].resources.rep || 0) + repGain } };
    s = { ...s, players: ps };
    s = logEntry(s, `🤝 P${playerIdx} · 중개 수수료 ₵+${effect.broker_fee}, ★+${repGain}`);
    s = raiseTrack(s, playerIdx, 'party', 1, '중개');
  }
  if (effect.stop_combat || effect.cancel_card || effect.cancel_action) {
    // 중단·취소 → rep 평판 (실제로는 다른 플레이어 타겟팅 필요하지만 여기선 보너스로)
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🛑 P${playerIdx} · 개입 · ★+2`);
  }
  if (effect.invisible || effect.invisible_2r || effect.stealth || effect.hide_actions || effect.hide_actions_1r || effect.negate_scout) {
    // 은신/은폐 → 수배 감소 + rep
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], wanted: Math.max(0, (ps[playerIdx].wanted || 0) - 1), resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 1 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🕶 P${playerIdx} · 은신 · 수배-1, ★+1`);
    s = raiseTrack(s, playerIdx, 'security', 1, '은신');  // v0.6.3b
  }
  if (effect.clear_wanted || effect.burn_identity) {
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], wanted: 0 };
    s = { ...s, players: ps };
    s = logEntry(s, `🧹 P${playerIdx} · 수배 초기화`);
    s = raiseTrack(s, playerIdx, 'security', 1, '수배 초기화');  // v0.6.3b
  }
  if (effect.heal) {
    const curP = s.players[playerIdx];
    const healed = Math.min(curP.maxHp, curP.hp + effect.heal);
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], hp: healed };
    s = { ...s, players: ps };
    s = logEntry(s, `❤️ P${playerIdx} · HP +${effect.heal} (→${healed})`);
  }
  if (effect.stat_boost) {
    // v0.8.5: 일회성 판정 보너스 + 다음 R 시작 시 카드 1장 추가 드로우
    s = { ...s, meta: { ...s.meta, attackBonusOnce: (s.meta.attackBonusOnce || 0) + effect.stat_boost, extraDrawNext: (s.meta.extraDrawNext || 0) + 1 } };
    s = logEntry(s, `💪 P${playerIdx} · 다음 판정 +${effect.stat_boost}, 다음 R 카드+1`);
  }
  // v0.8.5: 신규 distinct 효과들
  if (effect.always_first) {
    // QUICK DRAW (BLADE): 이번 라운드 모든 판정에서 우선권 시뮬 → 적 1명 HP-2 + 자기 ★+2
    const cur = s.players[playerIdx];
    const enemies = s.players.filter((pp, i) => i !== playerIdx && !pp.defeated && pp.role !== cur.role);
    if (enemies.length > 0) {
      const target = enemies[Math.floor(Math.random() * enemies.length)];
      const tIdx = s.players.indexOf(target);
      const ps = [...s.players];
      ps[tIdx] = { ...ps[tIdx], hp: Math.max(0, ps[tIdx].hp - 2) };
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
      s = { ...s, players: ps };
      s = logEntry(s, `⚡ P${playerIdx} · 선제 공격 → P${tIdx} HP-2, 자기 ★+2`);
      s = raiseTrack(s, playerIdx, 'combat', 1, '선제');
    }
  }
  if (effect.target) {
    // CONTRACT KILL (BLADE): 가장 hp 높은 적 지정 → ★+5 + 적 HP-3
    const cur = s.players[playerIdx];
    const enemies = s.players.filter((pp, i) => i !== playerIdx && !pp.defeated && pp.role !== cur.role);
    if (enemies.length > 0) {
      enemies.sort((a, b) => b.hp - a.hp);
      const target = enemies[0];
      const tIdx = s.players.indexOf(target);
      const ps = [...s.players];
      ps[tIdx] = { ...ps[tIdx], hp: Math.max(0, ps[tIdx].hp - 3) };
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 5 } };
      s = { ...s, players: ps };
      s = logEntry(s, `🎯 P${playerIdx} · 계약 타겟 → P${tIdx} HP-3, ★+5`);
      s = raiseTrack(s, playerIdx, 'combat', 1, '계약 타겟');
    }
  }
  if (effect.reveal === 'zone' || effect.reveal_zone) {
    // PORT SCAN (CIPHER): 한 구역 토큰 공개 → 토큰 즉시 발동 + 📡+2
    const allCoords = Object.keys(s.map);
    const hidden = allCoords.filter(c => s.map[c] && !s.map[c].tokenRevealed && s.map[c].token);
    if (hidden.length > 0) {
      const pick = hidden[Math.floor(Math.random() * hidden.length)];
      const newMap = { ...s.map, [pick]: { ...s.map[pick], tokenRevealed: true } };
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, data: (ps[playerIdx].resources.data || 0) + 2, rep: (ps[playerIdx].resources.rep || 0) + 1 } };
      s = { ...s, map: newMap, players: ps };
      s = logEntry(s, `🔍 P${playerIdx} · ${pick} 토큰 공개 (📡+2 ★+1)`);
      s = raiseTrack(s, playerIdx, 'mfg', 1, '스캔');
    }
  }
  if (effect.swap_ratio) {
    // BACK DEAL (BROKER): 자원 1:2 환전 (data 1 → credit 2)
    const cur = s.players[playerIdx];
    const haveData = cur.resources.data || 0;
    const trade = Math.min(haveData, effect.swap_ratio);
    if (trade > 0) {
      const ps = [...s.players];
      ps[playerIdx] = { ...cur, resources: { ...cur.resources, data: haveData - trade, credit: (cur.resources.credit || 0) + trade * 2 } };
      s = { ...s, players: ps };
      s = logEntry(s, `🔁 P${playerIdx} · 뒷거래 환전 📡-${trade} → ₵+${trade * 2}`);
      s = raiseTrack(s, playerIdx, 'party', 1, '뒷거래');
    }
  }
  if (effect.swap || effect.swap_ratio) {
    // 자원 교환 → credit 전환
    const add = 3;
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + add } };
    s = { ...s, players: ps };
    s = logEntry(s, `🔄 P${playerIdx} · 거래 교환 ₵+${add}`);
  }
  if (effect.draw_quest || effect.quest_two || effect.slot_plus) {
    // 퀘스트 수령 → rep + credit
    const cnt = effect.quest_two ? 2 : 1;
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + cnt, credit: (ps[playerIdx].resources.credit || 0) + cnt * 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `📜 P${playerIdx} · 퀘스트 수주 ★+${cnt}, ₵+${cnt * 2}`);
  }
  if (effect.deploy_trap || effect.trap || effect.trap_damage) {
    // v0.6.6: 함정 강화 → 요새+2, ★+4, ₵+3 + mfg 트랙
    const curPos = s.players[playerIdx].position;
    if (curPos && s.map[curPos]) {
      const newMap = { ...s.map, [curPos]: { ...s.map[curPos], fortified: (s.map[curPos].fortified || 0) + 2 } };
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 4, credit: (ps[playerIdx].resources.credit || 0) + 3 } };
      s = { ...s, map: newMap, players: ps };
      s = logEntry(s, `🪤 P${playerIdx} · 함정 (${curPos} 요새+2, ★+4, ₵+3)`);
      s = raiseTrack(s, playerIdx, 'mfg', 1, '함정');
    }
  }
  if (effect.cargo_haul || effect.supply_drop || effect.haul) {
    // v0.6.6: 화물 강화 → ₵+5 ⚙+3 ★+3 + transport+mfg 트랙
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 5, parts: (ps[playerIdx].resources.parts || 0) + 3, rep: (ps[playerIdx].resources.rep || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `📦 P${playerIdx} · 화물 운반 ₵+5, ⚙+3, ★+3`);
    s = raiseTrack(s, playerIdx, 'transport', 1, '화물 운반');
    s = raiseTrack(s, playerIdx, 'mfg', 1, '화물 운반');
  }
  if (effect.ambush) {
    // 매복 → 다음 공격 보너스 + rep
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 1 } };
    s = { ...s, players: ps, meta: { ...s.meta, attackBonusOnce: (s.meta.attackBonusOnce || 0) + 2 } };
    s = logEntry(s, `🎯 P${playerIdx} · 매복 준비 (다음 판정+2, ★+1)`);
  }
  if (effect.copy_bloc_card) {
    // v0.7.1: 블록 카드 복사 → credit + rep + party 트랙 + MOLE mini-raid
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 5, rep: (ps[playerIdx].resources.rep || 0) + 4 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🎭 P${playerIdx} · 신분 위장 ₵+5, ★+4`);
    s = raiseTrack(s, playerIdx, 'party', 1, '신분 위장');
    if (s.players[playerIdx]?.specific === 'MOLE') s = tryMoleMiniRaid(s, playerIdx, '신분 위장');
  }
  if (effect.reward) {
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + effect.reward, rep: (ps[playerIdx].resources.rep || 0) + 1 } };
    s = { ...s, players: ps };
    s = logEntry(s, `💰 P${playerIdx} · 보상 ₵+${effect.reward}, ★+1`);
  }
  // === CARBON/HELIX/AXIOM Bloc 미구현 효과 폴백 ===
  if (effect.zone_income_2x || effect.div_2x) {
    // v0.6.6: 자사 구역 수입 강화 — 구역×6 + 부품+3 + mfg 트랙 +1 (CARBON 구제)
    const pNow = s.players[playerIdx];
    const ownCount = Object.values(s.map).filter(c => c.owner === playerIdx).length;
    const bonus = ownCount * 6;
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (pNow.resources.credit || 0) + bonus, parts: (pNow.resources.parts || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `⚡ P${playerIdx} [${p.specific}] · 수입 2배 ₵+${bonus} ⚙+3 (${ownCount}구역)`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '수입 2배');
  }
  if (effect.zero_income || effect.block_resource) {
    // 적 1회 수입 차단 시뮬: 랜덤 경쟁자 크레딧 -3
    const rivals = s.players.filter((pp, i) => i !== playerIdx && !pp.defeated);
    if (rivals.length > 0) {
      const target = rand(rivals);
      const tIdx = s.players.indexOf(target);
      const ps = [...s.players];
      ps[tIdx] = { ...ps[tIdx], resources: { ...ps[tIdx].resources, credit: Math.max(0, (target.resources.credit || 0) - 3) } };
      s = { ...s, players: ps };
      s = logEntry(s, `⛔ P${playerIdx} [${p.specific}] · P${tIdx} 수입 봉쇄 ₵-3`);
      if (tIdx === 0 && playerIdx !== 0) s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'block_resource', detail: `₵-3` } };
    }
  }
  if (effect.fortify || effect.veil_up) {
    // 방어 강화: 모든 자사 구역 fortified +1
    const newMap = { ...s.map };
    let count = 0;
    Object.entries(newMap).forEach(([coord, cell]) => {
      if (cell.owner === playerIdx) {
        newMap[coord] = { ...cell, fortified: (cell.fortified || 0) + 1 };
        count++;
      }
    });
    if (count > 0) {
      s = { ...s, map: newMap };
      s = logEntry(s, `🛡 P${playerIdx} [${p.specific}] · 자사 ${count}구역 방어+1`);
    }
  }
  if (effect.heal_all) {
    // v0.6.6b: HELIX 강화 — Ghost 전원 HP+3 + 자기 ₵+5 + 영향력+2 + party 트랙
    const cur = s.players[playerIdx];
    const ps = s.players.map(pp => pp.role === 'ghost' && !pp.defeated ? { ...pp, hp: Math.min(pp.maxHp, pp.hp + 3) } : pp);
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (cur.resources.credit || 0) + 5, influence: (cur.resources.influence || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `❤️ P${playerIdx} [${cur.specific}] · 의료 사업 (Ghost HP+3, 자사 ₵+5 🎙+2)`);
    s = raiseTrack(s, playerIdx, 'party', 1, '의료 사업');
  }
  if (effect.ghost_extra_card || effect.contracts_boost) {
    // v0.6.6b: Ghost 드로우 보너스 → ₵+5 📡+2 + mfg 트랙 (HELIX/CARBON 강화)
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 5, data: (ps[playerIdx].resources.data || 0) + 2 } };
    s = { ...s, players: ps };
    s = raiseTrack(s, playerIdx, 'mfg', 1, '계약 보너스');
    s = logEntry(s, `📄 P${playerIdx} [${p.specific}] · 계약 보너스 ₵+3, 📡+1`);
  }
  if (effect.same_round_trade || effect.flash_trade) {
    // AXIOM FLASH TRADE → 크레딧 보너스
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 4 } };
    s = { ...s, players: ps };
    s = logEntry(s, `⚡ P${playerIdx} · 플래시 트레이드 ₵+4`);
  }
  if (effect.algorithm || effect.long_contract) {
    // v0.6.6b: 대형 계약 강화 — ₵+8 영향+3 + 자사 주식 +1 (Bloc 자산 가속)
    const cur = s.players[playerIdx];
    const ps = [...s.players];
    const newRes = { ...cur.resources, credit: (cur.resources.credit || 0) + 8, influence: (cur.resources.influence || 0) + 3 };
    let newStocks = cur.stocks;
    if (cur.role === 'bloc' && cur.specific) {
      newStocks = { ...cur.stocks, [cur.specific]: (cur.stocks[cur.specific] || 0) + 1 };
    }
    ps[playerIdx] = { ...cur, resources: newRes, stocks: newStocks };
    s = { ...s, players: ps };
    s = logEntry(s, `📊 P${playerIdx} · 대형 계약 ₵+8, 🎙+3${cur.role === 'bloc' ? ', 자사주식+1' : ''}`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '대형 계약');
  }
  if (effect.bond) {
    // v0.5.18: 채권 → 크레딧 + 타 블록 주식 1주 자동 매수 (CARBON 자산 가속)
    const pNow = s.players[playerIdx];
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (pNow.resources.credit || 0) + effect.bond } };
    // 저가 타 블록 주식 1주 매수
    const blocs = Object.entries(s.stocks).filter(([bl]) => !(pNow.role === 'bloc' && pNow.specific === bl));
    blocs.sort((a, b) => a[1] - b[1]);
    if (blocs.length > 0) {
      const [bl, price] = blocs[0];
      if (ps[playerIdx].resources.credit >= price) {
        ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: ps[playerIdx].resources.credit - price }, stocks: { ...ps[playerIdx].stocks, [bl]: (ps[playerIdx].stocks[bl] || 0) + 1 } };
        s = { ...s, players: ps };
        s = logEntry(s, `🏦 P${playerIdx} · 채권 ₵+${effect.bond} + ${bl} 1주 자동매수`);
      } else {
        s = { ...s, players: ps };
        s = logEntry(s, `🏦 P${playerIdx} · 채권 ₵+${effect.bond}`);
      }
    } else {
      s = { ...s, players: ps };
      s = logEntry(s, `🏦 P${playerIdx} · 채권 ₵+${effect.bond}`);
    }
  }
  if (effect.destroy_zone) {
    // v0.6.6b: IRONWALL SCORCHED 강화 — 적 구역 1곳 파괴 + 자기 ₵+5 + 무기+2
    const targets = Object.entries(s.map).filter(([c, cell]) => cell.owner !== null && cell.owner !== undefined && cell.owner !== playerIdx);
    if (targets.length > 0) {
      const [coord, cell] = rand(targets);
      const targetP = s.players[cell.owner];
      const newMap = { ...s.map, [coord]: { ...cell, owner: null, destroyed: true } };
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 5, weapons: (ps[playerIdx].resources.weapons || 0) + 2 } };
      s = { ...s, map: newMap, players: ps };
      s = logEntry(s, `💥 P${playerIdx} [${p.specific}] · ${coord} 파괴 (P${cell.owner} ${targetP.specific}) ₵+5 🔩+2`);
      s = raiseTrack(s, playerIdx, 'combat', 1, '구역 파괴');
      if (cell.owner === 0 && playerIdx !== 0) s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'destroy_zone', detail: `${coord} 파괴` } };
    }
  }
  // v0.6.6b: 신규 Bloc 효과 폴백
  // v0.8.6: Bloc 능동 액션 3종 — 현상금 발행 / 청부 살인 / Ghost 추적
  if (effect.bounty_post && p.role === 'bloc') {
    // 현상금 발행: 평판 가장 낮은 Ghost 1명 선정 → 수배 +3 (체포 압박) + 자기 ₵+3
    const ghosts = s.players.filter(pp => pp.role === 'ghost' && !pp.defeated);
    if (ghosts.length > 0) {
      // 가장 평판 높은 (가장 위협적인) Ghost 표적
      ghosts.sort((a, b) => (b.resources.rep || 0) - (a.resources.rep || 0));
      const target = ghosts[0];
      const tIdx = s.players.indexOf(target);
      const ps = [...s.players];
      ps[tIdx] = { ...ps[tIdx], wanted: (ps[tIdx].wanted || 0) + 3 };
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 3, influence: (ps[playerIdx].resources.influence || 0) + 1 } };
      s = { ...s, players: ps };
      s = logEntry(s, `🎯 P${playerIdx} [${p.specific}] · 현상금 발행 → P${tIdx} ${target.specific} 수배+3, 자기 ₵+3 🎙+1`);
      s = raiseTrack(s, playerIdx, 'security', 1, '현상금');
      if (tIdx === 0) s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'bounty_post', detail: '수배+3' } };
    }
  }
  if (effect.assassin_contract && p.role === 'bloc') {
    // 청부 살인: 가장 hp 높은 Ghost 1명 → HP-4 + 자기 평판 +2 + ₵-3 (비용)
    const ghosts = s.players.filter(pp => pp.role === 'ghost' && !pp.defeated);
    if (ghosts.length > 0 && (p.resources.credit || 0) >= 3) {
      ghosts.sort((a, b) => b.hp - a.hp);
      const target = ghosts[0];
      const tIdx = s.players.indexOf(target);
      const ps = [...s.players];
      ps[tIdx] = { ...ps[tIdx], hp: Math.max(0, ps[tIdx].hp - 4) };
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) - 3, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
      s = { ...s, players: ps };
      s = logEntry(s, `🗡 P${playerIdx} [${p.specific}] · 청부 살인 → P${tIdx} ${target.specific} HP-4 (₵-3 ★+2)`);
      s = raiseTrack(s, playerIdx, 'combat', 1, '청부');
      if (tIdx === 0) s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'assassin_contract', detail: 'HP-4' } };
    }
  }
  if (effect.ghost_track && p.role === 'bloc') {
    // Ghost 추적: 모든 Ghost 위치를 본인 정보로 (mapReveal +5R) + 모든 Ghost 도주 -1
    s = { ...s, meta: { ...s.meta, mapReveal: (s.meta.mapReveal || 0) + 5 } };
    const ps = s.players.map(pp => pp.role === 'ghost' && !pp.defeated ? { ...pp, wanted: (pp.wanted || 0) + 1 } : pp);
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, data: (ps[playerIdx].resources.data || 0) + 3, influence: (ps[playerIdx].resources.influence || 0) + 1 } };
    s = { ...s, players: ps };
    s = logEntry(s, `📡 P${playerIdx} [${p.specific}] · Ghost 추적 → 모든 Ghost 수배+1, 자기 📡+3 🎙+1`);
    s = raiseTrack(s, playerIdx, 'security', 1, 'Ghost 추적');
    if (s.players[0].role === 'ghost' && playerIdx !== 0) {
      s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'ghost_track', detail: '수배+1' } };
    }
  }
  if (effect.lock_zone || effect.quarantine) {
    // HELIX QUARANTINE — 자사 구역 격리 → 요새+2 + ₵+3
    const cur = s.players[playerIdx];
    if (cur.position && s.map[cur.position]) {
      const newMap = { ...s.map, [cur.position]: { ...s.map[cur.position], fortified: (s.map[cur.position].fortified || 0) + 2 } };
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (cur.resources.credit || 0) + 3 } };
      s = { ...s, map: newMap, players: ps };
      s = logEntry(s, `🦠 P${playerIdx} [${cur.specific}] · 격리 (${cur.position} 요새+2 ₵+3)`);
      s = raiseTrack(s, playerIdx, 'mfg', 1, '격리');
    }
  }
  if (effect.steal_op) {
    // HELIX HARVEST — 적 OPERATIVE 탈취 → 적 구역 1곳 자사 점령 + ₵+5
    const enemyZones = Object.entries(s.map).filter(([c, cell]) => cell.owner !== null && cell.owner !== undefined && cell.owner !== playerIdx && s.players[cell.owner]?.role !== 'ghost');
    if (enemyZones.length > 0) {
      const [coord, cell] = rand(enemyZones);
      const newMap = { ...s.map, [coord]: { ...cell, owner: playerIdx, fortified: 0 } };
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 5 } };
      s = { ...s, map: newMap, players: ps };
      s = logEntry(s, `🌾 P${playerIdx} [${p.specific}] · 자원 탈취 ${coord} 점령 ₵+5`);
      s = raiseTrack(s, playerIdx, 'party', 1, '탈취');
    }
  }
  if (effect.revive) {
    // HELIX CLONE_DECOY — Ghost 1명 부활 (이미 사망한 Ghost) + ₵+4 + party 트랙
    const deadGhost = s.players.find(pp => pp.role === 'ghost' && pp.defeated);
    const ps = [...s.players];
    if (deadGhost) {
      const dIdx = s.players.indexOf(deadGhost);
      ps[dIdx] = { ...ps[dIdx], defeated: false, hp: Math.floor(ps[dIdx].maxHp / 2) };
      s = { ...s, players: ps };
      s = logEntry(s, `🧬 P${playerIdx} · 클론 부활 → P${dIdx} ${deadGhost.specific} HP ${ps[dIdx].hp}`);
      s = recordHighlight(s, 'defeat_revive', playerIdx);  // v0.9.1
    }
    const ps2 = [...s.players];
    ps2[playerIdx] = { ...ps2[playerIdx], resources: { ...ps2[playerIdx].resources, credit: (ps2[playerIdx].resources.credit || 0) + 4 } };
    s = { ...s, players: ps2 };
    s = logEntry(s, `🧬 P${playerIdx} · 클론 디코이 ₵+4`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '클론');
  }
  if (effect.ghost_move) {
    // IRONWALL MARTIAL_LAW — Ghost 이동 -1 효과 시뮬: heat+2 + ₵+3 + combat 트랙
    s = { ...s, heat: Math.min(10, s.heat + 2) };
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🚓 P${playerIdx} [${p.specific}] · 계엄령 (heat+2 ₵+3)`);
    s = raiseTrack(s, playerIdx, 'combat', 1, '계엄령');
  }
  if (effect.crash_target) {
    // INVEST_HEAVY/HOSTILE_BID — 타깃 블록 주가 폭락 + ₵+5 + mfg
    const blocs = Object.keys(s.stocks);
    const cur = s.players[playerIdx];
    const targets = blocs.filter(bl => !(cur.role === 'bloc' && cur.specific === bl));
    if (targets.length > 0) {
      const target = rand(targets);
      const newStocks = { ...s.stocks, [target]: Math.max(1, s.stocks[target] - effect.crash_target) };
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (cur.resources.credit || 0) + 5 } };
      s = { ...s, stocks: newStocks, players: ps };
      s = logEntry(s, `📉 P${playerIdx} · ${target} 적대 입찰 (주가-${effect.crash_target} ₵+5)`);
      s = raiseTrack(s, playerIdx, 'mfg', 1, '적대 입찰');
    }
  }
  if (effect.remove_scandals || effect.clear_ghost_wanted) {
    // 평판 청소 → 자신 or 아군 쿨
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🧹 P${playerIdx} · 평판 청소 ★+2`);
  }

  // v0.7.1: MOLE mini-raid 헬퍼 — 인접 Bloc 자동 중립화
  // 50% 확률로만 발동, 50% 확률은 평판+1만 (정찰 정도)
  function tryMoleMiniRaid(state, pIdx, label) {
    const cur = state.players[pIdx];
    if (cur.role !== 'ghost' || !cur.position) return state;
    const adj = coordsAdj(cur.position).concat([cur.position]);
    const blocCoord = adj.find(c => state.map[c]?.owner != null && state.players[state.map[c].owner]?.role === 'bloc' && !state.players[state.map[c].owner]?.defeated);
    if (!blocCoord) return state;
    // 50% 확률 발동
    if (Math.random() < 0.5) {
      const ps0 = [...state.players];
      ps0[pIdx] = { ...ps0[pIdx], resources: { ...ps0[pIdx].resources, rep: (ps0[pIdx].resources.rep || 0) + 1 } };
      let s0 = { ...state, players: ps0 };
      s0 = logEntry(s0, `🕷 P${pIdx} · ${label} 정찰 (★+1, mini-raid 미발동)`);
      return s0;
    }
    const bcell = state.map[blocCoord];
    const bowner = state.players[bcell.owner];
    const newStocks = { ...state.stocks, [bowner.specific]: Math.max(1, state.stocks[bowner.specific] - 2) };
    const ps2 = [...state.players];
    ps2[pIdx] = { ...ps2[pIdx], resources: { ...ps2[pIdx].resources, rep: (ps2[pIdx].resources.rep || 0) + 2 } };
    const newMap = { ...state.map, [blocCoord]: { ...bcell, owner: null, fortified: 0, building: null } };
    let s2 = { ...state, players: ps2, stocks: newStocks, map: newMap };
    s2.meta = { ...s2.meta, raidsThisGame: { ...s2.meta.raidsThisGame, [pIdx]: (s2.meta.raidsThisGame[pIdx] || 0) + 1 } };
    s2 = logEntry(s2, `🕷 P${pIdx} · ${label} mini-raid → ${blocCoord} ${bowner.specific} 중립화 ★+2 주가-2`);
    s2 = recordHighlight(s2, 'first_mini_raid', pIdx);  // v0.9.1
    if (bcell.zone === 'nex') s2 = recordHighlight(s2, 'first_nexus_claim', pIdx);
    return s2;
  }
  // === v0.6.6c: BLADE 효과 강화 + combat 트랙
  if (effect.execute) {
    // v0.6.6c: 처형 강화 — ★+5 + combat 트랙 + 인접 Bloc mini-raid (★+6→+5 미세 조정)
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 5 }, wanted: (ps[playerIdx].wanted || 0) + 1 };
    s = { ...s, players: ps };
    s = logEntry(s, `🔪 P${playerIdx} · 처형 · ★+5, 수배+1`);
    s = raiseTrack(s, playerIdx, 'combat', 1, '처형');
    // BLADE mini-raid (인접 Bloc 자동 중립화)
    const cur = s.players[playerIdx];
    if (cur.role === 'ghost' && cur.position) {
      const adj = coordsAdj(cur.position).concat([cur.position]);
      const blocCoord = adj.find(c => s.map[c]?.owner != null && s.players[s.map[c].owner]?.role === 'bloc' && !s.players[s.map[c].owner]?.defeated);
      if (blocCoord) {
        const bcell = s.map[blocCoord];
        const bowner = s.players[bcell.owner];
        const newStocks = { ...s.stocks, [bowner.specific]: Math.max(1, s.stocks[bowner.specific] - 2) };
        const ps2 = [...s.players];
        ps2[playerIdx] = { ...ps2[playerIdx], resources: { ...ps2[playerIdx].resources, rep: (ps2[playerIdx].resources.rep || 0) + 2 } };
        const newMap = { ...s.map, [blocCoord]: { ...bcell, owner: null, fortified: 0, building: null } };
        s = { ...s, players: ps2, stocks: newStocks, map: newMap };
        s.meta = { ...s.meta, raidsThisGame: { ...s.meta.raidsThisGame, [playerIdx]: (s.meta.raidsThisGame[playerIdx] || 0) + 1 } };
        s = logEntry(s, `🔪 P${playerIdx} · 처형 mini-raid → ${blocCoord} 중립화 ★+2`);
      }
    }
  }
  if (effect.frenzy || effect.atk_per_hp) {
    // v0.6.6c: 광폭화 강화 — bonus +2 + combat 트랙
    const curP = s.players[playerIdx];
    const bonus = Math.floor((curP.hp / curP.maxHp) * 3);
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + bonus + 3 }, wanted: (ps[playerIdx].wanted || 0) + 1 };
    s = { ...s, players: ps };
    s = logEntry(s, `🩸 P${playerIdx} · 광폭 (HP%) · ★+${bonus+3}`);
    s = raiseTrack(s, playerIdx, 'combat', 1, '광폭');
  }
  if (effect.hp_to_1 || effect.last_stand) {
    // v0.6.6c: 최후 저항 강화 — ★+8 + combat LV5 부활 + raid count +1
    const curP = s.players[playerIdx];
    if (curP.hp > 1) {
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], hp: 1, resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 8 }, wanted: (ps[playerIdx].wanted || 0) + 2 };
      s = { ...s, players: ps };
      s.meta = { ...s.meta, raidsThisGame: { ...s.meta.raidsThisGame, [playerIdx]: (s.meta.raidsThisGame[playerIdx] || 0) + 1 } };
      s = logEntry(s, `⚰️ P${playerIdx} · 최후 저항 · HP→1, ★+8, 레이드+1`);
      s = raiseTrack(s, playerIdx, 'combat', 1, '최후 저항');
      s = recordHighlight(s, 'last_stand_activate', playerIdx);  // v0.9.1
    }
  }
  if (effect.negate || effect.shield || effect.human_shield) {
    // 방어: HP 회복 + 한 번 판정 감면
    const curP = s.players[playerIdx];
    const healed = Math.min(curP.maxHp, curP.hp + 2);
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], hp: healed };
    s = { ...s, players: ps };
    s = logEntry(s, `🛡 P${playerIdx} · 방어 태세 · HP+2 (→${healed})`);
  }
  // v0.6.6c: CIPHER 신규 효과 폴백 (mimic, transfer_attack, wipe_log, slow_target, redirect)
  if (effect.mimic || effect.transfer_attack || effect.redirect) {
    // 미믹/공격 전이 → ★+5 + ₵+3 + mfg 트랙
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 5, credit: (ps[playerIdx].resources.credit || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🎭 P${playerIdx} · 위장/전이 ★+5 ₵+3`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '위장 전이');
  }
  if (effect.wipe_log || effect.slow_target) {
    // 로그 삭제/타깃 둔화 → 수배 0 + ★+4 + 📡+2
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], wanted: 0, resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 4, data: (ps[playerIdx].resources.data || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🗑 P${playerIdx} · 로그 말소 · 수배 0 ★+4 📡+2`);
    s = raiseTrack(s, playerIdx, 'security', 1, '로그 말소');
  }
  if (effect.def_ignore || effect.steal) {
    // 방어 무시/탈취 → ★+5 + ₵+4 + Ghost mini-raid
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 5, credit: (ps[playerIdx].resources.credit || 0) + 4 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🔓 P${playerIdx} · 방어 무시/탈취 ★+5 ₵+4`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '탈취');
    // CIPHER mini-raid: 인접 Bloc 자동 (해킹형 mini-raid)
    const cur = s.players[playerIdx];
    if (cur.role === 'ghost' && cur.position) {
      const adj = coordsAdj(cur.position).concat([cur.position]);
      const blocCoord = adj.find(c => s.map[c]?.owner != null && s.players[s.map[c].owner]?.role === 'bloc' && !s.players[s.map[c].owner]?.defeated);
      if (blocCoord) {
        const bcell = s.map[blocCoord];
        const bowner = s.players[bcell.owner];
        const newStocks = { ...s.stocks, [bowner.specific]: Math.max(1, s.stocks[bowner.specific] - 2) };
        const ps2 = [...s.players];
        ps2[playerIdx] = { ...ps2[playerIdx], resources: { ...ps2[playerIdx].resources, rep: (ps2[playerIdx].resources.rep || 0) + 2 } };
        const newMap = { ...s.map, [blocCoord]: { ...bcell, owner: null, fortified: 0, building: null } };
        s = { ...s, players: ps2, stocks: newStocks, map: newMap };
        s.meta = { ...s.meta, raidsThisGame: { ...s.meta.raidsThisGame, [playerIdx]: (s.meta.raidsThisGame[playerIdx] || 0) + 1 } };
        s = logEntry(s, `💾 P${playerIdx} · 해킹 mini-raid → ${blocCoord} ${bowner.specific} 중립화 ★+2`);
      }
    }
  }
  if (effect.point_blank || effect.surprise || effect.same_zone_atk) {
    // v0.6.6c: 근거리·기습 강화 → ★+5 ₵+3 + combat 트랙
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 5, credit: (ps[playerIdx].resources.credit || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🎯 P${playerIdx} · 근거리·기습 · ★+5, ₵+3`);
    s = raiseTrack(s, playerIdx, 'combat', 1, '근거리');
  }
  // v0.6.6c: BLADE 신규 효과 폴백 — 모든 처형/공격 변종에 평판 + combat
  if (effect.assassin || effect.atk_twice || effect.atk_x3_retort || effect.atk_reroll || effect.force_enter) {
    // 암살/연속 공격 → ★+3 + combat 트랙 + Bloc mini-raid (★+5→+3 너프)
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `⚔️ P${playerIdx} · 연속 공격 ★+3`);
    s = raiseTrack(s, playerIdx, 'combat', 1, '연속 공격');
    const cur = s.players[playerIdx];
    if (cur.role === 'ghost' && cur.position) {
      const adj = coordsAdj(cur.position).concat([cur.position]);
      const blocCoord = adj.find(c => s.map[c]?.owner != null && s.players[s.map[c].owner]?.role === 'bloc' && !s.players[s.map[c].owner]?.defeated);
      if (blocCoord) {
        const bcell = s.map[blocCoord];
        const bowner = s.players[bcell.owner];
        const newStocks = { ...s.stocks, [bowner.specific]: Math.max(1, s.stocks[bowner.specific] - 2) };
        const ps2 = [...s.players];
        ps2[playerIdx] = { ...ps2[playerIdx], resources: { ...ps2[playerIdx].resources, rep: (ps2[playerIdx].resources.rep || 0) + 2 } };
        const newMap = { ...s.map, [blocCoord]: { ...bcell, owner: null, fortified: 0, building: null } };
        s = { ...s, players: ps2, stocks: newStocks, map: newMap };
        s.meta = { ...s.meta, raidsThisGame: { ...s.meta.raidsThisGame, [playerIdx]: (s.meta.raidsThisGame[playerIdx] || 0) + 1 } };
        s = logEntry(s, `⚔️ P${playerIdx} · 암살 mini-raid → ${blocCoord} ★+2`);
      }
    }
  }
  if (effect.protect_ally || effect.absorb || effect.def_infinite_to_1) {
    // 호위/방어 → HP+3 + ★+3 + security 트랙
    const cur = s.players[playerIdx];
    const ps = [...s.players];
    ps[playerIdx] = { ...cur, hp: Math.min(cur.maxHp, cur.hp + 3), resources: { ...cur.resources, rep: (cur.resources.rep || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🛡 P${playerIdx} · 호위·방어 HP+3 ★+3`);
    s = raiseTrack(s, playerIdx, 'security', 1, '호위');
  }
  if (effect.block_adj || effect.enemy_spd || effect.def_penalty || effect.def_zero) {
    // 적 봉쇄/속도 둔화 → ★+3 + ₵+3 + combat 트랙
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 3, credit: (ps[playerIdx].resources.credit || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🚧 P${playerIdx} · 적 봉쇄 ★+3 ₵+3`);
    s = raiseTrack(s, playerIdx, 'combat', 1, '봉쇄');
  }
  // MOLE — 내부 침투 계열 (v0.7.1: 모든 internal 효과에 mini-raid 추가 — Bloc 정보 누출 = 영향력 약화)
  if (effect.peek_bloc || effect.steal_card) {
    // 블록 내부 엿보기 → ★+5 ₵+4 + party 트랙 + MOLE mini-raid
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 5, credit: (ps[playerIdx].resources.credit || 0) + 4 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🕵 P${playerIdx} · 내부 엿보기 · ★+5, ₵+4`);
    s = raiseTrack(s, playerIdx, 'party', 1, '내부 엿보기');
    if (s.players[playerIdx]?.specific === 'MOLE') s = tryMoleMiniRaid(s, playerIdx, '엿보기');
  }
  if (effect.bloc_resource || effect.vote_flip) {
    // Bloc 자원 탈취·투표 조작 → ★+5 ₵+5 (mini-raid 제거 — 너무 잦음)
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 5, credit: (ps[playerIdx].resources.credit || 0) + 5 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🗳 P${playerIdx} · Bloc 자원/투표 조작 · ★+5, ₵+5`);
  }
  if (effect.frame || effect.swap_blame) {
    // 누명 씌우기 → 수배-2 + ★+4 + party 트랙 (mini-raid 제거)
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], wanted: Math.max(0, (ps[playerIdx].wanted || 0) - 2), resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 4 } };
    s = { ...s, players: ps };
    s = logEntry(s, `👺 P${playerIdx} · 누명 · 수배-2, ★+4`);
    s = raiseTrack(s, playerIdx, 'party', 1, '누명');
  }
  if (effect.infiltrate || effect.disguise || effect.bypass_veil) {
    // v0.6.5d: 침투 강화 — 렙+3, 데이터+2, 경호 트랙 +1, NPC 시그널 +1
    s = { ...s, meta: { ...s.meta, mapReveal: (s.meta.mapReveal || 0) + 3 } };
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 3, data: (ps[playerIdx].resources.data || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🎭 P${playerIdx} · 위장 침투 강화 · 지도 3R 노출, ★+3, 📡+2`);
    s = raiseTrack(s, playerIdx, 'security', 1, '침투');
    const npcIdx = s.players.findIndex(pp => pp.isNpc && pp.signal && pp.signal.revealed < pp.signal.max);
    if (npcIdx >= 0) s = revealSignal(s, npcIdx, playerIdx, 1);
    // v0.6.5d: MOLE 침투 mini-raid — 가장 가까운 Bloc 구역 자동 잠입 (방어 우회)
    const meP = s.players[playerIdx];
    if (meP.role === 'ghost' && meP.position) {
      const adj = coordsAdj(meP.position).concat([meP.position]);
      const blocCoord = adj.find(c => s.map[c]?.owner != null && s.players[s.map[c].owner]?.role === 'bloc' && !s.players[s.map[c].owner]?.defeated);
      if (blocCoord) {
        const bcell = s.map[blocCoord];
        const bowner = s.players[bcell.owner];
        const newStocks = { ...s.stocks, [bowner.specific]: Math.max(1, s.stocks[bowner.specific] - 2) };
        const ps2 = [...s.players];
        ps2[playerIdx] = { ...ps2[playerIdx], resources: { ...ps2[playerIdx].resources, rep: (ps2[playerIdx].resources.rep || 0) + 2 } };
        const newMap = { ...s.map, [blocCoord]: { ...bcell, owner: null, fortified: 0, building: null } };
        s = { ...s, players: ps2, stocks: newStocks, map: newMap };
        s.meta = { ...s.meta, raidsThisGame: { ...s.meta.raidsThisGame, [playerIdx]: (s.meta.raidsThisGame[playerIdx] || 0) + 1 } };
        s = logEntry(s, `🕷 P${playerIdx} · 침투 mini-raid → ${blocCoord} ${bowner.specific} 중립화 (★+2 주가-2)`);
      }
    }
  }
  if (effect.scandal || effect.stock_dmg) {
    // v0.7.1: 스캔들 강화 → 주가-3, ★+4 + MOLE mini-raid
    const blocs = Object.keys(s.stocks);
    const pick = rand(blocs);
    const newStocks = { ...s.stocks, [pick]: Math.max(1, s.stocks[pick] - 3) };
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 4 } };
    s = { ...s, stocks: newStocks, players: ps };
    s = logEntry(s, `💣 P${playerIdx} · ${pick} 스캔들 · 주가-3, ★+4`);
    s = raiseTrack(s, playerIdx, 'party', 1, '스캔들');
    if (s.players[playerIdx]?.specific === 'MOLE') s = tryMoleMiniRaid(s, playerIdx, '스캔들');
  }
  if (effect.permanent_clear) {
    // 영구 흔적 삭제: 수배 완전 초기화 + 렙+2
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], wanted: 0, resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🧹 P${playerIdx} · 영구 삭제 · 수배→0, ★+2`);
  }
  // RIGGER — 기술·제작 계열
  if (effect.emp_pulse || effect.tech_breach) {
    // EMP/해킹: 타겟 주가-3 + 데이터+2 + 렙+2 (v0.5.14)
    const blocs = Object.keys(s.stocks);
    const pick = rand(blocs);
    const newStocks = { ...s.stocks, [pick]: Math.max(1, s.stocks[pick] - 3) };
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, data: (ps[playerIdx].resources.data || 0) + 2, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
    s = { ...s, stocks: newStocks, players: ps };
    s = logEntry(s, `⚡ P${playerIdx} · EMP/브리치 · ${pick} 주가-3, 📡+2, ★+2`);
  }
  if (effect.field_craft || effect.jury_rig) {
    // v0.6.6: 현장 제작 강화 — ⚙+5 🔩+3 ★+4 + mfg 트랙 +1
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, parts: (ps[playerIdx].resources.parts || 0) + 5, weapons: (ps[playerIdx].resources.weapons || 0) + 3, rep: (ps[playerIdx].resources.rep || 0) + 4 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🔧 P${playerIdx} · 현장 제작 · ⚙+5, 🔩+3, ★+4`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '현장 제작');
  }
  // v0.6.6: 신규 RIGGER 효과 키 폴백 — repair / salvage / craft_item / zone_shield / zone_disable / atk_range / multi_target / disable_elec
  if (effect.repair || effect.salvage) {
    // 수리/자원 회수 → HP+3 + ⚙+3 + ★+3 + mfg 트랙
    const ps = [...s.players];
    const cur = ps[playerIdx];
    ps[playerIdx] = { ...cur, hp: Math.min(cur.maxHp, cur.hp + 3), resources: { ...cur.resources, parts: (cur.resources.parts || 0) + 3, rep: (cur.resources.rep || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🔩 P${playerIdx} · 수리/자원 회수 · HP+3 ⚙+3 ★+3`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '수리');
  }
  if (effect.craft_item || effect.zone_shield) {
    // 아이템 제작/구역 차폐 → 무기+2 + 부품+2 + 요새화+1 + 렙+3
    const cur = s.players[playerIdx];
    const ps = [...s.players];
    ps[playerIdx] = { ...cur, resources: { ...cur.resources, weapons: (cur.resources.weapons || 0) + 2, parts: (cur.resources.parts || 0) + 2, rep: (cur.resources.rep || 0) + 3 } };
    s = { ...s, players: ps };
    if (cur.position && s.map[cur.position]) {
      s = { ...s, map: { ...s.map, [cur.position]: { ...s.map[cur.position], fortified: (s.map[cur.position].fortified || 0) + 1 } } };
    }
    s = logEntry(s, `🛡 P${playerIdx} · 차폐/제작 · 🔩+2 ⚙+2 요새+1 ★+3`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '차폐');
  }
  if (effect.atk_range || effect.multi_target || effect.disable_elec || effect.zone_disable) {
    // 드론 광역 공격/EMP → 인접 Bloc 자동 mini-raid + 렙+3 + 주가-2
    const cur = s.players[playerIdx];
    const ps = [...s.players];
    ps[playerIdx] = { ...cur, resources: { ...cur.resources, rep: (cur.resources.rep || 0) + 3, data: (cur.resources.data || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🛰 P${playerIdx} · 드론 광역 ★+3 📡+2`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '드론 광역');
    // RIGGER mini-raid (인접 Bloc 자동 중립화 — MOLE infiltrate와 동일 패턴)
    if (cur.role === 'ghost' && cur.position) {
      const adj = coordsAdj(cur.position).concat([cur.position]);
      const blocCoord = adj.find(c => s.map[c]?.owner != null && s.players[s.map[c].owner]?.role === 'bloc' && !s.players[s.map[c].owner]?.defeated);
      if (blocCoord) {
        const bcell = s.map[blocCoord];
        const bowner = s.players[bcell.owner];
        const newStocks = { ...s.stocks, [bowner.specific]: Math.max(1, s.stocks[bowner.specific] - 2) };
        const ps2 = [...s.players];
        ps2[playerIdx] = { ...ps2[playerIdx], resources: { ...ps2[playerIdx].resources, rep: (ps2[playerIdx].resources.rep || 0) + 2 } };
        const newMap = { ...s.map, [blocCoord]: { ...bcell, owner: null, fortified: 0, building: null } };
        s = { ...s, players: ps2, stocks: newStocks, map: newMap };
        s.meta = { ...s.meta, raidsThisGame: { ...s.meta.raidsThisGame, [playerIdx]: (s.meta.raidsThisGame[playerIdx] || 0) + 1 } };
        s = logEntry(s, `🛰 P${playerIdx} · 드론 mini-raid → ${blocCoord} ${bowner.specific} 중립화 ★+2 주가-2`);
      }
    }
  }
  if (effect.shield_gen || effect.drone_swarm || effect.overclock) {
    // 드론·차폐: 다음 판정 +2 + 렙+3 (v0.5.14 강화)
    s = { ...s, meta: { ...s.meta, attackBonusOnce: (s.meta.attackBonusOnce || 0) + 2 } };
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 3 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🛰 P${playerIdx} · 드론/차폐 · 다음 판정+2, ★+3`);
  }
  if (effect.disable_tl || effect.force_tl_down) {
    // TL 방해 → 랜덤 Bloc TL 1 하락 + 렙+3
    const rivalBlocs = s.players.filter((pp, i) => i !== playerIdx && !pp.defeated && pp.role === 'bloc' && pp.tl > 1);
    if (rivalBlocs.length > 0) {
      const target = rand(rivalBlocs);
      const tIdx = s.players.indexOf(target);
      const ps = [...s.players];
      ps[tIdx] = { ...ps[tIdx], tl: Math.max(1, (ps[tIdx].tl || 1) - 1) };
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 3 } };
      s = { ...s, players: ps };
      s = logEntry(s, `📉 P${playerIdx} · P${tIdx} TL 방해 (→${ps[tIdx].tl}), ★+3`);
    }
  }
  if (effect.temp_tl) {
    // v0.8.5: OVERCLOCK (RIGGER) — 한 라운드 TL+1 → 다음 R 카드+1, 부품+2, 렙+2
    s = { ...s, meta: { ...s.meta, extraDrawNext: (s.meta.extraDrawNext || 0) + 1 } };
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 2, parts: (ps[playerIdx].resources.parts || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `⚡ P${playerIdx} · 오버클록 · 다음 R 카드+1, ⚙+2, ★+2`);
    s = raiseTrack(s, playerIdx, 'mfg', 1, '오버클록');
  }
  if (effect.transfer_ally || effect.fuel) {
    // v0.6.6c: 보급 강화 → ₵+4 ⚙+2 + transport 트랙
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 4, parts: (ps[playerIdx].resources.parts || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `⛽ P${playerIdx} · 보급 · ₵+4, ⚙+2`);
    s = raiseTrack(s, playerIdx, 'transport', 1, '보급');
  }
  if (effect.untrack || effect.shortcut || effect.ignore_obstacles || effect.ignore_all || effect.move_3_nowalls || effect.move_any || effect.teleport) {
    // v0.6.6c: 경로 우회 → 수배-1 ★+2 + transport 트랙 (★+3→2 너프)
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], wanted: Math.max(0, (ps[playerIdx].wanted || 0) - 1), resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🚶 P${playerIdx} · 경로 우회 · 수배-1, ★+2`);
    s = raiseTrack(s, playerIdx, 'transport', 1, '경로 우회');
  }
  if (effect.leave_fire || effect.burn_behind || effect.smuggle) {
    // v0.6.6c: 밀수/방화 → ₵+4 ★+2 + transport 트랙 (★+3→2)
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: (ps[playerIdx].resources.credit || 0) + 4, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🔥 P${playerIdx} · 밀수/방화 · ₵+4, ★+2`);
    s = raiseTrack(s, playerIdx, 'transport', 1, '밀수');
  }
  // v0.6.6c: DRIFTER 신규 — ram_atk
  if (effect.ram_atk) {
    // 충각: 같은 구역 적 HP-(ram_atk) + ★+3 + combat 트랙
    const cur = s.players[playerIdx];
    const enemies = s.players.filter((pp, i) => i !== playerIdx && !pp.defeated && pp.position === cur.position);
    const ps = [...s.players];
    if (enemies.length > 0) {
      const target = enemies[0];
      const tIdx = s.players.indexOf(target);
      ps[tIdx] = { ...ps[tIdx], hp: Math.max(0, ps[tIdx].hp - effect.ram_atk) };
      s = logEntry(s, `🚛 P${playerIdx} · 충각 → P${tIdx} HP-${effect.ram_atk}`);
    }
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 3 } };
    s = { ...s, players: ps };
    s = raiseTrack(s, playerIdx, 'combat', 1, '충각');
  }
  if (effect.break_veil) {
    // 베일 해제 → 데이터+1 + 렙+1
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, data: (ps[playerIdx].resources.data || 0) + 1, rep: (ps[playerIdx].resources.rep || 0) + 1 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🔓 P${playerIdx} · 베일 해제 · 📡+1, ★+1`);
  }
  if (effect.force_enter) {
    // 강제 진입 → 크레딧+1 + 렙+2
    const ps = [...s.players];
    ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, rep: (ps[playerIdx].resources.rep || 0) + 2 } };
    s = { ...s, players: ps };
    s = logEntry(s, `🚪 P${playerIdx} · 강제 진입 · ★+2`);
  }

  // === Bloc 신규 효과들 ===
  // 임의 블록 N주 자동 매수 (저가 순)
  if (effect.stock_buy_any) {
    const pNow = s.players[playerIdx];
    const blocs = Object.entries(s.stocks).filter(([bl]) => !(pNow.role === 'bloc' && pNow.specific === bl));
    blocs.sort((a, b) => a[1] - b[1]);
    let bought = 0;
    let newPlayerStocks = { ...pNow.stocks };
    let remainingCredit = pNow.resources.credit || 0;
    for (const [bl, price] of blocs) {
      while (bought < effect.stock_buy_any && remainingCredit >= price) {
        newPlayerStocks[bl] = (newPlayerStocks[bl] || 0) + 1;
        remainingCredit -= price;
        bought++;
      }
      if (bought >= effect.stock_buy_any) break;
    }
    if (bought > 0) {
      const ps = [...s.players];
      ps[playerIdx] = { ...ps[playerIdx], resources: { ...ps[playerIdx].resources, credit: remainingCredit }, stocks: newPlayerStocks };
      s = { ...s, players: ps };
      s = logEntry(s, `📈 P${playerIdx} [${p.specific}] · ${bought}주 자동 매수 (잔액 ₵${remainingCredit})`);
    } else {
      s = logEntry(s, `📈 P${playerIdx} · 매수 실패 (₵ 부족)`);
    }
  }

  // 현위치 요새화 — 방어력 +1 플래그 (단순화: 다음 레이드 threshold +1)
  if (effect.fortify_here) {
    const pNow = s.players[playerIdx];
    const cellHere = s.map[pNow.position];
    if (cellHere && cellHere.owner === playerIdx) {
      const newMap = { ...s.map, [pNow.position]: { ...cellHere, fortified: (cellHere.fortified || 0) + 1 } };
      s = { ...s, map: newMap };
      s = logEntry(s, `🛡 P${playerIdx} [${p.specific}] · ${pNow.position} 요새화 (방어 +1)`);
    } else {
      s = logEntry(s, `🛡 P${playerIdx} · 요새화 실패 (자사 구역 아님)`);
    }
  }

  // 용병 고용 — 랜덤 Bloc 구역(자사 제외) 주가 -3
  if (effect.hire_raid) {
    const targets = Object.entries(s.map).filter(([c, cell]) => cell.owner !== null && cell.owner !== undefined && cell.owner !== playerIdx && s.players[cell.owner]?.role === 'bloc');
    if (targets.length > 0) {
      const [coord, cell] = rand(targets);
      const targetBloc = s.players[cell.owner].specific;
      const targetIdx = cell.owner;
      const newStocks = { ...s.stocks, [targetBloc]: Math.max(1, s.stocks[targetBloc] - 3) };
      const newMap = { ...s.map, [coord]: { ...cell, owner: null } };
      s = { ...s, stocks: newStocks, map: newMap };
      s = logEntry(s, `🗡 P${playerIdx} [${p.specific}] · 용병 고용 → ${coord} ${targetBloc} 타격 (주가-3, 중립화)`);
      if (targetIdx === 0 && playerIdx !== 0) {
        s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'hire_raid', detail: `${coord} 잃음, 주가-3` } };
      }
    } else {
      s = logEntry(s, `🗡 P${playerIdx} · 용병 고용 실패 (타 Bloc 구역 없음)`);
    }
  }

  // Ghost 전원 수배 +N
  if (effect.ghost_wanted_all) {
    const ps = s.players.map(pp => pp.role === 'ghost' && !pp.defeated ? { ...pp, wanted: (pp.wanted || 0) + effect.ghost_wanted_all } : pp);
    s = { ...s, players: ps };
    s = logEntry(s, `🚨 P${playerIdx} [${p.specific}] · Ghost 전원 수배 +${effect.ghost_wanted_all}`);
    if (s.players[0].role === 'ghost' && playerIdx !== 0) {
      s.meta = { ...s.meta, lastTargetedBy: { attacker: playerIdx, effectKey: 'ghost_wanted_all', detail: `수배 +${effect.ghost_wanted_all}` } };
    }
  }

  return s;
}

