// v0.7.3: 11×11 정식 맵 (121 cells) — Ashgrid 도시 전체
// 중앙 F6에 NEXUS, 5 Bloc은 외곽 사방, Ghost 시작은 더 분산
// zone 분포: ruin/home/aux 다수, bank/data/arms/work/heal/club/cop/port 골고루
const MAP_11x11_ZONES = [
  // 코너 (외곽) — ruin / home 위주
  'ruin','home','ruin','aux','data','bank','data','aux','ruin','home','ruin',
  'home','aux','work','arms','data','home','data','arms','work','aux','home',
  'ruin','work','heal','club','aux','heal','aux','club','heal','work','ruin',
  'aux','arms','club','port','work','data','work','port','club','arms','aux',
  'data','data','aux','work','heal','arms','heal','work','aux','data','data',
  'bank','home','heal','data','arms','nex', 'arms','data','heal','home','bank',  // 중앙 F6 = NEXUS
  'data','data','aux','work','heal','arms','heal','work','aux','data','data',
  'aux','arms','club','port','work','data','work','port','club','arms','aux',
  'ruin','work','heal','club','aux','heal','aux','club','heal','work','ruin',
  'home','aux','work','arms','data','home','data','arms','work','aux','home',
  'ruin','home','ruin','aux','data','bank','data','aux','ruin','home','ruin',
];
const MAP_11x11 = (() => {
  const cells = [];
  for (let r = 0; r < 11; r++) {
    for (let c = 0; c < 11; c++) {
      const coord = String.fromCharCode(65 + c) + (r + 1);
      const zone = MAP_11x11_ZONES[r * 11 + c];
      cells.push([coord, zone]);
    }
  }
  return cells;
})();

